@model Inquiry
@{
    ViewData["Title"] = "Inquiry Details";
    var detailRole = Context.Session.GetString("UserRole") ?? "";
    bool isStaff = detailRole == "Admin" || detailRole == "Employee";
    bool isClient = detailRole == "Client";
}

<div class="page-header d-flex align-items-start justify-content-between flex-wrap gap-2">
    <div>
        <h4>Inquiry Details</h4>
        <p>Full information for this lead</p>
    </div>
    <div class="d-flex gap-2">
        @if (isClient /*&& Model.StatusName == "Received"*/)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-brand px-3" style="font-size:.84rem;">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary px-3" style="font-size:.84rem;">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header-clean">
                <h6><i class="bi bi-building me-2" style="color:var(--brand);"></i>@Model.HotelName</h6>
                @if (Model.StatusName == "Received")
                {
                    <span class="badge" style="background:#DBEAFE;color:#1e40af;font-weight:700;">📥 Received</span>
                }
                else if (Model.StatusName == "In Progress")
                {
                    <span class="badge" style="background:#FEF3C7;color:#92400e;font-weight:700;">⚙ In Progress</span>
                }
                else if (Model.StatusName == "Completed")
                {
                    <span class="badge" style="background:#D1FAE5;color:#065f46;font-weight:700;">✅ Completed</span>
                }
            </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    @{
                        void Field(string label, string? value) {
                            <div class="col-sm-6">
                                <div style="font-size:.74rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:3px;">@label</div>
                                <div style="font-size:.88rem;font-weight:500;">@(value ?? "—")</div>
                            </div>
                        }
                    }
                    @{ Field("Hotel Name", Model.HotelName); }
                    @{ Field("Client Name", Model.ClientName); }
                    @{ Field("Client Number", Model.ClientNumber); }
                    @{ Field("City", Model.CityName); }
                    @{ Field("Module", Model.ModuleName); }
                    @{ Field("Status", Model.StatusName); }
                    @if (isStaff)
                    {
                        Field("Follow-up Date", Model.FollowupDate.HasValue ? Model.FollowupDate.Value.ToString("dd MMM yyyy") : "—");
                        <div class="col-sm-6">
                            <div style="font-size:.74rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:3px;">Payment Received</div>
                            <div style="font-size:.88rem;font-weight:500;">
                                @if (Model.PaymentReceived)
                                {
                                    <span class="badge text-bg-success">✓ Yes</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">✗ No</span>
                                }
                            </div>
                        </div>
                    }
                    @{ Field("Added By", Model.CreatedByName); }
                    @{ Field("Created", Model.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")); }
                    @{ Field("Updated", Model.UpdatedAt.ToString("dd MMM yyyy, hh:mm tt")); }
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Note))
                {
                    <hr style="border-color:var(--border);" />
                    <div>
                        <div style="font-size:.74rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:4px;">Note</div>
                        <p style="font-size:.88rem;margin:0;color:var(--text-main);">@Model.Note</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-body p-4">
                <div class="text-center mb-3">
                    <div style="width:60px;height:60px;border-radius:50%;background:var(--brand-soft);color:var(--brand);font-weight:700;font-size:1.3rem;display:flex;align-items:center;justify-content:center;margin:0 auto 10px;">
                        @(Model.ClientName.Length > 0 ? Model.ClientName[0].ToString().ToUpper() : "?")
                    </div>
                    <div style="font-weight:600;font-size:.95rem;">@Model.ClientName</div>
                    <div style="font-size:.8rem;color:var(--text-muted);">@Model.ClientNumber</div>
                </div>
                <hr style="border-color:var(--border);" />
                <div class="d-grid gap-2">
                    @if (isStaff)
                    {
                        @if (Model.StatusName == "Received")
                        {
                            <form asp-action="AdvanceStatus" asp-route-id="@Model.Id" method="post">
                                <button type="submit" class="btn btn-warning w-100" style="font-size:.83rem;">
                                    <i class="bi bi-arrow-right me-1"></i>Mark In Progress
                                </button>
                            </form>
                        }
                        else if (Model.StatusName == "In Progress")
                        {
                            <form asp-action="AdvanceStatus" asp-route-id="@Model.Id" method="post">
                                <button type="submit" class="btn btn-success w-100" style="font-size:.83rem;">
                                    <i class="bi bi-check-circle me-1"></i>Mark Completed
                                </button>
                            </form>
                        }
                        else if (Model.StatusName == "Completed")
                        {
                            <div class="alert alert-success py-2 px-3 mb-0" style="font-size:.83rem;">
                                <i class="bi bi-check-circle me-1"></i>Inquiry is completed
                            </div>
                        }
                    }
                    @if (isClient && Model.StatusName == "Received")
                    {
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                              onsubmit="return confirm('Delete this inquiry permanently?')">
                            <button type="submit" class="btn btn-outline-danger w-100" style="font-size:.83rem;">
                                <i class="bi bi-trash3 me-1"></i>Delete Inquiry
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
