@model Inquiry
@{
    ViewData["Title"] = "Inquiry Details";
    var detailRole = Context.Session.GetString("UserRole") ?? "";
    bool isStaff = detailRole == "Admin" || detailRole == "Employee";
    bool isClient = detailRole == "Client";

    string statusClass = Model.StatusName switch {
        "Received"    => "status-received",
        "In Progress" => "status-progress",
        "Completed"   => "status-completed",
        _             => "status-received"
    };
    string statusIcon = Model.StatusName switch {
        "Received"    => "bi-inbox-fill",
        "In Progress" => "bi-gear-fill",
        "Completed"   => "bi-check-circle-fill",
        _             => "bi-inbox-fill"
    };
    string avatarInitial = Model.ClientName.Length > 0
        ? Model.ClientName[0].ToString().ToUpper()
        : "?";
}

<style>
/* ═══════ DESIGN TOKENS ═══════ */
:root {
    --brand:        #4F46E5;
    --brand-light:  #EEF2FF;
    --brand-dark:   #3730A3;

    --success:      #059669;
    --success-bg:   #ECFDF5;
    --warning:      #D97706;
    --warning-bg:   #FFFBEB;
    --info:         #2563EB;
    --info-bg:      #EFF6FF;
    --danger:       #DC2626;
    --danger-bg:    #FEF2F2;

    --surface:      #FFFFFF;
    --surface-alt:  #F8FAFC;
    --border:       #E2E8F0;
    --text:         #1E293B;
    --text-sub:     #64748B;
    --text-muted:   #94A3B8;

    --radius:       12px;
    --radius-sm:    8px;
    --shadow-sm:    0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
    --shadow-md:    0 4px 16px rgba(0,0,0,.08);
    --shadow-lg:    0 12px 40px rgba(0,0,0,.10);
    --transition:   .25s cubic-bezier(.4,0,.2,1);
}

/* ═══════ PAGE WRAPPER ═══════ */
.iq-page {
    max-width: 1120px;
    margin: 0 auto;
    padding: 32px 20px 60px;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color: var(--text);
    animation: iq-fadeUp .5s ease-out both;
}
@@keyframes iq-fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* ═══════ TOP BAR ═══════ */
.iq-topbar {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 28px;
}
.iq-topbar-left h1 {
    font-size: 1.65rem;
    font-weight: 700;
    margin: 0 0 4px;
    letter-spacing: -.02em;
}
.iq-topbar-left p {
    margin: 0;
    color: var(--text-sub);
    font-size: .9rem;
}
.iq-topbar-actions {
    display: flex;
    gap: 10px;
    align-items: center;
}

/* ═══════ BUTTONS ═══════ */
.iq-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 9px 18px;
    border-radius: var(--radius-sm);
    font-size: .84rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: var(--transition);
    white-space: nowrap;
}
.iq-btn i { font-size: 1rem; }

.iq-btn-brand {
    background: var(--brand);
    color: #fff;
}
.iq-btn-brand:hover {
    background: var(--brand-dark);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(79,70,229,.35);
}
.iq-btn-outline {
    background: var(--surface);
    color: var(--text);
    border: 1.5px solid var(--border);
}
.iq-btn-outline:hover {
    border-color: var(--brand);
    color: var(--brand);
    background: var(--brand-light);
}
.iq-btn-warning {
    background: var(--warning);
    color: #fff;
}
.iq-btn-warning:hover {
    background: #B45309;
    transform: translateY(-1px);
}
.iq-btn-success {
    background: var(--success);
    color: #fff;
}
.iq-btn-success:hover {
    background: #047857;
    transform: translateY(-1px);
}
.iq-btn-danger-outline {
    background: transparent;
    color: var(--danger);
    border: 1.5px solid var(--danger);
}
.iq-btn-danger-outline:hover {
    background: var(--danger-bg);
}

/* ═══════ GRID LAYOUT ═══════ */
.iq-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 24px;
    align-items: start;
}

/* ═══════ CARD ═══════ */
.iq-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    transition: box-shadow var(--transition);
}
.iq-card:hover {
    box-shadow: var(--shadow-md);
}

/* ═══════ MAIN CARD HEADER ═══════ */
.iq-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px;
    border-bottom: 1px solid var(--border);
    background: var(--surface-alt);
}
.iq-hotel-name {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0;
    color: var(--text);
}

/* ═══════ STATUS BADGE ═══════ */
.iq-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 14px;
    border-radius: 999px;
    font-size: .78rem;
    font-weight: 600;
    letter-spacing: .02em;
    animation: iq-pop .4s ease-out both;
}
@@eyframes iq-pop {
    from { transform: scale(.85); opacity: 0; }
    to   { transform: scale(1); opacity: 1; }
}
.status-received    { background: var(--info-bg);    color: var(--info); }
.status-progress    { background: var(--warning-bg); color: var(--warning); }
.status-completed   { background: var(--success-bg); color: var(--success); }
.iq-status i { font-size: .85rem; }

/* ═══════ DETAIL FIELDS ═══════ */
.iq-fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    padding: 0;
}
.iq-field {
    padding: 16px 24px;
    border-bottom: 1px solid var(--border);
    transition: background var(--transition);
}
.iq-field:hover {
    background: var(--surface-alt);
}
.iq-field:nth-child(odd) {
    border-right: 1px solid var(--border);
}
.iq-field-label {
    font-size: .75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--text-muted);
    margin-bottom: 4px;
}
.iq-field-value {
    font-size: .9rem;
    font-weight: 600;
    color: var(--text);
    word-break: break-word;
}

/* payment badge */
.iq-pay-yes {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: var(--success-bg);
    color: var(--success);
    padding: 3px 10px;
    border-radius: 999px;
    font-size: .78rem;
    font-weight: 600;
}
.iq-pay-no {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: #F1F5F9;
    color: var(--text-muted);
    padding: 3px 10px;
    border-radius: 999px;
    font-size: .78rem;
    font-weight: 600;
}

/* ═══════ NOTE BLOCK ═══════ */
.iq-note {
    margin: 0;
    padding: 20px 24px;
    border-top: 1px solid var(--border);
    background: var(--surface-alt);
}
.iq-note-title {
    font-size: .78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--text-muted);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 6px;
}
.iq-note-body {
    font-size: .88rem;
    line-height: 1.65;
    color: var(--text-sub);
    white-space: pre-wrap;
    background: var(--surface);
    padding: 14px 16px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
}

/* ═══════ SIDEBAR CARD ═══════ */
.iq-sidebar .iq-card { position: sticky; top: 24px; }

.iq-client-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 28px 20px 20px;
    border-bottom: 1px solid var(--border);
}
.iq-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--brand), #7C3AED);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.35rem;
    font-weight: 700;
    box-shadow: 0 4px 14px rgba(79,70,229,.3);
    transition: transform var(--transition);
}
.iq-avatar:hover { transform: scale(1.08) rotate(3deg); }
.iq-client-name {
    font-weight: 700;
    font-size: .95rem;
    margin-top: 4px;
}
.iq-client-num {
    font-size: .82rem;
    color: var(--text-muted);
}

.iq-actions {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
}
.iq-actions .iq-btn { width: 100%; justify-content: center; }

.iq-completed-msg {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 16px;
    background: var(--success-bg);
    color: var(--success);
    border-radius: var(--radius-sm);
    font-size: .84rem;
    font-weight: 600;
}

/* ═══════ RESPONSIVE ═══════ */
@@media (max-width: 860px) {
    .iq-grid {
        grid-template-columns: 1fr;
    }
    .iq-sidebar .iq-card { position: static; }
    .iq-fields {
        grid-template-columns: 1fr;
    }
    .iq-field:nth-child(odd) {
        border-right: none;
    }
}
@@media (max-width: 480px) {
    .iq-page { padding: 16px 12px 40px; }
    .iq-topbar { flex-direction: column; }
    .iq-topbar-actions { width: 100%; }
    .iq-topbar-actions .iq-btn { flex: 1; justify-content: center; }
}
</style>

<!-- ════════════════════════════════════════════════ -->
<!-- PAGE START -->
<!-- ════════════════════════════════════════════════ -->
<div class="iq-page">

    <!-- TOP BAR -->
    <div class="iq-topbar">
        <div class="iq-topbar-left">
            <h1>Inquiry Details</h1>
            <p>Full information for this lead</p>
        </div>
        <div class="iq-topbar-actions">
            @if (isClient)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="iq-btn iq-btn-brand">
                    <i class="bi bi-pencil-square"></i> Edit
                </a>
            }
            <a asp-action="Index" class="iq-btn iq-btn-outline">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <!-- GRID -->
    <div class="iq-grid">

        <!-- ── MAIN CARD ── -->
        <div class="iq-main">
            <div class="iq-card">
                <div class="iq-card-header">
                    <h2 class="iq-hotel-name">@Model.HotelName</h2>
                    <span class="iq-status @statusClass">
                        <i class="bi @statusIcon"></i> @Model.StatusName
                    </span>
                </div>

                <div class="iq-fields">
                    @{
                        void RenderField(string label, string? value) {
                            <div class="iq-field">
                                <div class="iq-field-label">@label</div>
                                <div class="iq-field-value">@(value ?? "—")</div>
                            </div>
                        }
                    }

                    @{ RenderField("Hotel Name",   Model.HotelName); }
                    @{ RenderField("Client Name",   Model.ClientName); }
                    @{ RenderField("Client Number", Model.ClientNumber); }
                    @{ RenderField("City",          Model.CityName); }
                    @{ RenderField("Module",        Model.ModuleName); }
                    @{ RenderField("Status",        Model.StatusName); }

                    @if (isStaff)
                    {
                        RenderField("Follow-up Date",
                            Model.FollowupDate.HasValue
                                ? Model.FollowupDate.Value.ToString("dd MMM yyyy")
                                : "—");

                        <div class="iq-field">
                            <div class="iq-field-label">Payment Received</div>
                            <div class="iq-field-value">
                                @if (Model.PaymentReceived)
                                {
                                    <span class="iq-pay-yes"><i class="bi bi-check-circle-fill"></i> Yes</span>
                                }
                                else
                                {
                                    <span class="iq-pay-no"><i class="bi bi-x-circle"></i> No</span>
                                }
                            </div>
                        </div>
                    }

                    @{ RenderField("Added By", Model.CreatedByName); }
                    @{ RenderField("Created",  Model.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")); }
                    @{ RenderField("Updated",  Model.UpdatedAt.ToString("dd MMM yyyy, hh:mm tt")); }
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.Note))
                {
                    <div class="iq-note">
                        <div class="iq-note-title">
                            <i class="bi bi-sticky"></i> Note
                        </div>
                        <div class="iq-note-body">@Model.Note</div>
                    </div>
                }
            </div>
        </div>

        <!-- ── SIDEBAR ── -->
        <div class="iq-sidebar">
            <div class="iq-card">
                <div class="iq-client-box">
                    <div class="iq-avatar">@avatarInitial</div>
                    <div class="iq-client-name">@Model.ClientName</div>
                    <div class="iq-client-num">@Model.ClientNumber</div>
                </div>

                <div class="iq-actions">
                    @if (isStaff)
                    {
                        if (Model.StatusName == "Received")
                        {
                            <form asp-action="AdvanceStatus" asp-route-id="@Model.Id" method="post">
                                <button type="submit" class="iq-btn iq-btn-warning">
                                    <i class="bi bi-arrow-right-circle"></i> Mark In Progress
                                </button>
                            </form>
                        }
                        else if (Model.StatusName == "In Progress")
                        {
                            <form asp-action="AdvanceStatus" asp-route-id="@Model.Id" method="post">
                                <button type="submit" class="iq-btn iq-btn-success">
                                    <i class="bi bi-check2-all"></i> Mark Completed
                                </button>
                            </form>
                        }
                        else if (Model.StatusName == "Completed")
                        {
                            <div class="iq-completed-msg">
                                <i class="bi bi-patch-check-fill"></i> Inquiry is completed
                            </div>
                        }
                    }

                    @if (isClient && Model.StatusName == "Received")
                    {
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                              onsubmit="return confirm('Delete this inquiry permanently?')">
                            <button type="submit" class="iq-btn iq-btn-danger-outline">
                                <i class="bi bi-trash3"></i> Delete Inquiry
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>

    </div><!-- /iq-grid -->
</div><!-- /iq-page -->

<script>
    // Animate fields on scroll into view
    (function () {
        const fields = document.querySelectorAll('.iq-field');
        const obs = new IntersectionObserver((entries) => {
            entries.forEach((e, i) => {
                if (e.isIntersecting) {
                    e.target.style.transition = `opacity .4s ease ${i * 40}ms, transform .4s ease ${i * 40}ms`;
                    e.target.style.opacity = '1';
                    e.target.style.transform = 'translateY(0)';
                    obs.unobserve(e.target);
                }
            });
        }, { threshold: 0.15 });
        fields.forEach(f => {
            f.style.opacity = '0';
            f.style.transform = 'translateY(10px)';
            obs.observe(f);
        });
    })();
</script>
