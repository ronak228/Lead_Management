@model Inquiry
@{
    ViewData["Title"] = "Inquiry Details";
    var detailRole = Context.Session.GetString("UserRole") ?? "";
    bool isStaff = detailRole == "Admin" || detailRole == "Employee";
    bool isClient = detailRole == "Client";

    string statusClass = Model.StatusName switch {
        "Received"    => "status-received",
        "In Progress" => "status-progress",
        "Completed"   => "status-completed",
        _             => "status-received"
    };
    string statusIcon = Model.StatusName switch {
        "Received"    => "bi-inbox-fill",
        "In Progress" => "bi-gear-fill",
        "Completed"   => "bi-check-circle-fill",
        _             => "bi-inbox-fill"
    };
    string avatarInitial = Model.ClientName.Length > 0
        ? Model.ClientName[0].ToString().ToUpper()
        : "?";
}

<style>
    /* ============================================
       PROFESSIONAL INQUIRY DETAILS - FINAL VERSION
    ============================================ */
    
    :root {
        --primary: #0d6efd;
        --primary-dark: #0b5ed7;
        --primary-light: #e8f0fe;
        --success: #16a34a;
        --success-light: #eaf9ef;
        --warning: #f59e0b;
        --warning-light: #fff8e7;
        --info: #0ea5e9;
        --info-light: #e0f2fe;
        --danger: #dc2626;
        --danger-light: #fef3f2;
        --gray-50: #f8f9fa;
        --gray-100: #f1f3f5;
        --gray-200: #e9ecef;
        --gray-300: #dee2e6;
        --gray-600: #6c757d;
        --gray-700: #495057;
        --gray-900: #1a2c3e;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.05);
        --shadow-md: 0 4px 14px rgba(0,0,0,0.06);
        --shadow-lg: 0 10px 25px rgba(0,0,0,0.08);
        --radius-md: 12px;
        --radius-lg: 16px;
    }

    /* Page Container */
    .detail-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
        animation: fadeInUp 0.4s ease-out;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Header */
    .detail-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .detail-header h1 {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--gray-900);
        margin: 0 0 0.25rem;
        letter-spacing: -0.3px;
    }

    .detail-header p {
        margin: 0;
        color: var(--gray-600);
        font-size: 0.85rem;
    }

    .header-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    /* Buttons */
    .btn-custom {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1.25rem;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s ease;
        cursor: pointer;
        border: none;
    }

    .btn-primary-custom {
        background: var(--primary);
        color: white;
    }

    .btn-primary-custom:hover {
        background: var(--primary-dark);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(13, 110, 253, 0.25);
    }

    .btn-outline-custom {
        background: white;
        border: 1.5px solid var(--gray-200);
        color: var(--gray-700);
    }

    .btn-outline-custom:hover {
        border-color: var(--primary);
        color: var(--primary);
        background: var(--primary-light);
        transform: translateY(-1px);
    }

    .btn-warning-custom {
        background: var(--warning);
        color: white;
    }

    .btn-warning-custom:hover {
        background: #d97706;
        transform: translateY(-1px);
    }

    .btn-success-custom {
        background: var(--success);
        color: white;
    }

    .btn-success-custom:hover {
        background: #059669;
        transform: translateY(-1px);
    }

    .btn-danger-custom {
        background: transparent;
        border: 1.5px solid var(--danger);
        color: var(--danger);
    }

    .btn-danger-custom:hover {
        background: var(--danger);
        color: white;
        transform: translateY(-1px);
    }

    /* Grid Layout */
    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 360px;
        gap: 1.75rem;
        align-items: start;
    }

    /* Main Card */
    .card-main {
        background: white;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        transition: box-shadow 0.2s ease;
    }

    .card-main:hover {
        box-shadow: var(--shadow-md);
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem 1.75rem;
        background: white;
        border-bottom: 1px solid var(--gray-200);
    }

    .hotel-name {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0;
        color: var(--gray-900);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .hotel-name i {
        color: var(--primary);
        font-size: 1.2rem;
    }

    /* Status Badge */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.35rem 1rem;
        border-radius: 40px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.3px;
    }

    .status-received {
        background: var(--info-light);
        color: var(--info);
    }

    .status-progress {
        background: var(--warning-light);
        color: var(--warning);
    }

    .status-completed {
        background: var(--success-light);
        color: var(--success);
    }

    /* Fields Grid */
    .fields-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0;
    }

    .field-item {
        padding: 1rem 1.75rem;
        border-bottom: 1px solid var(--gray-100);
        transition: background 0.2s ease;
    }

    .field-item:hover {
        background: var(--gray-50);
    }

    .field-item:nth-child(odd) {
        border-right: 1px solid var(--gray-100);
    }

    .field-label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--gray-600);
        margin-bottom: 0.35rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .field-label i {
        font-size: 0.7rem;
    }

    .field-value {
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--gray-900);
        word-break: break-word;
    }

    /* Payment Badge */
    .payment-yes {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        background: var(--success-light);
        color: var(--success);
        padding: 0.25rem 0.75rem;
        border-radius: 30px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .payment-no {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        background: var(--gray-100);
        color: var(--gray-600);
        padding: 0.25rem 0.75rem;
        border-radius: 30px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    /* Note Section */
    .note-section {
        padding: 1.25rem 1.75rem;
        background: var(--gray-50);
        border-top: 1px solid var(--gray-200);
    }

    .note-title {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--gray-600);
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .note-content {
        font-size: 0.85rem;
        line-height: 1.6;
        color: var(--gray-700);
        background: white;
        padding: 1rem;
        border-radius: 12px;
        border: 1px solid var(--gray-200);
        white-space: pre-wrap;
    }

    /* Sidebar Card */
    .card-sidebar {
        background: white;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        position: sticky;
        top: 2rem;
    }

    .client-profile {
        text-align: center;
        padding: 1.75rem;
        border-bottom: 1px solid var(--gray-200);
        background: linear-gradient(135deg, var(--primary-light) 0%, white 100%);
    }

    .client-avatar {
        width: 70px;
        height: 70px;
        margin: 0 auto 0.75rem;
        background: linear-gradient(135deg, var(--primary), #7c3aed);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        font-weight: 700;
        color: white;
        box-shadow: 0 4px 14px rgba(79, 70, 229, 0.3);
        transition: transform 0.2s ease;
    }

    .client-avatar:hover {
        transform: scale(1.05);
    }

    .client-name-sidebar {
        font-weight: 700;
        font-size: 1rem;
        color: var(--gray-900);
        margin-bottom: 0.25rem;
    }

    .client-number-sidebar {
        font-size: 0.8rem;
        color: var(--gray-600);
    }

    .sidebar-actions {
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .sidebar-actions .btn-custom {
        width: 100%;
        justify-content: center;
    }

    .completed-message {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem;
        background: var(--success-light);
        color: var(--success);
        border-radius: 12px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    /* Responsive */
    @@media (max-width: 900px) {
        .detail-grid {
            grid-template-columns: 1fr;
        }

        .card-sidebar {
            position: static;
        }

        .fields-grid {
            grid-template-columns: 1fr;
        }

        .field-item:nth-child(odd) {
            border-right: none;
        }
    }

    @@media (max-width: 640px) {
        .detail-page {
            padding: 1rem;
        }

        .detail-header {
            flex-direction: column;
        }

        .header-actions {
            width: 100%;
        }

        .header-actions .btn-custom {
            flex: 1;
            justify-content: center;
        }

        .card-header {
            flex-direction: column;
            gap: 0.75rem;
            text-align: center;
        }

        .field-item {
            padding: 0.875rem 1rem;
        }

        .note-section {
            padding: 1rem;
        }
    }

    /* Animation for fields */
    .field-item {
        animation: slideIn 0.3s ease-out backwards;
    }

    .field-item:nth-child(1) { animation-delay: 0.02s; }
    .field-item:nth-child(2) { animation-delay: 0.04s; }
    .field-item:nth-child(3) { animation-delay: 0.06s; }
    .field-item:nth-child(4) { animation-delay: 0.08s; }
    .field-item:nth-child(5) { animation-delay: 0.10s; }
    .field-item:nth-child(6) { animation-delay: 0.12s; }
    .field-item:nth-child(7) { animation-delay: 0.14s; }
    .field-item:nth-child(8) { animation-delay: 0.16s; }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateX(-8px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }
</style>

<div class="detail-page">

    <!-- Header -->
    <div class="detail-header">
        <div>
            <h1>
                <i class="bi bi-chat-dots-fill" style="color: var(--primary); font-size: 1.5rem;"></i>
                Inquiry Details
            </h1>
            <p>Full information for this lead inquiry</p>
        </div>
        <div class="header-actions">
            @if (isClient)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-custom btn-primary-custom">
                    <i class="bi bi-pencil-square"></i> Edit
                </a>
            }
            <a asp-action="Index" class="btn-custom btn-outline-custom">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <!-- Grid Layout -->
    <div class="detail-grid">

        <!-- Main Content -->
        <div class="card-main">
            <div class="card-header">
                <div class="hotel-name">
                    <i class="bi bi-building"></i>
                    @Model.HotelName
                </div>
                <div class="status-badge @statusClass">
                    <i class="bi @statusIcon"></i>
                    @Model.StatusName
                </div>
            </div>

            <div class="fields-grid">
                <!-- Hotel Name -->
                <div class="field-item">
                    <div class="field-label">
                        <i class="bi bi-building"></i> Hotel Name
                    </div>
                    <div class="field-value">@Model.HotelName</div>
                </div>

                <!-- Client Name -->
                <div class="field-item">
                    <div class="field-label">
                        <i class="bi bi-person"></i> Client Name
                    </div>
                    <div class="field-value">@Model.ClientName</div>
                </div>

                <!-- Client Number -->
                <div class="field-item">
                    <div class="field-label">
                        <i class="bi bi-telephone"></i> Client Number
                    </div>
                    <div class="field-value">@Model.ClientNumber</div>
                </div>

                <!-- City -->
                <div class="field-item">
                    <div class="field-label">
                        <i class="bi bi-geo-alt"></i> City
                    </div>
                    <div class="field-value">@(Model.CityName ?? "—")</div>
                </div>

                <!-- Module -->
                <div class="field-item">
                    <div class="field-label">
                        <i class="bi bi-grid"></i> Module
                    </div>
                    <div class="field-value">@(Model.ModuleName ?? "—")</div>
                </div>

                <!-- Status -->
                <div class="field-item">
                    <div class="field-label">
                        <i class="bi bi-flag"></i> Status
                    </div>
                    <div class="field-value">@(Model.StatusName ?? "—")</div>
                </div>

                @if (isStaff)
                {
                    <!-- Follow-up Date -->
                    <div class="field-item">
                        <div class="field-label">
                            <i class="bi bi-calendar-event"></i> Follow-up Date
                        </div>
                        <div class="field-value">
                            @if (Model.FollowupDate.HasValue)
                            {
                                var isOverdue = Model.FollowupDate.Value.Date < DateTime.Today;
                                var isToday = Model.FollowupDate.Value.Date == DateTime.Today;
                                <span style="color: @(isOverdue ? "var(--danger)" : isToday ? "var(--warning)" : "inherit");
                                             font-weight: @(isOverdue || isToday ? "600" : "400");">
                                    <i class="bi @(isOverdue ? "bi-exclamation-circle" : isToday ? "bi-bell" : "bi-calendar3") me-1"></i>
                                    @Model.FollowupDate.Value.ToString("dd MMM yyyy")
                                </span>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </div>
                    </div>

                    <!-- Payment Received -->
                    <div class="field-item">
                        <div class="field-label">
                            <i class="bi bi-cash-stack"></i> Payment Received
                        </div>
                        <div class="field-value">
                            @if (Model.PaymentReceived)
                            {
                                <span class="payment-yes">
                                    <i class="bi bi-check-circle-fill"></i> Yes
                                </span>
                            }
                            else
                            {
                                <span class="payment-no">
                                    <i class="bi bi-x-circle"></i> No
                                </span>
                            }
                        </div>
                    </div>
                }

                <!-- Added By -->
                <div class="field-item">
                    <div class="field-label">
                        <i class="bi bi-person-badge"></i> Added By
                    </div>
                    <div class="field-value">@(Model.CreatedByName ?? "System")</div>
                </div>

                <!-- Created Date -->
                <div class="field-item">
                    <div class="field-label">
                        <i class="bi bi-calendar-plus"></i> Created
                    </div>
                    <div class="field-value">@Model.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")</div>
                </div>

                <!-- Updated Date -->
                <div class="field-item">
                    <div class="field-label">
                        <i class="bi bi-calendar-check"></i> Updated
                    </div>
                    <div class="field-value">@Model.UpdatedAt.ToString("dd MMM yyyy, hh:mm tt")</div>
                </div>
            </div>

            <!-- Note Section -->
            @if (!string.IsNullOrWhiteSpace(Model.Note))
            {
                <div class="note-section">
                    <div class="note-title">
                        <i class="bi bi-chat-text"></i> Additional Notes
                    </div>
                    <div class="note-content">
                        <i class="bi bi-quote me-1" style="color: var(--primary);"></i>
                        @Model.Note
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="card-sidebar">
            <div class="client-profile">
                <div class="client-avatar">
                    @avatarInitial
                </div>
                <div class="client-name-sidebar">@Model.ClientName</div>
                <div class="client-number-sidebar">
                    <i class="bi bi-telephone me-1"></i> @Model.ClientNumber
                </div>
            </div>

            <div class="sidebar-actions">
                @if (isStaff)
                {
                    if (Model.StatusName == "Received")
                    {
                        <form asp-action="AdvanceStatus" asp-route-id="@Model.Id" method="post">
                            <button type="submit" class="btn-custom btn-warning-custom">
                                <i class="bi bi-arrow-right-circle"></i> Mark In Progress
                            </button>
                        </form>
                    }
                    else if (Model.StatusName == "In Progress")
                    {
                        <form asp-action="AdvanceStatus" asp-route-id="@Model.Id" method="post">
                            <button type="submit" class="btn-custom btn-success-custom">
                                <i class="bi bi-check2-all"></i> Mark Completed
                            </button>
                        </form>
                    }
                    else if (Model.StatusName == "Completed")
                    {
                        <div class="completed-message">
                            <i class="bi bi-patch-check-fill"></i>
                            Inquiry is completed
                        </div>
                    }
                }

                @if (isClient && Model.StatusName == "Received")
                {
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                          onsubmit="return confirm('⚠️ Delete this inquiry permanently?\n\nHotel: @Model.HotelName\nClient: @Model.ClientName\n\nThis action cannot be undone!')">
                        <button type="submit" class="btn-custom btn-danger-custom">
                            <i class="bi bi-trash3"></i> Delete Inquiry
                        </button>
                    </form>
                }
            </div>
        </div>

    </div>
</div>

<script>
    // Smooth page load
    document.addEventListener('DOMContentLoaded', function() {
        // Add any additional initialization here
        console.log('Inquiry details page loaded');
    });
</script>