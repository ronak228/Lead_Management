                        </div>
                        <div>
                            <label>To Date</label>
                            <input type="date" name="dateTo" value="@Model.DateTo" class="form-control" />
                        </div>
                    }

                    <div class="filter-actions">
                        <button type="submit" class="btn-brand" style="border-radius:8px;">
                            <i class="bi bi-funnel"></i> Filter
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:8px;">
                            <i class="bi bi-arrow-clockwise"></i> Reset
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- LIST -->
    <div class="panel">
        <div class="panel-head">
            <h6>
                @(isClient ? "My Inquiries" : "All Inquiries")
                <span class="records-count">(@Model.Inquiries.Count records)</span>
