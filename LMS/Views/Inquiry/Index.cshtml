@model InquiryListViewModel
@{
    ViewData["Title"] = "Inquiries";
    var inqRole = Context.Session.GetString("UserRole") ?? "";
    bool isClient = inqRole == "Client";
}

<div class="page-header d-flex align-items-start justify-content-between flex-wrap gap-2">
    <div>
        <h4>@(isClient ? "My Inquiries" : "Inquiries")</h4>
        <p>@(isClient ? "Your submitted service inquiries" : "Manage all hotel lead inquiries")</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        @if (!isClient)
        {
        <a asp-action="Export" asp-route-search="@Model.Search" asp-route-filterStatus="@Model.FilterStatus"
           asp-route-filterModule="@Model.FilterModule" asp-route-filterPayment="@Model.FilterPayment"
           asp-route-filterCity="@Model.FilterCity" asp-route-dateFrom="@Model.DateFrom" asp-route-dateTo="@Model.DateTo"
           class="btn btn-outline-success px-3" style="font-size:.83rem;">
            <i class="bi bi-file-earmark-excel me-1"></i>Export
        </a>
        }
        @if (isClient)
        {
        <a asp-action="Create" class="btn btn-brand px-4" style="font-size:.84rem;">
            <i class="bi bi-plus me-1"></i>New Inquiry
        </a>
        }
    </div>
</div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body py-3 px-4">
        <form method="get" class="d-flex flex-wrap gap-2 align-items-end">
            <div class="flex-grow-1" style="min-width:160px;">
                <label class="form-label mb-2">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-white" style="border-right:none;">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" name="search" value="@Model.Search"
                           class="form-control" style="border-left:none;"
                           placeholder="Hotel, client, number…" />
                </div>
            </div>
            <div class="flex-grow-1" style="min-width:140px;">
                <label class="form-label mb-2">Status</label>
                <select name="filterStatus" class="form-select">
                    <option value="">All Statuses</option>
                    @foreach (var s in Model.Statuses)
                    {
                        if (Model.FilterStatus == s.Id) {
                            <option value="@s.Id" selected>@s.Name</option>
                        } else {
                            <option value="@s.Id">@s.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="flex-grow-1" style="min-width:140px;">
                <label class="form-label mb-2">Module</label>
                <select name="filterModule" class="form-select">
                    <option value="">All Modules</option>
                    @foreach (var m in Model.Modules)
                    {
                        if (Model.FilterModule == m.Id) {
                            <option value="@m.Id" selected>@m.Name</option>
                        } else {
                            <option value="@m.Id">@m.Name</option>
                        }
                    }
                </select>
            </div>
            @if (!isClient)
            {
            <div class="flex-grow-1" style="min-width:130px;">
                <label class="form-label mb-2">City</label>
                <select name="filterCity" class="form-select">
                    <option value="">All Cities</option>
                    @foreach (var ci in Model.Cities)
                    {
                        if (Model.FilterCity == ci.Id.ToString()) {
                            <option value="@ci.Id" selected>@ci.Name</option>
                        } else {
                            <option value="@ci.Id">@ci.Name</option>
                        }
                    }
                </select>
            </div>
            }
            <div class="flex-grow-1" style="min-width:120px;">
                <label class="form-label mb-2">Payment</label>
                <select name="filterPayment" class="form-select">
                    <option value="">All</option>
                    @if (Model.FilterPayment == "yes") {
                        <option value="yes" selected>Received</option>
                    } else {
                        <option value="yes">Received</option>
                    }
                    @if (Model.FilterPayment == "no") {
                        <option value="no" selected>Pending</option>
                    } else {
                        <option value="no">Pending</option>
                    }
                </select>
            </div>
            @if (!isClient)
            {
            <div class="flex-grow-1" style="min-width:130px;">
                <label class="form-label mb-2">From Date</label>
                <input type="date" name="dateFrom" value="@Model.DateFrom" class="form-control" />
            </div>
            <div class="flex-grow-1" style="min-width:130px;">
                <label class="form-label mb-2">To Date</label>
                <input type="date" name="dateTo" value="@Model.DateTo" class="form-control" />
            </div>
            }
            <div class="d-flex gap-2 align-self-end w-100">
                <button type="submit" class="btn btn-brand flex-grow-1">Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary flex-grow-1">Reset</a>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card">
    <div class="card-header-clean">
        <h6><i class="bi bi-search me-2" style="color:var(--brand);"></i>
            @(isClient ? "My Inquiries" : "All Inquiries")
            <span class="text-muted fw-normal" style="font-size:.76rem;">(@Model.Inquiries.Count records)</span>
        </h6>
    </div>
    <div class="card-body p-0">
        @if (Model.Inquiries.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox d-block mb-2" style="font-size:2.2rem;opacity:.25;"></i>
                <span style="font-size:.84rem;">No inquiries found. <a asp-action="Create" style="color:var(--brand);">Add one</a></span>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-clean mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Hotel Name</th>
                            @if (!isClient) { <th class="table-mobile-hide">Client</th> }
                            @if (!isClient) { <th class="table-mobile-hide">Client ID</th> }
                            <th class="table-mobile-hide">Contact</th>
                            <th class="table-mobile-hide">City</th>
                            <th class="table-mobile-hide">Module</th>
                            <th>Status</th>
                            @if (!isClient) { <th class="table-mobile-hide">Follow-up</th> }
                            <th class="table-mobile-hide">Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int sr = 1; }
                        @foreach (var inq in Model.Inquiries)
                        {
                            <tr>
                                <td class="text-muted">@sr</td>
                                <td class="fw-500">
                                    @inq.HotelName
                                </td>
                                @if (!isClient)
                                {
                                    <td class="table-mobile-hide">@inq.ClientName</td>
                                }
                                @if (!isClient)
                                {
                                    <td class="table-mobile-hide" style="font-size:.72rem;">
                                        @if (inq.ClientId.HasValue)
                                        {
                                            <a asp-controller="Client" asp-action="Details" asp-route-id="@inq.ClientId"
                                               style="color:var(--brand);font-weight:600;text-decoration:none;font-family:monospace;">
                                                @(string.IsNullOrEmpty(inq.ClientRef) ? $"#{inq.ClientId}" : inq.ClientRef)
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                }
                                <td class="table-mobile-hide" style="font-size:.8rem;">@inq.ClientNumber</td>
                                <td class="table-mobile-hide" style="font-size:.8rem;">@(inq.CityName ?? "—")</td>
                                <td class="table-mobile-hide">
                                    @if (inq.ModuleName != null)
                                    {
                                        <span style="background:#f0f0ff;color:var(--brand);font-size:.72rem;padding:2px 8px;border-radius:20px;font-weight:600;">@inq.ModuleName</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    @if (inq.StatusName != null)
                                    {
                                        <span style="background:#fef9ec;color:#92400e;font-size:.72rem;padding:2px 8px;border-radius:20px;font-weight:600;">@inq.StatusName</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                @if (!isClient)
                                {
                                <td class="table-mobile-hide" style="font-size:.75rem;">
                                    @if (inq.FollowupDate.HasValue)
                                    {
                                        var isOverdue = inq.FollowupDate.Value.Date < DateTime.Today;
                                        var isToday   = inq.FollowupDate.Value.Date == DateTime.Today;
                                        <span style="color:@(isOverdue?"#dc2626":isToday?"#d97706":"inherit");font-weight:@(isToday||isOverdue?"600":"400");">
                                            @inq.FollowupDate.Value.ToString("dd MMM yy")
                                            @if (isOverdue) { <i class="bi bi-exclamation-circle ms-1 text-danger"></i> }
                                            @if (isToday)   { <i class="bi bi-bell ms-1 text-warning"></i> }
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                }
                                <td class="text-muted table-mobile-hide" style="font-size:.75rem;">@inq.CreatedAt.ToString("dd MMM yy")</td>
                                <td class="text-end">
                                    <div class="table-actions">
                                        <a asp-action="Details" asp-route-id="@inq.Id"
                                           class="btn btn-sm btn-sm-icon btn-outline-secondary" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (isClient /*&& inq.StatusName == "Received"*/)
                                        {
                                            <a asp-action="Edit" asp-route-id="@inq.Id"
                                               class="btn btn-sm btn-sm-icon btn-outline-secondary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                            sr++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
