                                            var isOverdue = inq.FollowupDate.Value.Date < DateTime.Today;
                                            var isToday   = inq.FollowupDate.Value.Date == DateTime.Today;
                                            <span style="color:@(isOverdue?"#dc2626":isToday?"#d97706":"inherit");font-weight:@(isToday||isOverdue?"600":"400");">
                                                @inq.FollowupDate.Value.ToString("dd MMM yy")
                                                @if (isOverdue) { <i class="bi bi-exclamation-circle ms-1 text-danger"></i> }
                                                @if (isToday)   { <i class="bi bi-bell ms-1 text-warning"></i> }
                                            </span>
                                        }
                                        else { <span class="text-muted">—</span> }
                                    </td>
                                }

                                <td class="text-muted table-mobile-hide" style="font-size:.75rem;">
                                    @inq.CreatedAt.ToString("dd MMM yy")
                                </td>

                                <td class="text-end">
                                    <div class="row-actions">
                                        <a asp-action="Details" asp-route-id="@inq.Id"
                                           class="btn btn-sm btn-sm-icon btn-outline-secondary" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (isClient)
                                        {
                                            <a asp-action="Edit" asp-route-id="@inq.Id"
                                               class="btn btn-sm btn-sm-icon btn-outline-secondary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                            sr++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
