@* @model InquiryListViewModel
@{
    ViewData["Title"] = "Inquiries";
    var inqRole = Context.Session.GetString("UserRole") ?? "";
    bool isClient = inqRole == "Client";
}

<div class="page-header d-flex align-items-start justify-content-between flex-wrap gap-2">
    <div>
        <h4>@(isClient ? "My Inquiries" : "Inquiries")</h4>
        <p>@(isClient ? "Your submitted service inquiries" : "Manage all hotel lead inquiries")</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        @if (!isClient)
        {
        <a asp-action="Export" asp-route-search="@Model.Search" asp-route-filterStatus="@Model.FilterStatus"
           asp-route-filterModule="@Model.FilterModule" asp-route-filterPayment="@Model.FilterPayment"
           asp-route-filterCity="@Model.FilterCity" asp-route-dateFrom="@Model.DateFrom" asp-route-dateTo="@Model.DateTo"
           class="btn btn-outline-success px-3" style="font-size:.83rem;">
            <i class="bi bi-file-earmark-excel me-1"></i>Export
        </a>
        }
        @if (isClient)
        {
        <a asp-action="Create" class="btn btn-brand px-4" style="font-size:.84rem;">
            <i class="bi bi-plus me-1"></i>New Inquiry
        </a>
        }
    </div>
</div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body py-3 px-4">
        <form method="get" class="d-flex flex-wrap gap-2 align-items-end">
            <div class="flex-grow-1" style="min-width:160px;">
                <label class="form-label mb-2">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-white" style="border-right:none;">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" name="search" value="@Model.Search"
                           class="form-control" style="border-left:none;"
                           placeholder="Hotel, client, number…" />
                </div>
            </div>
            <div class="flex-grow-1" style="min-width:140px;">
                <label class="form-label mb-2">Status</label>
                <select name="filterStatus" class="form-select">
                    <option value="">All Statuses</option>
                    @foreach (var s in Model.Statuses)
                    {
                        if (Model.FilterStatus == s.Id) {
                            <option value="@s.Id" selected>@s.Name</option>
                        } else {
                            <option value="@s.Id">@s.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="flex-grow-1" style="min-width:140px;">
                <label class="form-label mb-2">Module</label>
                <select name="filterModule" class="form-select">
                    <option value="">All Modules</option>
                    @foreach (var m in Model.Modules)
                    {
                        if (Model.FilterModule == m.Id) {
                            <option value="@m.Id" selected>@m.Name</option>
                        } else {
                            <option value="@m.Id">@m.Name</option>
                        }
                    }
                </select>
            </div>
            @if (!isClient)
            {
            <div class="flex-grow-1" style="min-width:130px;">
                <label class="form-label mb-2">City</label>
                <select name="filterCity" class="form-select">
                    <option value="">All Cities</option>
                    @foreach (var ci in Model.Cities)
                    {
                        if (Model.FilterCity == ci.Id.ToString()) {
                            <option value="@ci.Id" selected>@ci.Name</option>
                        } else {
                            <option value="@ci.Id">@ci.Name</option>
                        }
                    }
                </select>
            </div>
            }
            <div class="flex-grow-1" style="min-width:120px;">
                <label class="form-label mb-2">Payment</label>
                <select name="filterPayment" class="form-select">
                    <option value="">All</option>
                    @if (Model.FilterPayment == "yes") {
                        <option value="yes" selected>Received</option>
                    } else {
                        <option value="yes">Received</option>
                    }
                    @if (Model.FilterPayment == "no") {
                        <option value="no" selected>Pending</option>
                    } else {
                        <option value="no">Pending</option>
                    }
                </select>
            </div>
            @if (!isClient)
            {
            <div class="flex-grow-1" style="min-width:130px;">
                <label class="form-label mb-2">From Date</label>
                <input type="date" name="dateFrom" value="@Model.DateFrom" class="form-control" />
            </div>
            <div class="flex-grow-1" style="min-width:130px;">
                <label class="form-label mb-2">To Date</label>
                <input type="date" name="dateTo" value="@Model.DateTo" class="form-control" />
            </div>
            }
            <div class="d-flex gap-2 align-self-end w-100">
                <button type="submit" class="btn btn-brand flex-grow-1">Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary flex-grow-1">Reset</a>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card">
    <div class="card-header-clean">
        <h6><i class="bi bi-search me-2" style="color:var(--brand);"></i>
            @(isClient ? "My Inquiries" : "All Inquiries")
            <span class="text-muted fw-normal" style="font-size:.76rem;">(@Model.Inquiries.Count records)</span>
        </h6>
    </div>
    <div class="card-body p-0">
        @if (Model.Inquiries.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox d-block mb-2" style="font-size:2.2rem;opacity:.25;"></i>
                <span style="font-size:.84rem;">No inquiries found. <a asp-action="Create" style="color:var(--brand);">Add one</a></span>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-clean mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Hotel Name</th>
                            @if (!isClient) { <th class="table-mobile-hide">Client</th> }
                            @if (!isClient) { <th class="table-mobile-hide">Client ID</th> }
                            <th class="table-mobile-hide">Contact</th>
                            <th class="table-mobile-hide">City</th>
                            <th class="table-mobile-hide">Module</th>
                            <th>Status</th>
                            @if (!isClient) { <th class="table-mobile-hide">Follow-up</th> }
                            <th class="table-mobile-hide">Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int sr = 1; }
                        @foreach (var inq in Model.Inquiries)
                        {
                            <tr>
                                <td class="text-muted">@sr</td>
                                <td class="fw-500">
                                    @inq.HotelName
                                </td>
                                @if (!isClient)
                                {
                                    <td class="table-mobile-hide">@inq.ClientName</td>
                                }
                                @if (!isClient)
                                {
                                    <td class="table-mobile-hide" style="font-size:.72rem;">
                                        @if (inq.ClientId.HasValue)
                                        {
                                            <a asp-controller="Client" asp-action="Details" asp-route-id="@inq.ClientId"
                                               style="color:var(--brand);font-weight:600;text-decoration:none;font-family:monospace;">
                                                @(string.IsNullOrEmpty(inq.ClientRef) ? $"#{inq.ClientId}" : inq.ClientRef)
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                }
                                <td class="table-mobile-hide" style="font-size:.8rem;">@inq.ClientNumber</td>
                                <td class="table-mobile-hide" style="font-size:.8rem;">@(inq.CityName ?? "—")</td>
                                <td class="table-mobile-hide">
                                    @if (inq.ModuleName != null)
                                    {
                                        <span style="background:#f0f0ff;color:var(--brand);font-size:.72rem;padding:2px 8px;border-radius:20px;font-weight:600;">@inq.ModuleName</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    @if (inq.StatusName != null)
                                    {
                                        <span style="background:#fef9ec;color:#92400e;font-size:.72rem;padding:2px 8px;border-radius:20px;font-weight:600;">@inq.StatusName</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                @if (!isClient)
                                {
                                <td class="table-mobile-hide" style="font-size:.75rem;">
                                    @if (inq.FollowupDate.HasValue)
                                    {
                                        var isOverdue = inq.FollowupDate.Value.Date < DateTime.Today;
                                        var isToday   = inq.FollowupDate.Value.Date == DateTime.Today;
                                        <span style="color:@(isOverdue?"#dc2626":isToday?"#d97706":"inherit");font-weight:@(isToday||isOverdue?"600":"400");">
                                            @inq.FollowupDate.Value.ToString("dd MMM yy")
                                            @if (isOverdue) { <i class="bi bi-exclamation-circle ms-1 text-danger"></i> }
                                            @if (isToday)   { <i class="bi bi-bell ms-1 text-warning"></i> }
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                }
                                <td class="text-muted table-mobile-hide" style="font-size:.75rem;">@inq.CreatedAt.ToString("dd MMM yy")</td>
                                <td class="text-end">
                                    <div class="table-actions">
                                        <a asp-action="Details" asp-route-id="@inq.Id"
                                           class="btn btn-sm btn-sm-icon btn-outline-secondary" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (isClient /*&& inq.StatusName == "Received"*/)
                                        {
                                            <a asp-action="Edit" asp-route-id="@inq.Id"
                                               class="btn btn-sm btn-sm-icon btn-outline-secondary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                            sr++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div> *@

@model InquiryListViewModel
@{
    ViewData["Title"] = "Inquiries";
    var inqRole = Context.Session.GetString("UserRole") ?? "";
    bool isClient = inqRole == "Client";
}

<style>
    /* Professional CSS Variables */
    :root {
        --primary: #0d6efd;
        --primary-dark: #0b5ed7;
        --primary-light: #e8f0fe;
        --success: #16a34a;
        --success-light: #eaf9ef;
        --warning: #f59e0b;
        --warning-light: #fff8e7;
        --danger: #dc2626;
        --danger-light: #fef3f2;
        --gray-50: #f8f9fa;
        --gray-100: #f1f3f5;
        --gray-200: #e9ecef;
        --gray-300: #dee2e6;
        --gray-600: #6c757d;
        --gray-700: #495057;
        --gray-900: #1a2c3e;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.05);
        --shadow-md: 0 4px 14px rgba(0,0,0,0.06);
        --shadow-lg: 0 10px 25px rgba(0,0,0,0.08);
        --radius-md: 12px;
        --radius-lg: 16px;
    }

    body {
        background: #f5f7fb;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    /* Page Header */
    .page-header-modern {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.75rem;
    }

    .page-header-modern h4 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--gray-900);
        margin-bottom: 0.25rem;
        letter-spacing: -0.3px;
    }

    .page-header-modern .subtitle {
        color: var(--gray-600);
        font-size: 0.85rem;
        margin-bottom: 0;
    }

    /* Button Styles */
    .btn-primary-modern {
        background: var(--primary);
        border: none;
        border-radius: 10px;
        padding: 0.5rem 1.25rem;
        font-weight: 600;
        font-size: 0.85rem;
        color: white;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s ease;
    }

    .btn-primary-modern:hover {
        background: var(--primary-dark);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(13, 110, 253, 0.2);
        color: white;
    }

    .btn-outline-success-modern {
        background: white;
        border: 1.5px solid var(--gray-200);
        border-radius: 10px;
        padding: 0.5rem 1.25rem;
        font-weight: 600;
        font-size: 0.85rem;
        color: var(--gray-700);
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s ease;
    }

    .btn-outline-success-modern:hover {
        border-color: var(--success);
        color: var(--success);
        background: var(--success-light);
        transform: translateY(-1px);
    }

    /* Card/Panel */
    .card-modern {
        background: white;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        margin-bottom: 1.5rem;
        overflow: hidden;
        transition: all 0.2s ease;
    }

    .card-modern:hover {
        box-shadow: var(--shadow-md);
    }

    .card-header-modern {
        padding: 1rem 1.5rem;
        background: white;
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .card-header-modern h6 {
        font-size: 0.9rem;
        font-weight: 700;
        margin: 0;
        color: var(--gray-900);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .records-count {
        font-size: 0.75rem;
        font-weight: 400;
        color: var(--gray-600);
        margin-left: 0.5rem;
    }

    .card-body-modern {
        padding: 1.25rem 1.5rem;
    }

    /* Filter Grid */
    .filter-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    }

    .filter-group label {
        display: block;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        color: var(--gray-600);
        margin-bottom: 0.4rem;
    }

    .filter-group .form-control,
    .filter-group .form-select {
        height: 40px;
        font-size: 0.85rem;
        border-radius: 10px;
        border: 1.5px solid var(--gray-200);
        transition: all 0.2s ease;
    }

    .filter-group .form-control:focus,
    .filter-group .form-select:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.1);
    }

    .input-group-custom {
        display: flex;
        align-items: stretch;
    }

    .input-group-custom .input-group-text {
        background: white;
        border: 1.5px solid var(--gray-200);
        border-right: none;
        border-radius: 10px 0 0 10px;
        color: var(--gray-600);
    }

    .input-group-custom .form-control {
        border-radius: 0 10px 10px 0;
        border-left: none;
    }

    .filter-actions {
        display: flex;
        gap: 0.75rem;
        align-items: flex-end;
    }

    .filter-actions .btn {
        height: 40px;
        font-size: 0.82rem;
        padding: 0 1.25rem;
    }

    /* Table Styles */
    .table-responsive-custom {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .table-modern {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.85rem;
    }

    .table-modern thead th {
        background: var(--gray-50);
        color: var(--gray-600);
        font-weight: 700;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        padding: 1rem 1rem;
        border-bottom: 2px solid var(--gray-200);
        white-space: nowrap;
    }

    .table-modern tbody td {
        padding: 1rem 1rem;
        border-bottom: 1px solid var(--gray-100);
        vertical-align: middle;
    }

    .table-modern tbody tr:hover {
        background: var(--gray-50);
    }

    .table-modern tbody tr:last-child td {
        border-bottom: none;
    }

    /* Badges/Pills */
    .badge-modern {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.7rem;
        font-weight: 600;
        padding: 0.25rem 0.75rem;
        border-radius: 30px;
        white-space: nowrap;
    }

    .badge-primary {
        background: var(--primary-light);
        color: var(--primary);
    }

    .badge-status {
        background: var(--warning-light);
        color: #92400e;
    }

    /* Client Ref Link */
    .client-ref-link {
        color: var(--primary);
        font-weight: 600;
        text-decoration: none;
        font-family: monospace;
        font-size: 0.72rem;
        background: var(--primary-light);
        padding: 2px 8px;
        border-radius: 16px;
        display: inline-block;
    }

    .client-ref-link:hover {
        background: var(--primary);
        color: white;
    }

    /* Action Buttons */
    .action-buttons {
        display: inline-flex;
        gap: 0.5rem;
    }

    .btn-icon-sm {
        width: 32px;
        height: 32px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        border: 1px solid var(--gray-200);
        background: white;
        color: var(--gray-600);
        transition: all 0.2s ease;
    }

    .btn-icon-sm:hover {
        background: var(--primary-light);
        border-color: var(--primary);
        color: var(--primary);
        transform: translateY(-1px);
    }

    /* Follow-up Indicators */
    .followup-overdue {
        color: var(--danger);
        font-weight: 600;
    }

    .followup-today {
        color: var(--warning);
        font-weight: 600;
    }

    /* Empty State */
    .empty-state-modern {
        text-align: center;
        padding: 3rem 1.5rem;
        color: var(--gray-600);
    }

    .empty-state-modern i {
        font-size: 3rem;
        color: var(--gray-300);
        margin-bottom: 1rem;
        display: block;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .page-header-modern h4 {
            font-size: 1.25rem;
        }

        .card-header-modern {
            padding: 0.875rem 1rem;
        }

        .card-body-modern {
            padding: 1rem;
        }

        .filter-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 0.75rem;
        }

        .filter-actions {
            grid-column: 1 / -1;
        }

        .table-mobile-hide {
            display: none !important;
        }

        .table-modern thead th,
        .table-modern tbody td {
            padding: 0.75rem 0.5rem;
            font-size: 0.75rem;
        }

        .btn-icon-sm {
            width: 28px;
            height: 28px;
        }
    }

    @@media (max-width: 480px) {
        .filter-grid {
            grid-template-columns: 1fr;
        }

        .page-header-modern {
            flex-direction: column;
        }

        .page-actions-modern {
            width: 100%;
        }

        .page-actions-modern .btn {
            flex: 1;
            justify-content: center;
        }
    }

    @@media (min-width: 769px) and (max-width: 1024px) {
        .filter-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }
</style>

<div class="container-fluid px-2 px-md-3 py-3">

    <!-- HEADER -->
    <div class="page-header-modern">
        <div>
            <h4>
                <i class="bi bi-chat-dots-fill" style="color: var(--primary); font-size: 1.5rem;"></i>
                @(isClient ? "My Inquiries" : "Inquiries")
            </h4>
            <p class="subtitle">@(isClient ? "Your submitted service inquiries" : "Manage all hotel lead inquiries")</p>
        </div>
        <div class="page-actions-modern d-flex gap-2 flex-wrap">
            @if (!isClient)
            {
                <a asp-action="Export"
                   asp-route-search="@Model.Search"
                   asp-route-filterStatus="@Model.FilterStatus"
                   asp-route-filterModule="@Model.FilterModule"
                   asp-route-filterPayment="@Model.FilterPayment"
                   asp-route-filterCity="@Model.FilterCity"
                   asp-route-dateFrom="@Model.DateFrom"
                   asp-route-dateTo="@Model.DateTo"
                   class="btn-outline-success-modern">
                    <i class="bi bi-file-earmark-excel"></i> Export
                </a>
            }
            @if (isClient)
            {
                <a asp-action="Create" class="btn-primary-modern">
                    <i class="bi bi-plus-lg"></i> New Inquiry
                </a>
            }
        </div>
    </div>

    <!-- FILTERS -->
    <div class="card-modern">
        <div class="card-body-modern">
            <form method="get" asp-action="Index">
                <div class="filter-grid">
                    <div class="filter-group">
                        <label><i class="bi bi-search"></i> Search</label>
                        <div class="input-group-custom">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" name="search" value="@Model.Search"
                                   class="form-control" placeholder="Hotel, client, number…" />
                        </div>
                    </div>

                    <div class="filter-group">
                        <label><i class="bi bi-flag"></i> Status</label>
                        <select name="filterStatus" class="form-select">
                            <option value="">All Statuses</option>
                            @foreach (var s in Model.Statuses)
                            {
                                if (Model.FilterStatus == s.Id) {
                                    <option value="@s.Id" selected>@s.Name</option>
                                } else {
                                    <option value="@s.Id">@s.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="filter-group">
                        <label><i class="bi bi-grid"></i> Module</label>
                        <select name="filterModule" class="form-select">
                            <option value="">All Modules</option>
                            @foreach (var m in Model.Modules)
                            {
                                if (Model.FilterModule == m.Id) {
                                    <option value="@m.Id" selected>@m.Name</option>
                                } else {
                                    <option value="@m.Id">@m.Name</option>
                                }
                            }
                        </select>
                    </div>

                    @if (!isClient)
                    {
                        <div class="filter-group">
                            <label><i class="bi bi-geo-alt"></i> City</label>
                            <select name="filterCity" class="form-select">
                                <option value="">All Cities</option>
                                @foreach (var ci in Model.Cities)
                                {
                                    if (Model.FilterCity == ci.Id.ToString()) {
                                        <option value="@ci.Id" selected>@ci.Name</option>
                                    } else {
                                        <option value="@ci.Id">@ci.Name</option>
                                    }
                                }
                            </select>
                        </div>
                    }

                    <div class="filter-group">
                        <label><i class="bi bi-cash-stack"></i> Payment</label>
                        <select name="filterPayment" class="form-select">
                            <option value="">All</option>
                            @if (Model.FilterPayment == "yes") {
                                <option value="yes" selected>Received</option>
                            } else {
                                <option value="yes">Received</option>
                            }
                            @if (Model.FilterPayment == "no") {
                                <option value="no" selected>Pending</option>
                            } else {
                                <option value="no">Pending</option>
                            }
                        </select>
                    </div>

                    @if (!isClient)
                    {
                        <div class="filter-group">
                            <label><i class="bi bi-calendar3"></i> From Date</label>
                            <input type="date" name="dateFrom" value="@Model.DateFrom" class="form-control" />
                        </div>
                        <div class="filter-group">
                            <label><i class="bi bi-calendar3"></i> To Date</label>
                            <input type="date" name="dateTo" value="@Model.DateTo" class="form-control" />
                        </div>
                    }

                    <div class="filter-actions">
                        <button type="submit" class="btn-primary-modern" style="width:100%; justify-content: center;">
                            <i class="bi bi-funnel"></i> Filter
                        </button>
                        <a asp-action="Index" class="btn-outline-success-modern" style="justify-content: center;">
                            <i class="bi bi-arrow-clockwise"></i> Reset
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- INQUIRIES LIST -->
    <div class="card-modern">
        <div class="card-header-modern">
            <h6>
                <i class="bi bi-table" style="color: var(--primary);"></i>
                @(isClient ? "My Inquiries" : "All Inquiries")
                <span class="records-count">(@Model.Inquiries.Count records)</span>
            </h6>
        </div>

        @if (Model.Inquiries.Count == 0)
        {
            <div class="empty-state-modern">
                <i class="bi bi-inbox"></i>
                <div>No inquiries found.</div>
                @if (isClient)
                {
                    <a asp-action="Create" class="btn-primary-modern mt-3" style="display: inline-flex;">
                        <i class="bi bi-plus-lg"></i> Create Your First Inquiry
                    </a>
                }
            </div>
        }
        else
        {
            <div class="table-responsive-custom">
                <table class="table-modern">
                    <thead>
                        <tr>
                            <th style="width: 45px;">#</th>
                            <th>Hotel Name</th>
                            @if (!isClient) { <th class="table-mobile-hide">Client</th> }
                            @if (!isClient) { <th class="table-mobile-hide">Client ID</th> }
                            <th class="table-mobile-hide">Contact</th>
                            <th class="table-mobile-hide">City</th>
                            <th class="table-mobile-hide">Module</th>
                            <th>Status</th>
                            @if (!isClient) { <th class="table-mobile-hide">Follow-up</th> }
                            <th class="table-mobile-hide">Date</th>
                            <th style="width: 80px;" class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int sr = 1; }
                        @foreach (var inq in Model.Inquiries)
                        {
                            <tr>
                                <td class="text-muted fw-semibold">@sr</td>
                                <td class="fw-semibold" style="color: var(--gray-900);">@inq.HotelName</td>

                                @if (!isClient)
                                {
                                    <td class="table-mobile-hide">@inq.ClientName</td>
                                    <td class="table-mobile-hide">
                                        @if (inq.ClientId.HasValue)
                                        {
                                            <a asp-controller="Client" asp-action="Details" asp-route-id="@inq.ClientId"
                                               class="client-ref-link">
                                                @(string.IsNullOrEmpty(inq.ClientRef) ? $"#{inq.ClientId}" : inq.ClientRef)
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                }

                                <td class="table-mobile-hide">
                                    <i class="bi bi-telephone me-1" style="font-size: 0.65rem;"></i>
                                    @inq.ClientNumber
                                </td>
                                <td class="table-mobile-hide">
                                    @if (!string.IsNullOrEmpty(inq.CityName))
                                    {
                                        <i class="bi bi-geo-alt me-1" style="font-size: 0.65rem; color: var(--primary);"></i>
                                        @inq.CityName
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td class="table-mobile-hide">
                                    @if (inq.ModuleName != null)
                                    {
                                        <span class="badge-modern badge-primary">
                                            <i class="bi bi-grid"></i> @inq.ModuleName
                                        </span>
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td>
                                    @if (inq.StatusName != null)
                                    {
                                        <span class="badge-modern badge-status">
                                            <i class="bi bi-flag"></i> @inq.StatusName
                                        </span>
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>

                                @if (!isClient)
                                {
                                    <td class="table-mobile-hide">
                                        @if (inq.FollowupDate.HasValue)
                                        {
                                            var isOverdue = inq.FollowupDate.Value.Date < DateTime.Today;
                                            var isToday = inq.FollowupDate.Value.Date == DateTime.Today;
                                            <span class="@(isOverdue ? "followup-overdue" : isToday ? "followup-today" : "")">
                                                <i class="bi @(isOverdue ? "bi-exclamation-circle" : isToday ? "bi-bell" : "bi-calendar3") me-1"></i>
                                                @inq.FollowupDate.Value.ToString("dd MMM yy")
                                            </span>
                                        }
                                        else { <span class="text-muted">—</span> }
                                    </td>
                                }

                                <td class="table-mobile-hide text-muted">
                                    <i class="bi bi-calendar3 me-1" style="font-size: 0.65rem;"></i>
                                    @inq.CreatedAt.ToString("dd MMM yy")
                                </td>

                                <td class="text-end">
                                    <div class="action-buttons">
                                        <a asp-action="Details" asp-route-id="@inq.Id"
                                           class="btn-icon-sm" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (isClient)
                                        {
                                            <a asp-action="Edit" asp-route-id="@inq.Id"
                                               class="btn-icon-sm" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                            sr++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>