@* @model InquiryListViewModel
@{
    ViewData["Title"] = "Inquiries";
    var inqRole = Context.Session.GetString("UserRole") ?? "";
    bool isClient = inqRole == "Client";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

<style>
    /* ============ DESIGN SYSTEM ============ */
    :root {
        --primary: #4f46e5;
        --primary-dark: #4338ca;
        --primary-light: #eef2ff;
        --primary-grad: linear-gradient(135deg, #6366f1 0%, #4f46e5 50%, #7c3aed 100%);
        --success: #059669;
        --success-light: #d1fae5;
        --warning: #d97706;
        --warning-light: #fef3c7;
        --danger: #dc2626;
        --danger-light: #fee2e2;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --shadow-xs: 0 1px 2px 0 rgb(0 0 0 / 0.04);
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px -1px rgba(0,0,0,0.04);
        --shadow-md: 0 4px 12px -2px rgba(0,0,0,0.08), 0 2px 6px -2px rgba(0,0,0,0.04);
        --shadow-lg: 0 12px 28px -6px rgba(79,70,229,0.15), 0 4px 10px -4px rgba(0,0,0,0.05);
        --radius-md: 12px;
        --radius-lg: 16px;
    }

    body {
        background:
            radial-gradient(circle at 0% 0%, rgba(99, 102, 241, 0.06) 0%, transparent 40%),
            radial-gradient(circle at 100% 0%, rgba(139, 92, 246, 0.05) 0%, transparent 40%),
            #f7f8fc;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        color: var(--gray-900);
    }

    .inquiries-wrapper {
        max-width: 1440px;
        margin: 0 auto;
        padding: 1.75rem 1.5rem;
    }

    /* ============ PAGE HEADER ============ */
    .page-header-modern {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    .page-header-modern h4 {
        font-size: 1.75rem;
        font-weight: 800;
        letter-spacing: -0.025em;
        background: linear-gradient(135deg, var(--gray-900) 0%, var(--primary) 100%);
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin: 0 0 0.25rem 0;
        line-height: 1.15;
        display: flex;
        align-items: center;
        gap: 0.55rem;
    }
    .page-header-modern h4 i {
        -webkit-text-fill-color: var(--primary);
        font-size: 1.4rem;
    }
    .page-header-modern .subtitle {
        color: var(--gray-500);
        font-size: 0.88rem;
        font-weight: 500;
        margin: 0;
    }
    .page-actions-modern {
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
    }

    /* ============ BUTTONS ============ */
    .btn-primary-modern,
    .btn-outline-success-modern,
    .btn-secondary-modern {
        height: 40px;
        padding: 0 1.1rem;
        font-weight: 600;
        font-size: 0.83rem;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.45rem;
        text-decoration: none;
        white-space: nowrap;
        transition: all 0.22s cubic-bezier(.4,0,.2,1);
        line-height: 1;
        border: 1.5px solid transparent;
    }
    .btn-primary-modern {
        background: var(--primary-grad);
        color: white;
        box-shadow: 0 4px 12px -3px rgba(79, 70, 229, 0.4);
    }
    .btn-primary-modern:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 18px -4px rgba(79, 70, 229, 0.5);
        color: white;
    }
    .btn-outline-success-modern {
        background: white;
        border-color: var(--gray-200);
        color: var(--gray-700);
        box-shadow: var(--shadow-xs);
    }
    .btn-outline-success-modern:hover {
        border-color: var(--success);
        color: var(--success);
        background: var(--success-light);
        transform: translateY(-2px);
    }
    .btn-secondary-modern {
        background: white;
        border-color: var(--gray-200);
        color: var(--gray-700);
    }
    .btn-secondary-modern:hover {
        border-color: var(--gray-400);
        background: var(--gray-50);
        color: var(--gray-900);
    }

    /* ============ CARD / PANEL ============ */
    .card-modern {
        background: white;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        margin-bottom: 1.25rem;
        overflow: hidden;
        transition: box-shadow 0.25s;
    }
    .card-modern:hover { box-shadow: var(--shadow-md); }

    .card-header-modern {
        padding: 1rem 1.25rem;
        background: linear-gradient(180deg, #fafbff 0%, #ffffff 100%);
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
        min-height: 60px;
    }
    .card-header-modern h6 {
        font-size: 0.95rem;
        font-weight: 700;
        margin: 0;
        color: var(--gray-900);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        letter-spacing: -0.01em;
        line-height: 1.4;
    }
    .card-header-modern h6 i {
        color: var(--primary);
        font-size: 1.05rem;
    }
    .records-count {
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--gray-600);
        background: var(--gray-100);
        padding: 0.25rem 0.65rem;
        border-radius: 999px;
        margin-left: 0.4rem;
        line-height: 1;
    }
    .card-body-modern { padding: 1.25rem; }

    /* ============ FILTERS ============ */
    .filter-grid {
        display: grid;
        gap: 0.9rem;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        align-items: end;
    }
    .filter-group { min-width: 0; }
    .filter-group label {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--gray-600);
        margin-bottom: 0.4rem;
        line-height: 1;
    }
    .filter-group label i { color: var(--primary); font-size: 0.8rem; }

    .filter-group .form-control,
    .filter-group .form-select {
        height: 40px;
        font-size: 0.86rem;
        border-radius: 10px;
        border: 1.5px solid var(--gray-200);
        background: white;
        color: var(--gray-800);
        transition: all 0.2s ease;
        padding: 0 0.8rem;
        width: 100%;
        line-height: 1.2;
    }
    .filter-group .form-control:focus,
    .filter-group .form-select:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.12);
        outline: none;
    }

    .input-group-custom {
        display: flex;
        align-items: stretch;
        height: 40px;
    }
    .input-group-custom .input-group-text {
        background: white;
        border: 1.5px solid var(--gray-200);
        border-right: none;
        border-radius: 10px 0 0 10px;
        color: var(--primary);
        padding: 0 0.7rem;
        display: flex;
        align-items: center;
        font-size: 0.9rem;
    }
    .input-group-custom .form-control {
        border-radius: 0 10px 10px 0;
        border-left: none;
        height: 40px;
    }

    .filter-actions {
        display: flex;
        gap: 0.55rem;
        align-items: end;
    }
    .filter-actions .btn-primary-modern,
    .filter-actions .btn-secondary-modern {
        flex: 1;
    }

    /* ============ TABLE ============ */
    .table-responsive-custom {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }
    .table-modern {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.85rem;
        table-layout: auto;
    }
    .table-modern thead th {
        background: var(--gray-50);
        color: var(--gray-500);
        font-weight: 600;
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 0.85rem 0.9rem;
        border-bottom: 1px solid var(--gray-200);
        white-space: nowrap;
        vertical-align: middle;
        line-height: 1.2;
    }
    .table-modern tbody td {
        padding: 0.85rem 0.9rem;
        border-bottom: 1px solid var(--gray-100);
        vertical-align: middle;
        color: var(--gray-800);
        line-height: 1.45;
        white-space: nowrap; /* prevent wrapping for tight cells */
    }
    /* allow wrapping only for long text columns */
    .table-modern tbody td.cell-wrap { white-space: normal; }

    .table-modern tbody tr {
        transition: background 0.15s;
    }
    .table-modern tbody tr:hover { background: var(--gray-50); }
    .table-modern tbody tr:last-child td { border-bottom: none; }

    .row-index {
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--gray-400);
        font-variant-numeric: tabular-nums;
    }
    .hotel-name {
        font-weight: 700;
        color: var(--gray-900);
        font-size: 0.88rem;
    }
    .client-name {
        color: var(--gray-700);
        font-weight: 500;
    }
    .contact-cell, .city-cell, .date-cell {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.83rem;
        color: var(--gray-700);
        white-space: nowrap;
        font-variant-numeric: tabular-nums;
    }
    .contact-cell i, .city-cell i, .date-cell i {
        color: var(--primary);
        font-size: 0.8rem;
        flex-shrink: 0;
    }
    .date-cell { color: var(--gray-500); }
    .date-cell i { color: var(--gray-400); }

    /* ============ BADGES ============ */
    .badge-modern {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.7rem;
        font-weight: 600;
        padding: 0.3rem 0.7rem;
        border-radius: 999px;
        white-space: nowrap;
        border: 1px solid transparent;
        line-height: 1.2;
    }
    .badge-primary {
        background: var(--primary-light);
        color: var(--primary);
        border-color: rgba(79, 70, 229, 0.15);
    }
    .badge-status {
        background: var(--warning-light);
        color: var(--warning);
        border-color: rgba(217, 119, 6, 0.2);
    }

    /* ============ CLIENT REF ============ */
    .client-ref-link {
        color: var(--primary);
        font-weight: 700;
        text-decoration: none;
        font-family: 'SF Mono', 'Consolas', monospace;
        font-size: 0.72rem;
        background: var(--primary-light);
        padding: 0.3rem 0.6rem;
        border-radius: 0.5rem;
        display: inline-block;
        border: 1px solid rgba(79, 70, 229, 0.12);
        transition: all 0.2s;
        white-space: nowrap;
        line-height: 1;
    }
    .client-ref-link:hover {
        background: var(--primary);
        color: white;
        transform: translateY(-1px);
    }

    /* ============ ACTION BUTTONS ============ */
    .action-buttons {
        display: inline-flex;
        gap: 0.35rem;
        justify-content: flex-end;
    }
    .btn-icon-sm {
        width: 32px;
        height: 32px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        border: 1px solid var(--gray-200);
        background: white;
        color: var(--gray-600);
        transition: all 0.2s ease;
        text-decoration: none;
        font-size: 0.85rem;
        line-height: 1;
    }
    .btn-icon-sm:hover {
        background: var(--primary-light);
        border-color: var(--primary);
        color: var(--primary);
        transform: translateY(-1px);
        box-shadow: 0 4px 10px -3px rgba(79, 70, 229, 0.25);
    }

    /* ============ FOLLOW-UP ============ */
    .followup-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.3rem 0.65rem;
        border-radius: 0.5rem;
        font-size: 0.76rem;
        font-weight: 600;
        white-space: nowrap;
        line-height: 1.2;
        font-variant-numeric: tabular-nums;
    }
    .followup-chip i { font-size: 0.78rem; flex-shrink: 0; }
    .followup-overdue { color: var(--danger); background: var(--danger-light); }
    .followup-today   { color: var(--warning); background: var(--warning-light); }
    .followup-future  { color: var(--gray-700); background: var(--gray-50); border: 1px solid var(--gray-200); }
    .followup-future i { color: var(--gray-400); }

    /* ============ EMPTY STATE ============ */
    .empty-state-modern {
        text-align: center;
        padding: 3.5rem 1.5rem;
        color: var(--gray-500);
    }
    .empty-state-modern i {
        font-size: 3.25rem;
        color: var(--gray-300);
        margin-bottom: 0.85rem;
        display: block;
    }
    .empty-state-modern p {
        font-size: 0.95rem;
        font-weight: 500;
        margin-bottom: 1rem;
    }

    .text-muted-cell {
        color: var(--gray-400);
        font-weight: 500;
    }

    /* ============ COLUMN HINTS ============ */
    /* Keep small fixed widths only where needed; let browser balance the rest */
    .col-num     { width: 48px; text-align: center; }
    .col-status  { width: 130px; }
    .col-actions { width: 90px; }

    /* ============ RESPONSIVE ============ */
    @@media (max-width: 1024px) {
        .filter-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @@media (max-width: 768px) {
        .inquiries-wrapper { padding: 1rem; }
        .page-header-modern h4 { font-size: 1.35rem; }
        .page-header-modern h4 i { font-size: 1.15rem; }
        .card-header-modern { padding: 0.85rem 1rem; min-height: 54px; }
        .card-body-modern { padding: 1rem; }
        .filter-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 0.75rem;
        }
        .filter-actions { grid-column: 1 / -1; }
        .table-mobile-hide { display: none !important; }
        .table-modern thead th,
        .table-modern tbody td {
            padding: 0.7rem 0.6rem;
            font-size: 0.78rem;
        }
        .btn-icon-sm { width: 30px; height: 30px; font-size: 0.78rem; }
    }
    @@media (max-width: 480px) {
        .filter-grid { grid-template-columns: 1fr; }
        .page-header-modern { flex-direction: column; align-items: stretch; }
        .page-actions-modern { width: 100%; }
        .page-actions-modern .btn-primary-modern,
        .page-actions-modern .btn-outline-success-modern { flex: 1; }
    }
</style>

<div class="inquiries-wrapper">
    <!-- ============ PAGE HEADER ============ -->
    <div class="page-header-modern">
        <div>
            <h4>
                <i class="bi bi-chat-left-text-fill"></i>
                @(isClient ? "My Inquiries" : "Inquiries")
            </h4>
            <p class="subtitle">@(isClient ? "Your submitted service inquiries" : "Manage all hotel lead inquiries")</p>
        </div>

        <div class="page-actions-modern">
            @if (!isClient)
            {
                <a asp-action="Export"
                   asp-route-search="@Model.Search"
                   asp-route-filterStatus="@Model.FilterStatus"
                   asp-route-filterModule="@Model.FilterModule"
                   asp-route-filterPayment="@Model.FilterPayment"
                   asp-route-filterCity="@Model.FilterCity"
                   asp-route-dateFrom="@Model.DateFrom"
                   asp-route-dateTo="@Model.DateTo"
                   class="btn-outline-success-modern">
                    <i class="bi bi-file-earmark-excel"></i> Export
                </a>
            }
            @if (isClient)
            {
                <a asp-action="Create" class="btn-primary-modern">
                    <i class="bi bi-plus-lg"></i> New Inquiry
                </a>
            }
        </div>
    </div>

    <!-- ============ FILTERS ============ -->
    <div class="card-modern">
        <div class="card-header-modern">
            <h6><i class="bi bi-funnel-fill"></i> Filters</h6>
        </div>
        <div class="card-body-modern">
            <form method="get" asp-action="Index">
                <div class="filter-grid">
                    <div class="filter-group">
                        <label><i class="bi bi-search"></i> Search</label>
                        <div class="input-group-custom">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" name="search" value="@Model.Search"
                                   class="form-control" placeholder="Hotel, client, number…" />
                        </div>
                    </div>

                    <div class="filter-group">
                        <label><i class="bi bi-flag"></i> Status</label>
                        <select name="filterStatus" class="form-select">
                            <option value="">All Statuses</option>
                            @foreach (var s in Model.Statuses)
                            {
                                if (Model.FilterStatus == s.Id) {
                                    <option value="@s.Id" selected>@s.Name</option>
                                } else {
                                    <option value="@s.Id">@s.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="filter-group">
                        <label><i class="bi bi-grid"></i> Module</label>
                        <select name="filterModule" class="form-select">
                            <option value="">All Modules</option>
                            @foreach (var m in Model.Modules)
                            {
                                if (Model.FilterModule == m.Id) {
                                    <option value="@m.Id" selected>@m.Name</option>
                                } else {
                                    <option value="@m.Id">@m.Name</option>
                                }
                            }
                        </select>
                    </div>

                    @if (!isClient)
                    {
                        <div class="filter-group">
                            <label><i class="bi bi-geo-alt"></i> City</label>
                            <select name="filterCity" class="form-select">
                                <option value="">All Cities</option>
                                @foreach (var ci in Model.Cities)
                                {
                                    if (Model.FilterCity == ci.Id.ToString()) {
                                        <option value="@ci.Id" selected>@ci.Name</option>
                                    } else {
                                        <option value="@ci.Id">@ci.Name</option>
                                    }
                                }
                            </select>
                        </div>
                    }

                    <div class="filter-group">
                        <label><i class="bi bi-cash-coin"></i> Payment</label>
                        <select name="filterPayment" class="form-select">
                            <option value="">All</option>
                            @if (Model.FilterPayment == "yes") {
                                <option value="yes" selected>Received</option>
                            } else {
                                <option value="yes">Received</option>
                            }
                            @if (Model.FilterPayment == "no") {
                                <option value="no" selected>Pending</option>
                            } else {
                                <option value="no">Pending</option>
                            }
                        </select>
                    </div>

                    @if (!isClient)
                    {
                        <div class="filter-group">
                            <label><i class="bi bi-calendar-event"></i> From Date</label>
                            <input type="date" name="dateFrom" value="@Model.DateFrom" class="form-control" />
                        </div>
                        <div class="filter-group">
                            <label><i class="bi bi-calendar-event"></i> To Date</label>
                            <input type="date" name="dateTo" value="@Model.DateTo" class="form-control" />
                        </div>
                    }

                    <div class="filter-group filter-actions">
                        <button type="submit" class="btn-primary-modern">
                            <i class="bi bi-funnel"></i> Filter
                        </button>
                        <a asp-action="Index" class="btn-secondary-modern">
                            <i class="bi bi-arrow-counterclockwise"></i> Reset
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- ============ INQUIRIES TABLE ============ -->
    <div class="card-modern">
        <div class="card-header-modern">
            <h6>
                <i class="bi bi-list-ul"></i>
                @(isClient ? "My Inquiries" : "All Inquiries")
                <span class="records-count">@Model.Inquiries.Count records</span>
            </h6>
        </div>

        @if (Model.Inquiries.Count == 0)
        {
            <div class="empty-state-modern">
                <i class="bi bi-inbox"></i>
                <p>No inquiries found.</p>
                @if (isClient)
                {
                    <a asp-action="Create" class="btn-primary-modern">
                        <i class="bi bi-plus-lg"></i> Create Your First Inquiry
                    </a>
                }
            </div>
        }
        else
        {
            <div class="table-responsive-custom">
                <table class="table-modern">
                    <thead>
                        <tr>
                            <th class="col-num">#</th>
                            <th>Hotel Name</th>
                            @if (!isClient) { <th class="table-mobile-hide">Client</th> }
                            @if (!isClient) { <th class="table-mobile-hide">Client ID</th> }
                            <th class="table-mobile-hide">Contact</th>
                            <th class="table-mobile-hide">City</th>
                            <th class="table-mobile-hide">Module</th>
                            <th class="col-status">Status</th>
                            @if (!isClient) { <th class="table-mobile-hide">Follow-up</th> }
                            <th class="table-mobile-hide">Date</th>
                            <th class="col-actions text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int sr = 1; }
                        @foreach (var inq in Model.Inquiries)
                        {
                            <tr>
                                <td class="col-num"><span class="row-index">@sr</span></td>
                                <td class="cell-wrap"><span class="hotel-name">@inq.HotelName</span></td>

                                @if (!isClient)
                                {
                                    <td class="table-mobile-hide cell-wrap"><span class="client-name">@inq.ClientName</span></td>
                                    <td class="table-mobile-hide">
                                        @if (inq.ClientId.HasValue)
                                        {
                                            <a asp-controller="Client" asp-action="Details" asp-route-id="@inq.ClientId"
                                               class="client-ref-link">
                                                @(string.IsNullOrEmpty(inq.ClientRef) ? $"#{inq.ClientId}" : inq.ClientRef)
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted-cell">—</span>
                                        }
                                    </td>
                                }

                                <td class="table-mobile-hide">
                                    <span class="contact-cell"><i class="bi bi-telephone"></i>@inq.ClientNumber</span>
                                </td>
                                <td class="table-mobile-hide">
                                    @if (!string.IsNullOrEmpty(inq.CityName))
                                    {
                                        <span class="city-cell"><i class="bi bi-geo-alt"></i>@inq.CityName</span>
                                    }
                                    else { <span class="text-muted-cell">—</span> }
                                </td>
                                <td class="table-mobile-hide">
                                    @if (inq.ModuleName != null)
                                    {
                                        <span class="badge-modern badge-primary">
                                            <i class="bi bi-grid"></i> @inq.ModuleName
                                        </span>
                                    }
                                    else { <span class="text-muted-cell">—</span> }
                                </td>
                                <td class="col-status">
                                    @if (inq.StatusName != null)
                                    {
                                        <span class="badge-modern badge-status">
                                            <i class="bi bi-flag"></i> @inq.StatusName
                                        </span>
                                    }
                                    else { <span class="text-muted-cell">—</span> }
                                </td>

                                @if (!isClient)
                                {
                                    <td class="table-mobile-hide">
                                        @if (inq.FollowupDate.HasValue)
                                        {
                                            var isOverdue = inq.FollowupDate.Value.Date < DateTime.Today;
                                            var isToday = inq.FollowupDate.Value.Date == DateTime.Today;
                                            if (isOverdue)
                                            {
                                                <span class="followup-chip followup-overdue">
                                                    <i class="bi bi-exclamation-circle"></i>
                                                    @inq.FollowupDate.Value.ToString("dd MMM yy")
                                                </span>
                                            }
                                            else if (isToday)
                                            {
                                                <span class="followup-chip followup-today">
                                                    <i class="bi bi-bell"></i>
                                                    @inq.FollowupDate.Value.ToString("dd MMM yy")
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="followup-chip followup-future">
                                                    <i class="bi bi-calendar3"></i>
                                                    @inq.FollowupDate.Value.ToString("dd MMM yy")
                                                </span>
                                            }
                                        }
                                        else { <span class="text-muted-cell">—</span> }
                                    </td>
                                }

                                <td class="table-mobile-hide">
                                    <span class="date-cell"><i class="bi bi-calendar3"></i>@inq.CreatedAt.ToString("dd MMM yy")</span>
                                </td>

                                <td class="col-actions text-end">
                                    <div class="action-buttons">
                                        <a asp-action="Details" asp-route-id="@inq.Id"
                                           class="btn-icon-sm" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (isClient)
                                        {
                                            <a asp-action="Edit" asp-route-id="@inq.Id"
                                               class="btn-icon-sm" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                            sr++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div> *@



@model InquiryListViewModel
@{
    ViewData["Title"] = "Inquiries";
    var inqRole = Context.Session.GetString("UserRole") ?? "";
    bool isClient = inqRole == "Client";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

<style>
    /* ============ DESIGN SYSTEM ============ */
    :root {
        --primary: #4f46e5;
        --primary-dark: #4338ca;
        --primary-light: #eef2ff;
        --primary-grad: linear-gradient(135deg, #6366f1 0%, #4f46e5 50%, #7c3aed 100%);
        --success: #059669;
        --success-light: #d1fae5;
        --warning: #d97706;
        --warning-light: #fef3c7;
        --danger: #dc2626;
        --danger-light: #fee2e2;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --shadow-xs: 0 1px 2px 0 rgb(0 0 0 / 0.04);
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px -1px rgba(0,0,0,0.04);
        --shadow-md: 0 4px 12px -2px rgba(0,0,0,0.08), 0 2px 6px -2px rgba(0,0,0,0.04);
        --shadow-lg: 0 12px 28px -6px rgba(79,70,229,0.15), 0 4px 10px -4px rgba(0,0,0,0.05);
        --radius-md: 12px;
        --radius-lg: 16px;
    }

    body {
        background:
            radial-gradient(circle at 0% 0%, rgba(99, 102, 241, 0.06) 0%, transparent 40%),
            radial-gradient(circle at 100% 0%, rgba(139, 92, 246, 0.05) 0%, transparent 40%),
            #f7f8fc;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        color: var(--gray-900);
    }

    .inquiries-wrapper {
        max-width: 1440px;
        margin: 0 auto;
        padding: 1.75rem 1.5rem;
    }

    /* ============ PAGE HEADER ============ */
    .page-header-modern {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    .page-header-modern h4 {
        font-size: 1.75rem;
        font-weight: 800;
        letter-spacing: -0.025em;
        background: linear-gradient(135deg, var(--gray-900) 0%, var(--primary) 100%);
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin: 0 0 0.25rem 0;
        line-height: 1.15;
        display: flex;
        align-items: center;
        gap: 0.55rem;
    }
    .page-header-modern h4 i {
        -webkit-text-fill-color: var(--primary);
        font-size: 1.4rem;
    }
    .page-header-modern .subtitle {
        color: var(--gray-500);
        font-size: 0.88rem;
        font-weight: 500;
        margin: 0;
    }
    .page-actions-modern {
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
    }

    /* ============ BUTTONS ============ */
    .btn-primary-modern,
    .btn-outline-success-modern,
    .btn-secondary-modern {
        height: 40px;
        padding: 0 1.1rem;
        font-weight: 600;
        font-size: 0.83rem;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.45rem;
        text-decoration: none;
        white-space: nowrap;
        transition: all 0.22s cubic-bezier(.4,0,.2,1);
        line-height: 1;
        border: 1.5px solid transparent;
    }
    .btn-primary-modern {
        background: var(--primary-grad);
        color: white;
        box-shadow: 0 4px 12px -3px rgba(79, 70, 229, 0.4);
    }
    .btn-primary-modern:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 18px -4px rgba(79, 70, 229, 0.5);
        color: white;
    }
    .btn-outline-success-modern {
        background: white;
        border-color: var(--gray-200);
        color: var(--gray-700);
        box-shadow: var(--shadow-xs);
    }
    .btn-outline-success-modern:hover {
        border-color: var(--success);
        color: var(--success);
        background: var(--success-light);
        transform: translateY(-2px);
    }
    .btn-secondary-modern {
        background: white;
        border-color: var(--gray-200);
        color: var(--gray-700);
    }
    .btn-secondary-modern:hover {
        border-color: var(--gray-400);
        background: var(--gray-50);
        color: var(--gray-900);
    }

    /* ============ CARD / PANEL ============ */
    .card-modern {
        background: white;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        margin-bottom: 1.25rem;
        overflow: hidden;
        transition: box-shadow 0.25s;
    }
    .card-modern:hover { box-shadow: var(--shadow-md); }

    .card-header-modern {
        padding: 1rem 1.25rem;
        background: linear-gradient(180deg, #fafbff 0%, #ffffff 100%);
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
        min-height: 60px;
    }
    .card-header-modern h6 {
        font-size: 0.95rem;
        font-weight: 700;
        margin: 0;
        color: var(--gray-900);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        letter-spacing: -0.01em;
        line-height: 1.4;
    }
    .card-header-modern h6 i {
        color: var(--primary);
        font-size: 1.05rem;
    }
    .records-count {
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--gray-600);
        background: var(--gray-100);
        padding: 0.25rem 0.65rem;
        border-radius: 999px;
        margin-left: 0.4rem;
        line-height: 1;
    }
    .card-body-modern { padding: 1.25rem; }

    /* ============ FILTERS ============ */
    .filter-grid {
        display: grid;
        gap: 0.9rem;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        align-items: end;
    }
    .filter-group { min-width: 0; }
    .filter-group label {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--gray-600);
        margin-bottom: 0.4rem;
        line-height: 1;
    }
    .filter-group label i { color: var(--primary); font-size: 0.8rem; }

    .filter-group .form-control,
    .filter-group .form-select {
        height: 40px;
        font-size: 0.86rem;
        border-radius: 10px;
        border: 1.5px solid var(--gray-200);
        background: white;
        color: var(--gray-800);
        transition: all 0.2s ease;
        padding: 0 0.8rem;
        width: 100%;
        line-height: 1.2;
    }
    .filter-group .form-control:focus,
    .filter-group .form-select:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.12);
        outline: none;
    }

    .input-group-custom {
        display: flex;
        align-items: stretch;
        height: 40px;
    }
    .input-group-custom .input-group-text {
        background: white;
        border: 1.5px solid var(--gray-200);
        border-right: none;
        border-radius: 10px 0 0 10px;
        color: var(--primary);
        padding: 0 0.7rem;
        display: flex;
        align-items: center;
        font-size: 0.9rem;
    }
    .input-group-custom .form-control {
        border-radius: 0 10px 10px 0;
        border-left: none;
        height: 40px;
    }

    .filter-actions {
        display: flex;
        gap: 0.55rem;
        align-items: end;
    }
    .filter-actions .btn-primary-modern,
    .filter-actions .btn-secondary-modern {
        flex: 1;
    }

    /* ============ TABLE ============ */
    .table-responsive-custom {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }
    .table-modern {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.85rem;
        table-layout: auto;
    }
    .table-modern thead th {
        background: var(--gray-50);
        color: var(--gray-500);
        font-weight: 600;
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 0.85rem 0.9rem;
        border-bottom: 1px solid var(--gray-200);
        white-space: nowrap;
        vertical-align: middle;
        line-height: 1.2;
    }
    .table-modern tbody td {
        padding: 0.85rem 0.9rem;
        border-bottom: 1px solid var(--gray-100);
        vertical-align: middle;
        color: var(--gray-800);
        line-height: 1.45;
        white-space: nowrap; /* prevent wrapping for tight cells */
    }
    /* allow wrapping only for long text columns */
    .table-modern tbody td.cell-wrap { white-space: normal; }

    .table-modern tbody tr {
        transition: background 0.15s;
    }
    .table-modern tbody tr:hover { background: var(--gray-50); }
    .table-modern tbody tr:last-child td { border-bottom: none; }

    .row-index {
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--gray-400);
        font-variant-numeric: tabular-nums;
    }
    .hotel-name {
        font-weight: 700;
        color: var(--gray-900);
        font-size: 0.88rem;
    }
    .client-name {
        color: var(--gray-700);
        font-weight: 500;
    }
    .contact-cell, .city-cell, .date-cell {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.83rem;
        color: var(--gray-700);
        white-space: nowrap;
        font-variant-numeric: tabular-nums;
    }
    .contact-cell i, .city-cell i, .date-cell i {
        color: var(--primary);
        font-size: 0.8rem;
        flex-shrink: 0;
    }
    .date-cell { color: var(--gray-500); }
    .date-cell i { color: var(--gray-400); }

    /* ============ BADGES ============ */
    .badge-modern {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.7rem;
        font-weight: 600;
        padding: 0.3rem 0.7rem;
        border-radius: 999px;
        white-space: nowrap;
        border: 1px solid transparent;
        line-height: 1.2;
    }
    .badge-primary {
        background: var(--primary-light);
        color: var(--primary);
        border-color: rgba(79, 70, 229, 0.15);
    }
    .badge-status {
        background: var(--warning-light);
        color: var(--warning);
        border-color: rgba(217, 119, 6, 0.2);
    }

    /* ============ CLIENT REF ============ */
    .client-ref-link {
        color: var(--primary);
        font-weight: 700;
        text-decoration: none;
        font-family: 'SF Mono', 'Consolas', monospace;
        font-size: 0.72rem;
        background: var(--primary-light);
        padding: 0.3rem 0.6rem;
        border-radius: 0.5rem;
        display: inline-block;
        border: 1px solid rgba(79, 70, 229, 0.12);
        transition: all 0.2s;
        white-space: nowrap;
        line-height: 1;
    }
    .client-ref-link:hover {
        background: var(--primary);
        color: white;
        transform: translateY(-1px);
    }

    /* ============ ACTION BUTTONS ============ */
    .action-buttons {
        display: inline-flex;
        gap: 0.35rem;
        justify-content: flex-end;
    }
    .btn-icon-sm {
        width: 32px;
        height: 32px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        border: 1px solid var(--gray-200);
        background: white;
        color: var(--gray-600);
        transition: all 0.2s ease;
        text-decoration: none;
        font-size: 0.85rem;
        line-height: 1;
    }
    .btn-icon-sm:hover {
        background: var(--primary-light);
        border-color: var(--primary);
        color: var(--primary);
        transform: translateY(-1px);
        box-shadow: 0 4px 10px -3px rgba(79, 70, 229, 0.25);
    }

    /* ============ FOLLOW-UP ============ */
    .followup-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.3rem 0.65rem;
        border-radius: 0.5rem;
        font-size: 0.76rem;
        font-weight: 600;
        white-space: nowrap;
        line-height: 1.2;
        font-variant-numeric: tabular-nums;
    }
    .followup-chip i { font-size: 0.78rem; flex-shrink: 0; }
    .followup-overdue { color: var(--danger); background: var(--danger-light); }
    .followup-today   { color: var(--warning); background: var(--warning-light); }
    .followup-future  { color: var(--gray-700); background: var(--gray-50); border: 1px solid var(--gray-200); }
    .followup-future i { color: var(--gray-400); }

    /* ============ EMPTY STATE ============ */
    .empty-state-modern {
        text-align: center;
        padding: 3.5rem 1.5rem;
        color: var(--gray-500);
    }
    .empty-state-modern i {
        font-size: 3.25rem;
        color: var(--gray-300);
        margin-bottom: 0.85rem;
        display: block;
    }
    .empty-state-modern p {
        font-size: 0.95rem;
        font-weight: 500;
        margin-bottom: 1rem;
    }

    .text-muted-cell {
        color: var(--gray-400);
        font-weight: 500;
    }

    /* ============ COLUMN HINTS ============ */
    /* Keep small fixed widths only where needed; let browser balance the rest */
    .col-num     { width: 48px; text-align: center; }
    .col-status  { width: 130px; }
    .col-actions { width: 90px; }

    /* ============ RESPONSIVE ============ */
    @@media (max-width: 1024px) {
        .filter-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @@media (max-width: 768px) {
        .inquiries-wrapper { padding: 1rem; }
        .page-header-modern h4 { font-size: 1.35rem; }
        .page-header-modern h4 i { font-size: 1.15rem; }
        .card-header-modern { padding: 0.85rem 1rem; min-height: 54px; }
        .card-body-modern { padding: 1rem; }
        .filter-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 0.75rem;
        }
        .filter-actions { grid-column: 1 / -1; }
        .table-mobile-hide { display: none !important; }
        .table-modern thead th,
        .table-modern tbody td {
            padding: 0.7rem 0.6rem;
            font-size: 0.78rem;
        }
        .btn-icon-sm { width: 30px; height: 30px; font-size: 0.78rem; }
    }
    @@media (max-width: 480px) {
        .filter-grid { grid-template-columns: 1fr; }
        .page-header-modern { flex-direction: column; align-items: stretch; }
        .page-actions-modern { width: 100%; }
        .page-actions-modern .btn-primary-modern,
        .page-actions-modern .btn-outline-success-modern { flex: 1; }
    }
</style>

<div class="inquiries-wrapper">
    <!-- ============ PAGE HEADER ============ -->
    <div class="page-header-modern">
        <div>
            <h4>
                <i class="bi bi-chat-left-text-fill"></i>
                @(isClient ? "My Inquiries" : "Inquiries")
            </h4>
            <p class="subtitle">@(isClient ? "Your submitted service inquiries" : "Manage all hotel lead inquiries")</p>
        </div>

        <div class="page-actions-modern">
            @if (!isClient)
            {
                <a asp-action="Export"
                   asp-route-search="@Model.Search"
                   asp-route-filterStatus="@Model.FilterStatus"
                   asp-route-filterModule="@Model.FilterModule"
                   asp-route-filterPayment="@Model.FilterPayment"
                   asp-route-filterCity="@Model.FilterCity"
                   asp-route-dateFrom="@Model.DateFrom"
                   asp-route-dateTo="@Model.DateTo"
                   class="btn-outline-success-modern">
                    <i class="bi bi-file-earmark-excel"></i> Export
                </a>
            }
            @if (isClient)
            {
                <a asp-action="Create" class="btn-primary-modern">
                    <i class="bi bi-plus-lg"></i> New Inquiry
                </a>
            }
        </div>
    </div>

    <!-- ============ FILTERS ============ -->
    <div class="card-modern">
        <div class="card-header-modern">
            <h6><i class="bi bi-funnel-fill"></i> Filters</h6>
        </div>
        <div class="card-body-modern">
            <form method="get" asp-action="Index">
                <div class="filter-grid">
                    <div class="filter-group">
                        <label><i class="bi bi-search"></i> Search</label>
                        <div class="input-group-custom">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" name="search" value="@Model.Search"
                                   class="form-control" placeholder="Hotel, client, number…" />
                        </div>
                    </div>

                    <div class="filter-group">
                        <label><i class="bi bi-flag"></i> Status</label>
                        <select name="filterStatus" class="form-select">
                            <option value="">All Statuses</option>
                            @foreach (var s in Model.Statuses)
                            {
                                if (Model.FilterStatus == s.Id) {
                                    <option value="@s.Id" selected>@s.Name</option>
                                } else {
                                    <option value="@s.Id">@s.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="filter-group">
                        <label><i class="bi bi-grid"></i> Module</label>
                        <select name="filterModule" class="form-select">
                            <option value="">All Modules</option>
                            @foreach (var m in Model.Modules)
                            {
                                if (Model.FilterModule == m.Id) {
                                    <option value="@m.Id" selected>@m.Name</option>
                                } else {
                                    <option value="@m.Id">@m.Name</option>
                                }
                            }
                        </select>
                    </div>

                    @if (!isClient)
                    {
                        <div class="filter-group">
                            <label><i class="bi bi-geo-alt"></i> City</label>
                            <select name="filterCity" class="form-select">
                                <option value="">All Cities</option>
                                @foreach (var ci in Model.Cities)
                                {
                                    if (Model.FilterCity == ci.Id.ToString()) {
                                        <option value="@ci.Id" selected>@ci.Name</option>
                                    } else {
                                        <option value="@ci.Id">@ci.Name</option>
                                    }
                                }
                            </select>
                        </div>
                    }

                    <div class="filter-group">
                        <label><i class="bi bi-cash-coin"></i> Payment</label>
                        <select name="filterPayment" class="form-select">
                            <option value="">All</option>
                            @if (Model.FilterPayment == "yes") {
                                <option value="yes" selected>Received</option>
                            } else {
                                <option value="yes">Received</option>
                            }
                            @if (Model.FilterPayment == "no") {
                                <option value="no" selected>Pending</option>
                            } else {
                                <option value="no">Pending</option>
                            }
                        </select>
                    </div>

                    @if (!isClient)
                    {
                        <div class="filter-group">
                            <label><i class="bi bi-calendar-event"></i> From Date</label>
                            <input type="date" name="dateFrom" value="@Model.DateFrom" class="form-control" />
                        </div>
                        <div class="filter-group">
                            <label><i class="bi bi-calendar-event"></i> To Date</label>
                            <input type="date" name="dateTo" value="@Model.DateTo" class="form-control" />
                        </div>
                    }

                    <div class="filter-group filter-actions">
                        <button type="submit" class="btn-primary-modern">
                            <i class="bi bi-funnel"></i> Filter
                        </button>
                        <a asp-action="Index" class="btn-secondary-modern">
                            <i class="bi bi-arrow-counterclockwise"></i> Reset
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- ============ INQUIRIES TABLE ============ -->
    <div class="card-modern">
        <div class="card-header-modern">
            <h6>
                <i class="bi bi-list-ul"></i>
                @(isClient ? "My Inquiries" : "All Inquiries")
                <span class="records-count">@Model.Inquiries.Count records</span>
            </h6>
        </div>

        @if (Model.Inquiries.Count == 0)
        {
            <div class="empty-state-modern">
                <i class="bi bi-inbox"></i>
                <p>No inquiries found.</p>
                @if (isClient)
                {
                    <a asp-action="Create" class="btn-primary-modern">
                        <i class="bi bi-plus-lg"></i> Create Your First Inquiry
                    </a>
                }
            </div>
        }
        else
        {
            <div class="table-responsive-custom">
                <table class="table-modern">
                    <thead>
                        <tr>
                            <th class="col-num">#</th>
                            <th>Hotel Name</th>
                            @if (!isClient) { <th class="table-mobile-hide">Client</th> }
                            @if (!isClient) { <th class="table-mobile-hide">Client ID</th> }
                            <th class="table-mobile-hide">Contact</th>
                            <th class="table-mobile-hide">City</th>
                            <th class="table-mobile-hide">Module</th>
                            <th class="col-status">Status</th>
                            @if (!isClient) { <th class="table-mobile-hide">Follow-up</th> }
                            <th class="table-mobile-hide">Date</th>
                            <th class="col-actions text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int sr = 1; }
                        @foreach (var inq in Model.Inquiries)
                        {
                            <tr>
                                <td class="col-num"><span class="row-index">@sr</span></td>
                                <td class="cell-wrap"><span class="hotel-name">@inq.HotelName</span></td>

                                @if (!isClient)
                                {
                                    <td class="table-mobile-hide cell-wrap"><span class="client-name">@inq.ClientName</span></td>
                                    <td class="table-mobile-hide">
                                        @if (inq.ClientId.HasValue)
                                        {
                                            <a asp-controller="Client" asp-action="Details" asp-route-id="@inq.ClientId"
                                               class="client-ref-link">
                                                @(string.IsNullOrEmpty(inq.ClientRef) ? $"#{inq.ClientId}" : inq.ClientRef)
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted-cell">—</span>
                                        }
                                    </td>
                                }

                                <td class="table-mobile-hide">
                                    <span class="contact-cell"><i class="bi bi-telephone"></i>@inq.ClientNumber</span>
                                </td>
                                <td class="table-mobile-hide">
                                    @if (!string.IsNullOrEmpty(inq.CityName))
                                    {
                                        <span class="city-cell"><i class="bi bi-geo-alt"></i>@inq.CityName</span>
                                    }
                                    else { <span class="text-muted-cell">—</span> }
                                </td>
                                <td class="table-mobile-hide">
                                    @if (inq.ModuleName != null)
                                    {
                                        <span class="badge-modern badge-primary">
                                            <i class="bi bi-grid"></i> @inq.ModuleName
                                        </span>
                                    }
                                    else { <span class="text-muted-cell">—</span> }
                                </td>
                                <td class="col-status">
                                    @if (inq.StatusName != null)
                                    {
                                        <span class="badge-modern badge-status">
                                            <i class="bi bi-flag"></i> @inq.StatusName
                                        </span>
                                    }
                                    else { <span class="text-muted-cell">—</span> }
                                </td>

                                @if (!isClient)
                                {
                                    <td class="table-mobile-hide">
                                        @if (inq.FollowupDate.HasValue)
                                        {
                                            var isOverdue = inq.FollowupDate.Value.Date < DateTime.Today;
                                            var isToday = inq.FollowupDate.Value.Date == DateTime.Today;
                                            if (isOverdue)
                                            {
                                                <span class="followup-chip followup-overdue">
                                                    <i class="bi bi-exclamation-circle"></i>
                                                    @inq.FollowupDate.Value.ToString("dd MMM yy")
                                                </span>
                                            }
                                            else if (isToday)
                                            {
                                                <span class="followup-chip followup-today">
                                                    <i class="bi bi-bell"></i>
                                                    @inq.FollowupDate.Value.ToString("dd MMM yy")
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="followup-chip followup-future">
                                                    <i class="bi bi-calendar3"></i>
                                                    @inq.FollowupDate.Value.ToString("dd MMM yy")
                                                </span>
                                            }
                                        }
                                        else { <span class="text-muted-cell">—</span> }
                                    </td>
                                }

                                <td class="table-mobile-hide">
                                    <span class="date-cell"><i class="bi bi-calendar3"></i>@inq.CreatedAt.ToString("dd MMM yy")</span>
                                </td>

                                <td class="col-actions text-end">
                                    <div class="action-buttons">
                                        <a asp-action="Details" asp-route-id="@inq.Id"
                                           class="btn-icon-sm" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (isClient)
                                        {
                                            <a asp-action="Edit" asp-route-id="@inq.Id"
                                               class="btn-icon-sm" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                            sr++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

