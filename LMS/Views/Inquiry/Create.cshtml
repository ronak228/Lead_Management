@model InquiryFormViewModel
@{ 
    ViewData["Title"] = "New Inquiry"; 
}

<style>
    .page-header {
        margin-bottom: 2rem;
        padding-bottom: 0.5rem;
    }
    
    .page-header h4 {
        font-size: 1.75rem;
        font-weight: 700;
        background: linear-gradient(135deg, #1a2c3e 0%, #2c3e50 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 0.5rem;
    }
    
    .page-header p {
        color: #6c757d;
        font-size: 0.9rem;
        margin-bottom: 0;
    }
    
    /* Smooth page transition */
    .fade-in {
        animation: fadeInUp 0.5s ease-out;
    }
    
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="page-header fade-in">
    <h4>
        <i class="bi bi-plus-circle-fill" style="color: #0d6efd; font-size: 1.5rem; background: none; -webkit-text-fill-color: #0d6efd;"></i>
        New Inquiry
    </h4>
    <p>Fill in the details to add a new hotel lead inquiry</p>
</div>

<form asp-action="Create" method="post" class="fade-in">
    @await Html.PartialAsync("_Form", Model)
</form>