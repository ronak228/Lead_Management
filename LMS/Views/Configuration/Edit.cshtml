@model ConfigItem
@{
    var tab   = ViewBag.Tab as string ?? "status";
    var label = tab switch {
        "status"   => "Status",
        "module"   => "Module",
        "product"  => "Product",
        "category" => "Category",
        "city"     => "City",
        _          => "Item"
    };
    ViewData["Title"] = $"Edit {label}";
}

<div class="page-header">
    <h4>Edit @label</h4>
    <p>Update the details below and save your changes</p>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card">
            <div class="card-header-clean">
                <h6><i class="bi bi-pencil-square me-2" style="color:var(--brand);"></i>Edit @label</h6>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <input type="hidden" name="tab" value="@tab" />
                    <input type="hidden" name="id"  value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label">@label Name <span class="text-danger">*</span></label>
                        <input type="text" name="name" value="@Model.Name"
                               class="form-control" required placeholder="Enter name" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label d-block">Status</label>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="isActive" value="true"
                                   id="isActiveCheck" @(Model.IsActive ? "checked" : "") />
                            <label class="form-check-label" for="isActiveCheck" style="font-size:.83rem;">
                                Active
                            </label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-brand px-4" style="font-size:.84rem;">
                            <i class="bi bi-check me-1"></i>Save Changes
                        </button>
                        <a asp-action="Index" asp-route-tab="@tab"
                           class="btn btn-outline-secondary px-4" style="font-size:.84rem;">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
