@model ConfigurationViewModel
@{
    ViewData["Title"] = "Configuration";
    var tabs = new[] {
        ("status",   "Status",   "bi-flag"),
        ("module",   "Module",   "bi-box"),
        ("product",  "Product",  "bi-grid"),
        ("category", "Category", "bi-tag"),
        ("city",     "City",     "bi-geo-alt")
    };
}

<div class="page-header d-flex align-items-start justify-content-between">
    <div>
        <h4>Configuration</h4>
        <p>Manage dropdown options used across the system</p>
    </div>
</div>

<!-- Tab Nav -->
<ul class="nav nav-tabs-custom mb-0">
    @foreach (var (key, label, icon) in tabs)
    {
        <li class="nav-item">
            <a class="nav-link @(Model.ActiveTab == key ? "active" : "")"
               href="@Url.Action("Index", new { tab = key })">
                <i class="bi @icon me-1"></i>@label
            </a>
        </li>
    }
</ul>

@foreach (var (key, label, icon) in tabs)
{
    if (Model.ActiveTab != key) continue;

    var items = key switch {
        "status"   => Model.Statuses,
        "module"   => Model.Modules,
        "product"  => Model.Products,
        "category" => Model.Categories,
        "city"     => Model.Cities,
        _          => new()
    };

    <div class="card border-0 shadow-sm" style="border-radius:0 12px 12px 12px;">
        <div class="card-header-clean">
            <div class="d-flex align-items-center gap-2">
                <div class="stat-icon si-indigo" style="width:34px;height:34px;border-radius:8px;">
                    <i class="bi @icon" style="font-size:.85rem;"></i>
                </div>
                <h6>@label Management <span class="text-muted fw-normal" style="font-size:.78rem;">(@items.Count items)</span></h6>
            </div>
            <!-- Add Button triggers modal -->
            <button class="btn btn-brand btn-sm px-3" data-bs-toggle="modal" data-bs-target="#addModal"
                    style="border-radius:8px;font-size:.81rem;">
                <i class="bi bi-plus me-1"></i>Add @label
            </button>
        </div>

        <div class="card-body p-0">
            @if (items.Count == 0)
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox d-block mb-2" style="font-size:2rem;opacity:.3;"></i>
                    No @label entries yet. Click "Add @label" to get started.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-clean mb-0">
                        <thead>
                            <tr>
                                <th style="width:50px;">#</th>
                                <th>Name</th>
                                <th style="width:110px;">Status</th>
                                <th class="table-mobile-hide" style="width:90px;">Added</th>
                                <th style="width:120px;" class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int sr = 1; }
                            @foreach (var item in items)
                            {
                                <tr>
                                    <td class="text-muted">@sr</td>
                                    <td class="fw-500">@item.Name</td>
                                    <td>
                                        <span class="@(item.IsActive ? "badge-active" : "badge-inactive")">
                                            @(item.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td class="text-muted table-mobile-hide" style="font-size:.75rem;">@item.CreatedAt.ToString("dd MMM yy")</td>
                                    <td class="text-end">
                                        <div class="table-actions">
                                        <!-- Edit -->
                                        <a asp-controller="Configuration" asp-action="Edit"
                                           asp-route-tab="@key" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-sm-icon btn-outline-secondary"
                                           title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <!-- Toggle -->
                                        <form asp-action="Toggle" asp-route-tab="@key" asp-route-id="@item.Id"
                                              method="post" class="d-inline">
                                            <button type="submit"
                                                    class="btn btn-sm btn-sm-icon @(item.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                    title="@(item.IsActive ? "Deactivate" : "Activate")">
                                                <i class="bi @(item.IsActive ? "bi-pause" : "bi-play")"></i>
                                            </button>
                                        </form>
                                        <!-- Delete -->
                                        <form asp-action="Delete" asp-route-tab="@key" asp-route-id="@item.Id"
                                              method="post" class="d-inline"
                                              onsubmit="return confirm('Delete \'@item.Name\'?')">
                                            <button type="submit"
                                                    class="btn btn-sm btn-sm-icon btn-outline-danger"
                                                    title="Delete">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </form>
                                        </div>
                                    </td>
                                </tr>
                                sr++;
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Add Modal -->
    <div class="modal fade" id="addModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered" style="max-width:420px;">
            <div class="modal-content">
                <form asp-action="Add" method="post">
                    <input type="hidden" name="tab" value="@key" />
                    <div class="modal-header">
                        <h6 class="modal-title fw-600" style="font-weight:600;">
                            <i class="bi @icon me-2" style="color:var(--brand);"></i>Add New @label
                        </h6>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4">
                        <div class="mb-1">
                            <label class="form-label">@label Name <span class="text-danger">*</span></label>
                            <input type="text" name="name" class="form-control" required
                                   placeholder="Enter @label name" autofocus />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-sm btn-light" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-brand btn-sm px-4">
                            <i class="bi bi-check me-1"></i>Save
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
// Auto-open add modal if there was a validation error on add
@if (TempData["OpenAddModal"] != null)
{
    <text>
    document.addEventListener('DOMContentLoaded', function() {
        new bootstrap.Modal(document.getElementById('addModal')).show();
    });
    </text>
}
</script>
}
