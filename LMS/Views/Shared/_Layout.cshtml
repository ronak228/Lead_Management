<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Lead Management</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
@{
    var isLoggedIn  = Context.Session.GetInt32("UserId").HasValue;
    var sessionName = Context.Session.GetString("UserName") ?? "";
    var sessionRole = Context.Session.GetString("UserRole") ?? "";
    var ctrl        = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var initials    = sessionName.Length > 0 ? sessionName[0].ToString().ToUpper() : "U";
}
@if (isLoggedIn)
{
<div class="d-flex" id="wrapper">
  <nav id="sidebar">
    <div class="sidebar-brand">
      <div class="brand-icon"><i class="bi bi-building"></i></div>
      <div><div class="brand-text">LeadMS</div><div class="brand-sub">Hotel Portal</div></div>
    </div>
    <ul class="nav flex-column mt-1 px-0">
      <li class="nav-section-label"><span>Main</span></li>
      <li class="nav-item">
        <a class="nav-link @(ctrl=="Dashboard"?"active":"")" asp-controller="Dashboard" asp-action="Index">
          <i class="bi bi-grid-1x2"></i><span>Dashboard</span><span class="nav-tooltip">Dashboard</span></a>
      </li>

      @* ── Staff navigation (Admin + Employee) ── *@
      @if (sessionRole == "Admin" || sessionRole == "Employee")
      {
      <li class="nav-item">
        <a class="nav-link @(ctrl=="Inquiry"?"active":"")" asp-controller="Inquiry" asp-action="Index">
          <i class="bi bi-search"></i><span>Inquiries</span><span class="nav-tooltip">Inquiries</span></a>
      </li>
      <li class="nav-item">
        <a class="nav-link @(ctrl=="Client"?"active":"")" asp-controller="Client" asp-action="Index">
          <i class="bi bi-person-lines-fill"></i><span>Clients</span><span class="nav-tooltip">Clients</span></a>
      </li>
      <li class="nav-item">
        <a class="nav-link @(ctrl=="Payment"?"active":"")" asp-controller="Payment" asp-action="Index">
          <i class="bi bi-cash-coin"></i><span>Payments</span><span class="nav-tooltip">Payments</span></a>
      </li>
      <li class="nav-item">
        <a class="nav-link @(ctrl=="Expense"?"active":"")" asp-controller="Expense" asp-action="Index">
          <i class="bi bi-receipt"></i><span>Expenses</span><span class="nav-tooltip">Expenses</span></a>
      </li>
      }

      @* ── Client self-service ── *@
      @if (sessionRole == "Client")
      {
      <li class="nav-item">
        <a class="nav-link @(ctrl=="Inquiry"?"active":"")" asp-controller="Inquiry" asp-action="Index">
          <i class="bi bi-search"></i><span>My Inquiries</span><span class="nav-tooltip">My Inquiries</span></a>
      </li>
      <li class="nav-item">
        <a class="nav-link @(ctrl=="Payment"?"active":"")" asp-controller="Payment" asp-action="Index">
          <i class="bi bi-cash-coin"></i><span>My Payments</span><span class="nav-tooltip">My Payments</span></a>
      </li>
      <li class="nav-item">
        <a class="nav-link @(ctrl=="Client"?"active":"")" asp-controller="Client" asp-action="Index">
          <i class="bi bi-person-badge"></i><span>My Profile</span><span class="nav-tooltip">My Profile</span></a>
      </li>
      }

      @* ── Admin-only section ── *@
      @if (sessionRole == "Admin")
      {
      <li class="nav-section-label"><span>Admin</span></li>
      <li class="nav-item">
        <a class="nav-link @(ctrl=="Configuration"?"active":"")" asp-controller="Configuration" asp-action="Index">
          <i class="bi bi-sliders"></i><span>Configuration</span><span class="nav-tooltip">Configuration</span></a>
      </li>
      <li class="nav-item">
        <a class="nav-link @(ctrl=="UserManagement"?"active":"")" asp-controller="UserManagement" asp-action="Index">
          <i class="bi bi-people"></i><span>Users</span><span class="nav-tooltip">Users</span></a>
      </li>
      }
    </ul>
    <div class="sidebar-footer">
      <div class="sidebar-user">
        <div class="sidebar-avatar">@initials</div>
        <div class="sidebar-user-info">
          <div class="u-name">@sessionName</div>
          <span class="u-role @(sessionRole=="Admin"?"admin":"")">@sessionRole</span>
        </div>
      </div>
      <a asp-controller="Auth" asp-action="Logout" class="btn-logout">
        <i class="bi bi-box-arrow-right"></i><span>Sign Out</span>
      </a>
    </div>
  </nav>
  <div id="sidebarOverlay"></div>
  <div id="page-content">
    <nav class="top-navbar">
      <button class="btn-toggle" id="sidebarToggle"><i class="bi bi-list fs-5"></i></button>
      <span class="page-title">@ViewData["Title"]</span>
      <div class="ms-auto d-flex align-items-center gap-2">
        <span style="background:var(--brand-soft);color:var(--brand);font-size:.72rem;font-weight:600;padding:3px 10px;border-radius:20px;">@sessionRole</span>
        <span class="text-muted" style="font-size:.8rem;">@sessionName</span>
      </div>
    </nav>
    <main class="main-content">
      @if (TempData["Success"] != null)
      {<div class="alert alert-success d-flex align-items-center gap-2 mb-3"><i class="bi bi-check-circle-fill"></i>@TempData["Success"]</div>}
      @if (TempData["Error"] != null)
      {<div class="alert alert-danger d-flex align-items-center gap-2 mb-3"><i class="bi bi-exclamation-triangle-fill"></i>@TempData["Error"]</div>}
      @RenderBody()
    </main>
  </div>
</div>
}
else
{ @RenderBody() }
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  (function() {
    var toggle   = document.getElementById('sidebarToggle');
    var wrapper  = document.getElementById('wrapper');
    var overlay  = document.getElementById('sidebarOverlay');

    function isMobile() { return window.innerWidth < 768; }

    toggle && toggle.addEventListener('click', function() {
      if (isMobile()) {
        document.body.classList.toggle('sidebar-open');
      } else {
        wrapper && wrapper.classList.toggle('sidebar-collapsed');
      }
    });

    overlay && overlay.addEventListener('click', function() {
      document.body.classList.remove('sidebar-open');
    });

    // Close mobile sidebar on resize to desktop
    window.addEventListener('resize', function() {
      if (!isMobile()) document.body.classList.remove('sidebar-open');
    });
  })();
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
