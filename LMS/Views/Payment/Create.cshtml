                           class="btn btn-outline-secondary py-2" style="font-size:.84rem;">Cancel</a>
                    }
                    else
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary py-2" style="font-size:.84rem;">Cancel</a>
                    }
                </div>
            </div>
        </div>
    </div>
</form>

<script>
(function(){
    var modeEl = document.getElementById('paymentMode');
    var cheque = document.getElementById('fieldCheque');
    var txn    = document.getElementById('fieldTransaction');
    var bank   = document.getElementById('fieldBank');
    function update(){
        var m = modeEl.value;
        cheque.style.display = m === 'Cheque' ? '' : 'none';
        txn.style.display    = m === 'Online' ? '' : 'none';
        bank.style.display   = (m === 'Cheque' || m === 'Online') ? '' : 'none';
    }
    modeEl.addEventListener('change', update);
    update();

    var clientSelect = document.getElementById('clientSelect');
    if (clientSelect) {
        clientSelect.addEventListener('change', function () {
            var clientId = this.value;
            if (!clientId) return;
            var url = '@Url.Action("Create", "Payment")';
            window.location.href = url + '?clientId=' + encodeURIComponent(clientId);
        });
    }
})();
</script> *@








@model PaymentFormViewModel
@{ ViewData["Title"] = Model.Client != null ? $"Add Payment – {Model.Client.CompanyName}" : "Add Payment"; }

<style>
    /* Clean professional styles matching other pages */
    
    /* Card enhancements */
    .card {
        border-radius: 16px;
        border: 1px solid rgba(0, 0, 0, 0.05);
        background: #ffffff;
        transition: all 0.2s ease;
    }
    
    .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
    }
    
    /* Button refinements */
    .btn-brand {
        background-color: #0d6efd;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.2s ease;
    }
    
    .btn-brand:hover {
        background-color: #0b5ed7;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(13, 110, 253, 0.2);
    }
    
    .btn-outline-secondary {
        border-radius: 10px;
        transition: all 0.2s ease;
    }
    
    .btn-outline-secondary:hover {
        transform: translateY(-1px);
    }
    
    /* Card header */
    .card-header-clean {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        padding: 1rem 1.25rem;
        background: #ffffff;
        border-bottom: 1px solid #e9ecef;
    }
    
    .card-header-clean h6 {
        font-weight: 700;
        font-size: 0.9rem;
        margin-bottom: 0;
        color: #1a2c3e;
    }
    
    /* Form styling */
    .form-label {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.3px;
        color: #495057;
        margin-bottom: 6px;
    }
    
    .form-control,
    .form-select {
        border-radius: 10px;
        border: 1px solid #dee2e6;
        padding: 0.5rem 0.75rem;
        font-size: 0.85rem;
        transition: all 0.2s ease;
    }
    
    .form-control:focus,
    .form-select:focus {
        box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.1);
        border-color: #0d6efd;
    }
    
    .form-text {
        font-size: 0.7rem;
        color: #6c757d;
        margin-top: 4px;
    }
    
    /* Alert box styling */
    .alert-light {
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 12px;
    }
    
    /* Stats boxes */
    .stat-box {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 12px;
        text-align: center;
        transition: all 0.2s ease;
    }
    
    .stat-box:hover {
        background: #f0f2f5;
        transform: translateY(-2px);
    }
    
    .stat-label {
        font-size: 0.7rem;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
        margin-bottom: 4px;
    }
    
    .stat-value {
        font-size: 1.1rem;
        font-weight: 700;
    }
    
    .stat-value.positive {
        color: #16a34a;
    }
    
    .stat-value.negative {
        color: #dc2626;
    }
    
    /* Action buttons container */
    .action-buttons {
        position: sticky;
        top: 20px;
    }
    
    /* Responsive */
    @@media (max-width: 768px) {
        body {
            padding: 12px;
        }
        
        .page-header h4 {
            font-size: 1.3rem;
        }
        
        .row.g-4 {
            gap: 1rem;
        }
        
        .stat-box {
            padding: 8px;
        }
        
        .stat-value {
            font-size: 0.95rem;
        }
        
        .action-buttons {
            position: static;
            margin-top: 1rem;
        }
    }
    
    /* Animation for fields */
    #fieldCheque,
    #fieldTransaction,
    #fieldBank {
        transition: all 0.3s ease;
    }
    
    /* File input styling */
    input[type="file"] {
        padding: 0.4rem;
        background: #f8f9fa;
    }
    
    input[type="file"]:hover {
        background: #f0f2f5;
    }
</style>

