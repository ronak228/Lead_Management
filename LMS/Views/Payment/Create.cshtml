<script>
(function(){
    // Payment mode field toggling
    var modeEl = document.getElementById('paymentMode');
    var cheque = document.getElementById('fieldCheque');
    var txn    = document.getElementById('fieldTransaction');
    var bank   = document.getElementById('fieldBank');
    
    function updateFields(){
        var m = modeEl.value;
        if (m === 'Cheque') {
            cheque.style.display = 'block';
            txn.style.display = 'none';
            bank.style.display = 'block';
            
            // Add required attribute to cheque field
            document.querySelector('input[name="Payment.ChequeNo"]').required = true;
            document.querySelector('input[name="Payment.TransactionId"]').required = false;
            document.querySelector('input[name="Payment.BankName"]').required = true;
        } 
        else if (m === 'Online') {
            cheque.style.display = 'none';
            txn.style.display = 'block';
            bank.style.display = 'block';
            
            // Add required attribute to online fields
            document.querySelector('input[name="Payment.ChequeNo"]').required = false;
            document.querySelector('input[name="Payment.TransactionId"]').required = true;
            document.querySelector('input[name="Payment.BankName"]').required = true;
        } 
        else {
            cheque.style.display = 'none';
            txn.style.display = 'none';
            bank.style.display = 'none';
            
            // Remove required attributes
            document.querySelector('input[name="Payment.ChequeNo"]').required = false;
            document.querySelector('input[name="Payment.TransactionId"]').required = false;
            document.querySelector('input[name="Payment.BankName"]').required = false;
        }
    }
    
    modeEl.addEventListener('change', updateFields);
    updateFields();

    // Client selection redirect
    var clientSelect = document.getElementById('clientSelect');
    if (clientSelect) {
        clientSelect.addEventListener('change', function () {
            var clientId = this.value;
            if (!clientId) return;
            var url = '@Url.Action("Create", "Payment")';
            window.location.href = url + '?clientId=' + encodeURIComponent(clientId);
        });
    }
    
    // Amount validation
    var amountInput = document.querySelector('input[name="Payment.Amount"]');
    if (amountInput) {
        amountInput.addEventListener('change', function() {
            if (this.value <= 0) {
                this.setCustomValidity('Amount must be greater than 0');
            } else {
                this.setCustomValidity('');
            }
        });
    }
})();
</script>