@model Payment
@{ ViewData["Title"] = "Payment Details"; }

<div class="page-header d-flex align-items-start justify-content-between flex-wrap gap-2">
    <div>
        <h4>Payment Details</h4>
        <p>Receipt for <strong>@(Model.CompanyName ?? "—")</strong></p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Client" asp-action="Details" asp-route-id="@Model.ClientId"
           class="btn btn-outline-secondary px-3" style="font-size:.84rem;">
            <i class="bi bi-arrow-left me-1"></i>Back to Client
        </a>
    </div>
</div>

<div class="row g-4 justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header-clean">
                <h6><i class="bi bi-cash-coin me-2" style="color:var(--brand);"></i>Payment Receipt</h6>
            </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    @{
                        void Field(string label, string? val)
                        {
                            <div class="col-sm-6">
                                <div style="font-size:.74rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:3px;">@label</div>
                                <div style="font-size:.88rem;font-weight:500;">@(val ?? "—")</div>
                            </div>
                        }
                    }
                    @{ Field("Client", Model.CompanyName); }
                    @{ Field("Client Ref", Model.ClientRef); }
                    @{ Field("Contact", Model.ContactPerson); }
                    @{ Field("Payment Date", Model.PaymentDate.ToString("dd MMM yyyy")); }
                    @{ Field("Mode", Model.PaymentMode); }
                    <div class="col-sm-12">
                        <div style="font-size:.74rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:3px;">Amount</div>
                        <div style="font-size:1.6rem;font-weight:700;color:#16a34a;">₹@Model.Amount.ToString("N0")</div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.ChequeNo)) { Field("Cheque No", Model.ChequeNo); }
                    @if (!string.IsNullOrEmpty(Model.TransactionId)) { Field("Transaction ID", Model.TransactionId); }
                    @if (!string.IsNullOrEmpty(Model.BankName)) { Field("Bank", Model.BankName); }
                    @{ Field("Note", Model.Note); }
                    @{ Field("Recorded By", Model.CreatedByName); }
                    @{ Field("Recorded On", Model.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")); }
                </div>

                @if (!string.IsNullOrEmpty(Model.ProofFile))
                {
                    <hr style="border-color:var(--border);" />
                    <div>
                        <div style="font-size:.74rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:8px;">Proof Document</div>
                        @{ var ext = System.IO.Path.GetExtension(Model.ProofFile ?? "").ToLower(); }
                        @if (ext == ".pdf")
                        {
                            <a href="/uploads/payments/@Model.ProofFile" target="_blank"
                               class="btn btn-outline-secondary" style="font-size:.83rem;">
                                <i class="bi bi-file-earmark-pdf me-1 text-danger"></i>View PDF
                            </a>
                        }
                        else
                        {
                            <img src="/uploads/payments/@Model.ProofFile" style="max-width:100%;border-radius:8px;border:1px solid var(--border);" />
                        }
                    </div>
                }
            </div>
        </div>

        @if (SessionHelper.IsAdmin(Context.Session))
        {
            <div class="mt-3">
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Remove this payment?')">
                    <button type="submit" class="btn btn-outline-danger w-100" style="font-size:.83rem;">
                        <i class="bi bi-trash3 me-1"></i>Remove Payment
                    </button>
                </form>
            </div>
        }
    </div>
</div>
