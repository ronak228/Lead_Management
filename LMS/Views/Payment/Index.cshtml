@model PaymentListViewModel
@{
    ViewData["Title"] = "Payments";
    var payRole = Context.Session.GetString("UserRole") ?? "";
}

<style>
    /* ========== PROFESSIONAL DESIGN SYSTEM (from Client Details) ========== */
    :root {
        --c-brand: #2563eb;
        --c-brand-soft: color-mix(in srgb, var(--c-brand) 8%, transparent);
        --c-text: #111827;
        --c-text-2: #374151;
        --c-muted: #6b7280;
        --c-muted-2: #9ca3af;
        --c-surface: #ffffff;
        --c-surface-2: #f9fafb;
        --c-border: #e5e7eb;
        --c-border-2: #f3f4f6;
        --c-success: #15803d;
        --c-success-soft: #f0fdf4;
        --c-danger: #b91c1c;
        --c-danger-soft: #fef2f2;
        --c-warn: #b45309;
        --c-warn-soft: #fffbeb;

        --r-sm: 6px;
        --r-md: 8px;
        --r-lg: 12px;

        --sp-1: 4px;
        --sp-2: 8px;
        --sp-3: 12px;
        --sp-4: 16px;
        --sp-5: 20px;
        --sp-6: 24px;
        --sp-7: 32px;
        --sp-8: 40px;
    }

    .payments-page {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        color: var(--c-text);
        max-width: 1400px;
        margin: 0 auto;
        padding: clamp(16px, 3vw, 28px);
        box-sizing: border-box;
        line-height: 1.5;
    }
    .payments-page * { box-sizing: border-box; }

    /* ---------- Modern page header (from Inquiry) ---------- */
    .page-header-modern {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    .page-header-modern h4 {
        font-size: 1.75rem;
        font-weight: 800;
        letter-spacing: -0.025em;
        background: linear-gradient(135deg, var(--c-text) 0%, var(--c-brand) 100%);
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin: 0 0 0.25rem 0;
        line-height: 1.15;
        display: flex;
        align-items: center;
        gap: 0.55rem;
    }
    .page-header-modern h4 i {
        -webkit-text-fill-color: var(--c-brand);
        font-size: 1.4rem;
    }
    .page-header-modern .subtitle {
        color: var(--c-muted);
        font-size: 0.88rem;
        font-weight: 500;
        margin: 0;
    }
    .page-actions-modern {
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
    }

    /* ---------- Buttons (modern) ---------- */
    .btn-primary-modern,
    .btn-outline-success-modern,
    .btn-secondary-modern {
        height: 40px;
        padding: 0 1.1rem;
        font-weight: 600;
        font-size: 0.83rem;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.45rem;
        text-decoration: none;
        white-space: nowrap;
        transition: all 0.22s cubic-bezier(.4,0,.2,1);
        line-height: 1;
        border: 1.5px solid transparent;
    }
    .btn-primary-modern {
        background: linear-gradient(135deg, #6366f1 0%, #4f46e5 50%, #7c3aed 100%);
        color: white;
        box-shadow: 0 4px 12px -3px rgba(79, 70, 229, 0.4);
    }
    .btn-primary-modern:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 18px -4px rgba(79, 70, 229, 0.5);
        color: white;
    }
    .btn-outline-success-modern {
        background: white;
        border-color: var(--c-border);
        color: var(--c-text-2);
        box-shadow: 0 1px 2px rgba(0,0,0,0.04);
    }
    .btn-outline-success-modern:hover {
        border-color: var(--c-success);
        color: var(--c-success);
        background: var(--c-success-soft);
        transform: translateY(-2px);
    }
    .btn-secondary-modern {
        background: white;
        border-color: var(--c-border);
        color: var(--c-text-2);
    }
    .btn-secondary-modern:hover {
        border-color: var(--c-brand);
        background: var(--c-brand-soft);
        color: var(--c-brand);
        transform: translateY(-1px);
    }

    /* ---------- Cards, filters, table (unchanged from your Payments code) ---------- */
    .card-modern {
        background: var(--c-surface);
        border: 1px solid var(--c-border);
        border-radius: var(--r-lg);
        overflow: hidden;
        box-shadow: 0 1px 2px rgba(0,0,0,0.03);
        margin-bottom: var(--sp-5);
    }
    .card-header {
        padding: var(--sp-4) var(--sp-5);
        border-bottom: 1px solid var(--c-border-2);
        background: var(--c-surface);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: var(--sp-3);
    }
    .card-header h6 {
        font-size: 0.9rem;
        font-weight: 700;
        margin: 0;
        color: var(--c-text);
    }
    .card-body {
        padding: var(--sp-5);
    }

    .filter-form {
        display: flex;
        flex-wrap: wrap;
        gap: var(--sp-3);
        align-items: flex-end;
    }
    .filter-group {
        flex: 1;
        min-width: 160px;
    }
    .filter-label {
        display: block;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        color: var(--c-muted);
        margin-bottom: 4px;
    }
    .filter-input {
        width: 100%;
        padding: 0.6rem 0.8rem;
        font-size: 0.85rem;
        border: 1px solid var(--c-border);
        border-radius: var(--r-md);
        transition: 0.2s;
    }
    .filter-input:focus {
        outline: none;
        border-color: var(--c-brand);
        box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
    }
    .input-group-icon {
        display: flex;
        align-items: stretch;
    }
    .input-group-icon .input-group-text {
        background: white;
        border: 1px solid var(--c-border);
        border-right: none;
        border-radius: var(--r-md) 0 0 var(--r-md);
        padding: 0 10px;
        display: flex;
        align-items: center;
        color: var(--c-muted);
    }
    .input-group-icon .filter-input {
        border-radius: 0 var(--r-md) var(--r-md) 0;
        border-left: none;
    }
    .filter-actions {
        display: flex;
        gap: var(--sp-2);
        align-items: flex-end;
    }

    .summary-card {
        border-left: 3px solid var(--c-brand);
        background: var(--c-surface);
    }
    .summary-label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--c-muted);
    }
    .total-amount {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--c-success);
    }

    .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }
    .table-modern {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.85rem;
    }
    .table-modern thead th {
        background: var(--c-surface-2);
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--c-muted);
        padding: 1rem 1rem;
        border-bottom: 1px solid var(--c-border);
        white-space: nowrap;
    }
    .table-modern tbody td {
        padding: 1rem 1rem;
        border-bottom: 1px solid var(--c-border-2);
        vertical-align: middle;
    }
    .table-modern tbody tr:last-child td {
        border-bottom: none;
    }
    .table-modern tbody tr:hover {
        background: var(--c-surface-2);
    }

    .ref-badge {
        font-family: ui-monospace, monospace;
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--c-brand);
        background: var(--c-brand-soft);
        padding: 2px 8px;
        border-radius: var(--r-sm);
        display: inline-block;
    }
    .payment-mode-badge {
        background: var(--c-brand-soft);
        color: var(--c-brand);
        font-size: 0.7rem;
        padding: 4px 10px;
        border-radius: 30px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }
    .amount-positive {
        font-weight: 700;
        color: var(--c-success);
        white-space: nowrap;
    }

    .action-group {
        display: flex;
        gap: 6px;
        justify-content: flex-end;
    }
    .btn-icon-sm {
        width: 30px;
        height: 30px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: var(--r-sm);
        border: 1px solid var(--c-border);
        background: white;
        color: var(--c-text-2);
        transition: 0.15s;
    }
    .btn-icon-sm:hover {
        background: var(--c-surface-2);
        border-color: var(--c-brand);
        color: var(--c-brand);
    }
    .btn-icon-sm.danger:hover {
        border-color: var(--c-danger);
        color: var(--c-danger);
        background: var(--c-danger-soft);
    }

    .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--c-muted);
    }
    .empty-state i {
        font-size: 3rem;
        opacity: 0.3;
        margin-bottom: 0.5rem;
        display: block;
    }

    @@media (max-width: 768px) {
        .page-header-modern h4 { font-size: 1.3rem; }
        .filter-form { flex-direction: column; align-items: stretch; }
        .filter-actions { margin-top: var(--sp-2); }
        .filter-actions .btn-custom { flex: 1; justify-content: center; }
        .filter-group { min-width: auto; }
        .table-mobile-hide { display: none; }
        .total-amount { font-size: 1.2rem; }
        .card-header { padding: var(--sp-3) var(--sp-4); }
        .card-body { padding: var(--sp-4); }
    }
    @@media (max-width: 480px) {
        .page-header-modern { flex-direction: column; align-items: stretch; }
        .page-actions-modern { width: 100%; }
        .page-actions-modern .btn-primary-modern,
        .page-actions-modern .btn-outline-success-modern { flex: 1; justify-content: center; }
    }
</style>

<div class="payments-page">
    <!-- ========== MODERN PAGE HEADER (from Inquiry) ========== -->
    <div class="page-header-modern">
        <div>
            <h4>
                <i class="bi bi-cash-coin"></i>
                @(payRole == "Client" ? "My Payments" : $"Payments{(Model.CompanyName != null ? $" – {Model.CompanyName}" : "")}")
            </h4>
            <p class="subtitle">@(payRole == "Client" ? "Your payment history" : "All recorded income & payment receipts")</p>
        </div>
        <div class="page-actions-modern">
            @if (payRole != "Client")
            {
                <a asp-action="Export" asp-route-clientId="@Model.ClientId"
                   asp-route-dateFrom="@Model.DateFrom" asp-route-dateTo="@Model.DateTo"
                   class="btn-outline-success-modern">
                    <i class="bi bi-file-earmark-excel"></i> Export
                </a>
                <a asp-controller="Payment" asp-action="Create" class="btn-primary-modern">
                    <i class="bi bi-plus-lg"></i> New Payment
                </a>
            }
        </div>
    </div>

    <!-- FILTER CARD -->
    <div class="card-modern">
        <div class="card-body">
            <form method="get" class="filter-form">
                <div class="filter-group">
                    <label class="filter-label"><i class="bi bi-search"></i> Search Company</label>
                    <div class="input-group-icon">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" name="search" value="@Model.Search" class="filter-input" placeholder="Company or ref…" />
                    </div>
                </div>
                <div class="filter-group">
                    <label class="filter-label"><i class="bi bi-calendar3"></i> From Date</label>
                    <input type="date" name="dateFrom" value="@Model.DateFrom" class="filter-input" />
                </div>
                <div class="filter-group">
                    <label class="filter-label"><i class="bi bi-calendar3"></i> To Date</label>
                    <input type="date" name="dateTo" value="@Model.DateTo" class="filter-input" />
                </div>
                @if (Model.ClientId.HasValue)
                {
                    <input type="hidden" name="clientId" value="@Model.ClientId" />
                }
                <div class="filter-actions">
                    <button type="submit" class="btn-secondary-modern">Filter</button>
                    <a asp-action="Index" class="btn-secondary-modern">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <!-- SUMMARY CARD -->
    <div class="card-modern summary-card">
        <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <div class="summary-label">TOTAL TRANSACTIONS</div>
                <div class="mt-1 fw-semibold" style="font-size:0.85rem;">@Model.Payments.Count records</div>
            </div>
            <div class="total-amount">₹@Model.TotalAmount.ToString("N0")</div>
        </div>
    </div>

    <!-- TABLE CARD -->
    <div class="card-modern">
        <div class="card-header">
            <h6><i class="bi bi-receipt"></i> Payment Records</h6>
        </div>
        @if (Model.Payments.Count == 0)
        {
            <div class="empty-state">
                <i class="bi bi-cash-stack"></i>
                <span>No payments found.</span>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table-modern">
                    <thead>
                        <tr>
                            <th style="width:45px;">#</th>
                            <th class="table-mobile-hide">Ref</th>
                            <th>Company</th>
                            <th>Date</th>
                            <th class="table-mobile-hide">Note</th>
                            <th>Amount</th>
                            <th>Mode</th>
                            <th class="text-end" style="width:100px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int sr = 1; }
                        @foreach (var p in Model.Payments)
                        {
                            <tr>
                                <td class="text-muted fw-semibold">@sr</td>
                                <td class="table-mobile-hide"><span class="ref-badge">@(p.ClientRef ?? "—")</span></td>
                                <td class="fw-semibold">@(p.CompanyName ?? "—")</td>
                                <td style="font-size:0.8rem;"><i class="bi bi-calendar3 me-1"></i> @p.PaymentDate.ToString("dd MMM yyyy")</td>
                                <td class="table-mobile-hide text-muted" style="font-size:0.75rem; max-width:150px; overflow:hidden; text-overflow:ellipsis;" title="@p.Note">
                                    @if (!string.IsNullOrEmpty(p.Note)) { <i class="bi bi-chat-text me-1"></i> }
                                    @(p.Note ?? "—")
                                </td>
                                <td class="amount-positive">₹@p.Amount.ToString("N0")</td>
                                <td>
                                    <span class="payment-mode-badge">
                                        <i class="bi bi-wallet2"></i> @p.PaymentMode
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="action-group">
                                        <a asp-action="Details" asp-route-id="@p.Id" class="btn-icon-sm" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (!string.IsNullOrEmpty(p.ProofFile))
                                        {
                                            <a href="/uploads/payments/@p.ProofFile" target="_blank" class="btn-icon-sm" title="View Proof">
                                                <i class="bi bi-paperclip"></i>
                                            </a>
                                        }
                                        @if (SessionHelper.IsAdmin(Context.Session))
                                        {
                                            <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline"
                                                  onsubmit="return confirm('Remove this payment?')">
                                                <button type="submit" class="btn-icon-sm danger" title="Delete">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                            sr++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>