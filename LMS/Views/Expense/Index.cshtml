@model ExpenseListViewModel
@{ ViewData["Title"] = "Expenses"; }

<div class="page-header d-flex align-items-start justify-content-between flex-wrap gap-2">
    <div>
        <h4>Expenses</h4>
        <p>Track all operational expenses</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Export" asp-route-categoryId="@Model.CategoryId"
           asp-route-dateFrom="@Model.DateFrom" asp-route-dateTo="@Model.DateTo"
           class="btn btn-outline-success px-3" style="font-size:.83rem;">
            <i class="bi bi-file-earmark-excel me-1"></i>Export
        </a>
        <a asp-action="Create" class="btn btn-brand px-4" style="font-size:.84rem;">
            <i class="bi bi-plus me-1"></i>Add Expense
        </a>
    </div>
</div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body py-3 px-4">
        <form method="get" class="d-flex flex-wrap gap-2 align-items-end">
            <div style="min-width:200px;flex:1;">
                <label class="form-label mb-1" style="font-size:.76rem;">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-white" style="border-right:none;"><i class="bi bi-search text-muted" style="font-size:.8rem;"></i></span>
                    <input type="text" name="search" value="@Model.Search" class="form-control" style="border-left:none;" placeholder="From / To name…" />
                </div>
            </div>
            <div style="min-width:140px;">
                <label class="form-label mb-1" style="font-size:.76rem;">Category</label>
                <select name="categoryId" class="form-select">
                    <option value="">All Categories</option>
                    @foreach (var c in Model.Categories)
                    {
                        <option value="@c.Id" selected="@(Model.CategoryId == c.Id)">@c.Name</option>
                    }
                </select>
            </div>
            <div style="min-width:110px;">
                <label class="form-label mb-1" style="font-size:.76rem;">From Date</label>
                <input type="date" name="dateFrom" value="@Model.DateFrom" class="form-control" />
            </div>
            <div style="min-width:110px;">
                <label class="form-label mb-1" style="font-size:.76rem;">To Date</label>
                <input type="date" name="dateTo" value="@Model.DateTo" class="form-control" />
            </div>
            <div class="d-flex gap-2 align-self-end">
                <button type="submit" class="btn btn-brand px-3" style="font-size:.83rem;">Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary px-3" style="font-size:.83rem;">Reset</a>
            </div>
        </form>
    </div>
</div>

<!-- Summary -->
<div class="card mb-3">
    <div class="card-body py-3 px-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span style="font-size:.75rem;color:var(--text-muted);">Total Expenses (@Model.Expenses.Count records)</span>
        <div style="font-size:1.1rem;font-weight:700;color:#dc2626;">₹@Model.TotalAmount.ToString("N0")</div>
    </div>
</div>

<!-- Table -->
<div class="card">
    <div class="card-body p-0">
        @if (Model.Expenses.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-receipt d-block mb-2" style="font-size:2.2rem;opacity:.25;"></i>
                <span style="font-size:.84rem;">No expenses found. <a asp-action="Create" style="color:var(--brand);">Add one</a></span>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-clean mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Date</th>
                            <th class="table-mobile-hide">Category</th>
                            <th class="table-mobile-hide">From</th>
                            <th class="table-mobile-hide">To</th>
                            <th>Amount</th>
                            <th class="table-mobile-hide">Mode</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int sr = 1; }
                        @foreach (var e in Model.Expenses)
                        {
                            <tr>
                                <td class="text-muted">@sr</td>
                                <td style="font-size:.8rem;">@e.ExpenseDate.ToString("dd MMM yyyy")</td>
                                <td class="table-mobile-hide" style="font-size:.8rem;">
                                    @if (!string.IsNullOrEmpty(e.CategoryName))
                                    {
                                        <span style="background:#f0f0ff;color:var(--brand);font-size:.72rem;padding:2px 8px;border-radius:20px;font-weight:600;">@e.CategoryName</span>
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td class="table-mobile-hide" style="font-size:.82rem;">@(e.FromName ?? "—")</td>
                                <td class="table-mobile-hide" style="font-size:.82rem;">@(e.ToName ?? "—")</td>
                                <td style="font-weight:700;color:#dc2626;">₹@e.Amount.ToString("N0")</td>
                                <td class="table-mobile-hide" style="font-size:.8rem;">@e.PaymentMode</td>
                                <td class="text-end">
                                    <div class="table-actions">
                                        <a asp-action="Details" asp-route-id="@e.Id"
                                           class="btn btn-sm btn-sm-icon btn-outline-secondary" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@e.Id"
                                           class="btn btn-sm btn-sm-icon btn-outline-secondary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @if (SessionHelper.IsAdmin(Context.Session))
                                        {
                                            <form asp-action="Delete" asp-route-id="@e.Id" method="post" class="d-inline"
                                                  onsubmit="return confirm('Remove this expense?')">
                                                <button type="submit" class="btn btn-sm btn-sm-icon btn-outline-danger" title="Delete">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                            sr++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
