@model Client
@{
    ViewData["Title"] = "Client Details";
    var role = Context.Session.GetString("UserRole");
    var userId = Context.Session.GetInt32("UserId");
    bool isStaff = role == "Admin" || role == "Employee";
    bool isOwnProfile = role == "Client" && userId == Model.Id;
}

<div class="page-header d-flex align-items-start justify-content-between flex-wrap gap-2">
    <div>
        <h4>@Model.CompanyName
            <span style="font-family:monospace;font-size:.75rem;color:var(--brand);font-weight:700;margin-left:8px;">@Model.ClientRef</span>
        </h4>
        <p>Full client profile</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        @if (isOwnProfile)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-brand px-4" style="font-size:.84rem;">
                <i class="bi bi-pencil me-1"></i>Edit Profile
            </a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary px-3" style="font-size:.84rem;">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-4">
    <!-- Main details -->
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header-clean">
                <h6><i class="bi bi-building me-2" style="color:var(--brand);"></i>@Model.CompanyName</h6>
                <span class="@(Model.IsActive ? "badge-active" : "badge-inactive")">
                    @(Model.IsActive ? "Active" : "Inactive")
                </span>
            </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    @{
                        void Field(string label, string? value)
                        {
                            <div class="col-sm-6">
                                <div style="font-size:.74rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:3px;">@label</div>
                                <div style="font-size:.88rem;font-weight:500;">@(value ?? "—")</div>
                            </div>
                        }
                    }
                    @{ Field("Client ID",      Model.ClientRef); }
                    @{ Field("Company Name",   Model.CompanyName); }
                    @{ Field("Contact Person", Model.ContactPerson); }
                    @{ Field("Phone",          Model.Phone); }
                    @{ Field("Email",          Model.Email); }
                    @if (isStaff && !string.IsNullOrWhiteSpace(Model.Email))
                    {
                        <div class="col-sm-6">
                            <div style="font-size:.74rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:3px;">Login Account</div>
                            <div style="font-size:.88rem;font-weight:500;">
                                <span class="badge text-bg-success" style="font-size:.77rem;"><i class="bi bi-person-check me-1"></i>Active — @Model.Email</span>
                            </div>
                        </div>
                    }
                    @{ Field("City",           Model.CityName); }
                    @{ Field("Module",         Model.ModuleName); }
                    @{ Field("Address",        Model.Address); }
                    @{ Field("Added By",       Model.CreatedByName); }
                    @{ Field("Created",        Model.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")); }
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Notes))
                {
                    <hr style="border-color:var(--border);" />
                    <div>
                        <div style="font-size:.74rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:4px;">Notes</div>
                        <p style="font-size:.88rem;margin:0;color:var(--text-main);">@Model.Notes</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Side card -->
    <div class="col-lg-4">
        <div class="card">
            <div class="card-body p-4">
                <div class="text-center mb-3">
                    <div style="width:64px;height:64px;border-radius:50%;background:var(--brand-soft);color:var(--brand);font-weight:700;font-size:1.4rem;display:flex;align-items:center;justify-content:center;margin:0 auto 10px;">
                        @(Model.CompanyName.Length > 0 ? Model.CompanyName[0].ToString().ToUpper() : "?")
                    </div>
                    <div style="font-weight:700;font-size:1rem;">@Model.CompanyName</div>
                    <div style="font-size:.8rem;color:var(--text-muted);">@Model.ContactPerson</div>
                    <div style="font-family:monospace;font-size:.76rem;color:var(--brand);font-weight:700;">@Model.ClientRef</div>
                    @if (!string.IsNullOrWhiteSpace(Model.Email))
                    {<div style="font-size:.78rem;color:var(--text-muted);">@Model.Email</div>}
                </div>
            </div>
        </div>
    </div>
</div>

@{
    var payments = ViewBag.Payments as List<Dictionary<string, object?>> ?? new List<Dictionary<string, object?>>();
}

<div class="row g-4 mt-2">
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header-clean">
                <h6><i class="bi bi-cash-stack me-2" style="color:var(--brand);"></i>Payment Summary</h6>
            </div>
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted" style="font-size:.82rem;">Contract Total</span>
                    <strong>₹@Model.TotalAmount.ToString("N0")</strong>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted" style="font-size:.82rem;">Paid So Far</span>
                    <strong class="text-success">₹@Model.TotalPaid.ToString("N0")</strong>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted" style="font-size:.82rem;">Remaining</span>
                    <strong class="text-danger">₹@Model.TotalRemaining.ToString("N0")</strong>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted" style="font-size:.82rem;">Payment Status</span>
                    <span class="badge text-bg-secondary" style="font-size:.78rem;">@Model.PaymentStatus</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header-clean">
                <h6><i class="bi bi-receipt-cutoff me-2" style="color:var(--brand);"></i>Transaction History</h6>
            </div>
            <div class="card-body p-0">
                @if (!payments.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-inbox d-block mb-2" style="font-size:2rem;opacity:.25;"></i>
                        <span style="font-size:.82rem;">No payments recorded yet.</span>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-clean mb-0">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Amount</th>
                                    <th>Mode</th>
                                    <th class="table-mobile-hide">Note</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var payment in payments)
                                {
                                    <tr>
                                        <td style="font-size:.8rem;">@Convert.ToDateTime(payment["payment_date"]).ToString("dd MMM yyyy")</td>
                                        <td style="font-weight:700;color:#16a34a;">₹@Convert.ToDecimal(payment["amount"]).ToString("N0")</td>
                                        <td style="font-size:.83rem;">@payment["payment_mode"]</td>
                                        <td class="table-mobile-hide text-muted" style="font-size:.78rem;">@(payment["note"]?.ToString() ?? "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>