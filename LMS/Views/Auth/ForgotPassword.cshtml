@model ForgotPasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Forgot Password – Lead Management</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
<link rel="stylesheet" href="~/css/site.css"/>

<style>
body {
    font-family: 'Inter', sans-serif;
    background: #f5f7fb;
}

.auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
}

.auth-card {
    width: 100%;
    max-width: 420px;
    border-radius: 12px;
    border: none;
}

.auth-logo {
    width: 50px;
    height: 50px;
    background: #6c5ce7;
    color: white;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 10px;
    font-size: 20px;
}

.btn-brand {
    background: #6c5ce7;
    color: white;
    border: none;
}

.btn-brand:hover {
    background: #5a4bd1;
}

.form-control:focus {
    box-shadow: none;
    border-color: #6c5ce7;
}

/* mobile */
@@media (max-width: 576px) {
    .auth-card .card-body {
        padding: 16px !important;
    }
}
</style>
</head>

<body>

<div class="auth-page">
    <div class="auth-card card shadow-sm overflow-hidden">

        <!-- HEADER -->
        <div class="p-4 pb-0 text-center">
            <div class="auth-logo">
                <i class="bi bi-key"></i>
            </div>
            <h5 class="fw-bold mb-1">Forgot Password</h5>
            <p class="text-muted small">Enter your email to reset password</p>
        </div>

        <!-- BODY -->
        <div class="card-body p-4 pt-3">

            @if (Model != null && !string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2 small mb-3">
                    <i class="bi bi-exclamation-triangle me-1"></i>@Model.ErrorMessage
                </div>
            }

            @if (Model != null && !string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="alert alert-success py-2 small mb-3">
                    <i class="bi bi-check-circle me-1"></i>@Model.SuccessMessage
                </div>
            }

            <form asp-action="ForgotPassword" method="post">

                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white">
                            <i class="bi bi-envelope text-muted"></i>
                        </span>
                        <input asp-for="Email" type="email" class="form-control" placeholder="you@example.com" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-brand w-100 py-2 fw-semibold">
                    <i class="bi bi-envelope me-2"></i>Send Reset Link
                </button>

            </form>

            <p class="text-center small text-muted mt-3 mb-0">
                Remember your password?
                <a asp-action="Login" style="color:var(--brand);font-weight:600;text-decoration:none;">
                    Sign in
                </a>
            </p>

        </div>

        

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>