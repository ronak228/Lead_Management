@{ Layout = null; ViewData["Title"] = "Set Your Password"; }
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Set Your Password – Lead Management</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
<link rel="stylesheet" href="~/css/site.css"/>
</head>
<body>
<div class="auth-page">
  <div class="auth-card card p-0 overflow-hidden">
    <div class="p-4 pb-0 text-center">
      <div class="auth-logo"><i class="bi bi-shield-lock"></i></div>
      <h5 class="fw-700 mb-1" style="font-weight:700;">Set Your Password</h5>
      <p class="text-muted" style="font-size:.82rem;">Welcome! Create a password to activate your account.</p>
      @if (!string.IsNullOrEmpty(ViewBag.Email as string))
      {
        <div class="mb-2"><span class="badge text-bg-light border" style="font-size:.78rem;font-weight:500;"><i class="bi bi-envelope me-1"></i>@ViewBag.Email</span></div>
      }
    </div>
    <div class="card-body p-4 pt-3">
      @if (!string.IsNullOrEmpty(TempData["Error"] as string))
      {<div class="alert alert-danger py-2 small mb-3"><i class="bi bi-exclamation-triangle me-1"></i>@TempData["Error"]</div>}
      @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage as string))
      {<div class="alert alert-danger py-2 small mb-3"><i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.ErrorMessage</div>}
      <form method="post" asp-action="SetupPassword">
        <input type="hidden" name="token" value="@ViewBag.Token" />
        <div class="mb-3">
          <label class="form-label">New Password</label>
          <div class="input-group">
            <span class="input-group-text bg-white" style="border-right:none;border-radius:8px 0 0 8px;"><i class="bi bi-lock text-muted" style="font-size:.85rem;"></i></span>
            <input type="password" name="password" class="form-control" style="border-left:none;border-radius:0 8px 8px 0;"
                   placeholder="Min. 8 characters" autocomplete="new-password" required minlength="8"/>
          </div>
        </div>
        <div class="mb-4">
          <label class="form-label">Confirm Password</label>
          <div class="input-group">
            <span class="input-group-text bg-white" style="border-right:none;border-radius:8px 0 0 8px;"><i class="bi bi-lock-fill text-muted" style="font-size:.85rem;"></i></span>
            <input type="password" name="confirmPassword" class="form-control" style="border-left:none;border-radius:0 8px 8px 0;"
                   placeholder="Repeat password" autocomplete="new-password" required minlength="8"/>
          </div>
        </div>
        <button type="submit" class="btn btn-brand w-100 py-2 fw-600" style="font-weight:600;font-size:.88rem;">
          <i class="bi bi-check-circle me-2"></i>Activate Account
        </button>
      </form>
    </div>
    <div class="px-4 py-3 text-center" style="background:var(--surface);border-top:1px solid var(--border);">
      <small class="text-muted">&copy; @DateTime.Now.Year Lead Management System</small>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body></html>
