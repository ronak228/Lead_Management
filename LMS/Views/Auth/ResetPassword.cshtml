@model ResetPasswordViewModel
@{ Layout = null; ViewData["Title"] = "Reset Password"; }
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Reset Password – Lead Management</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
<link rel="stylesheet" href="~/css/site.css"/>
</head>
<body>
<div class="auth-page">
  <div class="auth-card card p-0 overflow-hidden">
    <div class="p-4 pb-0 text-center">
      <div class="auth-logo"><i class="bi bi-lock"></i></div>
      <h5 class="fw-700 mb-1" style="font-weight:700;">Create New Password</h5>
      <p class="text-muted" style="font-size:.82rem;">Enter a new password for your account</p>
    </div>
    <div class="card-body p-4 pt-3">
      @if (!string.IsNullOrEmpty(Model.ErrorMessage))
      {<div class="alert alert-danger py-2 small mb-3"><i class="bi bi-exclamation-triangle me-1"></i>@Model.ErrorMessage</div>}
      <form asp-action="ResetPassword" method="post">
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="Token" />
        <div class="mb-3">
          <label class="form-label">New Password</label>
          <div class="input-group">
            <span class="input-group-text bg-white" style="border-right:none;border-radius:8px 0 0 8px;"><i class="bi bi-lock text-muted" style="font-size:.85rem;"></i></span>
            <input asp-for="Password" type="password" class="form-control" style="border-left:none;border-radius:0 8px 8px 0;" placeholder="••••••••"/>
          </div>
          <small class="form-text text-muted">Minimum 8 characters required.</small>
        </div>
        <div class="mb-4">
          <label class="form-label">Confirm Password</label>
          <div class="input-group">
            <span class="input-group-text bg-white" style="border-right:none;border-radius:8px 0 0 8px;"><i class="bi bi-lock text-muted" style="font-size:.85rem;"></i></span>
            <input asp-for="ConfirmPassword" type="password" class="form-control" style="border-left:none;border-radius:0 8px 8px 0;" placeholder="••••••••"/>
          </div>
        </div>
        <button type="submit" class="btn btn-brand w-100 py-2 fw-600" style="font-weight:600;font-size:.88rem;">
          <i class="bi bi-check-circle me-2"></i>Reset Password
        </button>
      </form>
      <p class="text-center small text-muted mt-3 mb-0">
        <a asp-action="Login" style="color:var(--brand);font-weight:600;text-decoration:none;">Back to Sign In</a>
      </p>
    </div>
    <div class="px-4 py-3 text-center" style="background:var(--surface);border-top:1px solid var(--border);">
      <small class="text-muted">&copy; @DateTime.Now.Year Lead Management System</small>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
