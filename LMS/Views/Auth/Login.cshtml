@model LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Sign In";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign In – Lead Management</title>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #f5f7fb;
        }

        .auth-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px;
        }

        .auth-card {
            width: 100%;
            max-width: 420px;
            border-radius: 12px;
            border: none;
        }

        .auth-logo {
            width: 50px;
            height: 50px;
            background: #6c5ce7;
            color: white;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 10px;
            font-size: 20px;
        }

        .btn-brand {
            background: #6c5ce7;
            color: white;
            border: none;
        }

        .btn-brand:hover {
            background: #5a4bd1;
        }

        .input-group-text {
            background: white;
        }

        .form-control:focus {
            box-shadow: none;
            border-color: #6c5ce7;
        }

        /* MOBILE FIX */
        @@media (max-width: 576px) {
            .auth-card {
                max-width: 100%;
                border-radius: 10px;
            }

            .auth-card .card-body {
                padding: 16px !important;
            }

            .auth-card .p-4 {
                padding: 16px !important;
            }

            h5 {
                font-size: 1.1rem;
            }

            .form-label {
                font-size: 0.85rem;
            }

            .btn {
                font-size: 0.85rem;
            }
        }
    </style>
</head>

<body>

<div class="auth-page">
    <div class="auth-card card shadow-sm overflow-hidden">

        <!-- HEADER -->
        <div class="p-4 pb-0 text-center">
            <div class="auth-logo">
                <i class="bi bi-building"></i>
            </div>
            <h5 class="fw-bold mb-1">Welcome back</h5>
            <p class="text-muted small">Sign in to your Lead Management account</p>
        </div>

        <!-- BODY -->
        <div class="card-body p-4 pt-3">

            @if (TempData["RegisterSuccess"] != null)
            {
                <div class="alert alert-success py-2 small mb-3">
                    <i class="bi bi-check-circle me-1"></i>@TempData["RegisterSuccess"]
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2 small mb-3">
                    <i class="bi bi-exclamation-triangle me-1"></i>@Model.ErrorMessage
                </div>
            }

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger py-2 small mb-3">
                    <i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.Error
                </div>
            }

            <form asp-action="Login" method="post">

                <!-- EMAIL -->
                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-envelope text-muted"></i>
                        </span>
                        <input asp-for="Email" type="email" class="form-control" placeholder="admin@hotel.com" />
                    </div>
                </div>

                <!-- PASSWORD -->
                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-lock text-muted"></i>
                        </span>
                        <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" id="pwd1" />
                        <button type="button" class="btn btn-light" onclick="togglePassword('#pwd1', this)">
                            <i class="bi bi-eye text-muted"></i>
                        </button>
                    </div>
                </div>

                <!-- BUTTON -->
                <button type="submit" class="btn btn-brand w-100 py-2 fw-semibold">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </button>

            </form>

            <!-- LINKS -->
            <p class="text-center small text-muted mt-3 mb-0">
                Don't have an account?
                <a asp-action="Register" class="fw-semibold text-decoration-none" style="color:#6c5ce7;">
                    Create one
                </a>
                <br />
                <a asp-action="ForgotPassword" class="fw-semibold text-decoration-none" style="color:#6c5ce7;">
                    Forgot password?
                </a>
            </p>
        </div>

        

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    function togglePassword(inputId, btn) {
        const input = document.querySelector(inputId);
        const icon = btn.querySelector('i');

        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('bi-eye', 'bi-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.replace('bi-eye-slash', 'bi-eye');
        }
    }
</script>

</body>
</html>