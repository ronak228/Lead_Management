@model RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Register";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Register – Lead Management</title>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- Your CSS -->
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #f5f7fb;
        }

        .auth-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px;
        }

        .auth-card {
            width: 100%;
            max-width: 420px;
            border-radius: 12px;
            border: none;
        }

        .auth-logo {
            width: 50px;
            height: 50px;
            background: #6c5ce7;
            color: white;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 10px;
            font-size: 20px;
        }

        .btn-brand {
            background: #6c5ce7;
            color: white;
            border: none;
        }

        .btn-brand:hover {
            background: #5a4bd1;
        }

        .form-control:focus {
            box-shadow: none;
            border-color: #6c5ce7;
        }

        /* 🔥 FIX FOR PASSWORD FIELD */
        .input-group {
            flex-wrap: nowrap;
        }

        .input-group .form-control {
            min-width: 0;
        }

        .input-group-text {
            display: flex;
            align-items: center;
            padding: 0;
            background: #fff;
        }

        .input-group .btn {
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 12px;
        }

        /* MOBILE */
        @@media (max-width: 576px) {
            .auth-card {
                max-width: 100%;
                border-radius: 10px;
            }

            .auth-card .card-body {
                padding: 16px !important;
            }

            .auth-card .p-4 {
                padding: 16px !important;
            }

            h5 {
                font-size: 1.1rem;
            }

            .form-label {
                font-size: 0.85rem;
            }

            .btn {
                font-size: 0.85rem;
            }
        }
    </style>
</head>

<body>

<div class="auth-page">
    <div class="auth-card card shadow-sm overflow-hidden">

        <!-- HEADER -->
        <div class="p-4 pb-0 text-center">
            <div class="auth-logo">
                <i class="bi bi-person-plus"></i>
            </div>
            <h5 class="fw-bold mb-1">Create Account</h5>
            <p class="text-muted" style="font-size:.82rem;">Join the Lead Management System</p>
        </div>

        <!-- BODY -->
        <div class="card-body p-4 pt-3">

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2 small mb-3">
                    <i class="bi bi-exclamation-triangle me-1"></i>@Model.ErrorMessage
                </div>
            }

            <form asp-action="Register" method="post" id="regForm">

                <!-- HIDDEN ROLE -->
                <input type="hidden" asp-for="Role" value="Client" />

                <!-- INFO -->
                <div class="alert alert-info py-2 mb-3 small">
                    <i class="bi bi-info-circle me-1"></i>
                    Self-registration is for <strong>Client / Hotel</strong> accounts only.
                </div>

                <!-- CLIENT FIELDS -->
                <div id="clientFields">
                    <div class="mb-3">
                        <label class="form-label">Company Name <span class="text-danger">*</span></label>
                        <input asp-for="CompanyName" type="text" class="form-control" placeholder="e.g. Grand Hyatt Hotels" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Company Phone <span class="text-danger">*</span></label>
                        <input asp-for="Phone" type="text" class="form-control" placeholder="e.g. 9876543210" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Full Name</label>
                    <input asp-for="FullName" type="text" class="form-control" placeholder="John Smith" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="john@hotel.com" />
                </div>

                <!-- PASSWORD -->
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <div class="input-group">
                        <input asp-for="Password" type="password" class="form-control" placeholder="Min. 6 characters" id="pwd1" />
                        <span class="input-group-text">
                            <button type="button" class="btn btn-light border-0" onclick="togglePassword('#pwd1', this)">
                                <i class="bi bi-eye text-muted"></i>
                            </button>
                        </span>
                    </div>
                </div>

                <!-- CONFIRM PASSWORD -->
                <div class="mb-4">
                    <label class="form-label">Confirm Password</label>
                    <div class="input-group">
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Repeat password" id="pwd2" />
                        <span class="input-group-text">
                            <button type="button" class="btn btn-light border-0" onclick="togglePassword('#pwd2', this)">
                                <i class="bi bi-eye text-muted"></i>
                            </button>
                        </span>
                    </div>
                </div>

                <!-- SUBMIT -->
                <button type="submit" class="btn btn-brand w-100 py-2 fw-semibold">
                    <i class="bi bi-person-check me-2"></i>Create Account
                </button>

            </form>

            <p class="text-center small text-muted mt-3 mb-0">
                Already have an account?
                <a asp-action="Login" style="color:var(--brand);font-weight:600;text-decoration:none;">
                    Sign in
                </a>
            </p>

        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
function togglePassword(inputId, btn) {
    const input = document.querySelector(inputId);
    const icon = btn.querySelector('i');

    if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('bi-eye', 'bi-eye-slash');
    } else {
        input.type = 'password';
        icon.classList.replace('bi-eye-slash', 'bi-eye');
    }
}
</script>

</body>
</html>