@model RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Register";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Create Account – Lead Management</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        :root {
            --brand: #6c5ce7;
            --brand-dark: #5a4bd1;
            --brand-soft: #eeebff;
            --text: #1f2440;
            --muted: #6b7280;
            --border: #e5e7eb;
            --bg: #f5f7fb;
            --success: #16a34a;
            --danger: #dc2626;
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            margin: 0;
            -webkit-font-smoothing: antialiased;
        }

        /* Decorative background blobs */
        .auth-page {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px 16px;
            overflow: hidden;
        }
        .auth-page::before,
        .auth-page::after {
            content: "";
            position: absolute;
            width: 380px;
            height: 380px;
            border-radius: 50%;
            filter: blur(90px);
            opacity: 0.35;
            z-index: 0;
        }
        .auth-page::before {
            background: #6c5ce7;
            top: -120px;
            left: -120px;
        }
        .auth-page::after {
            background: #00cec9;
            bottom: -140px;
            right: -120px;
        }

        .auth-card {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 460px;
            background: #fff;
            border-radius: 16px;
            border: 1px solid var(--border);
            box-shadow: 0 20px 50px -20px rgba(31, 36, 64, 0.18);
            animation: cardIn 0.5s ease-out both;
        }

        @@keyframes cardIn {
            from { opacity: 0; transform: translateY(12px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .auth-header {
            text-align: center;
            padding: 28px 28px 8px;
        }

        .auth-logo {
            width: 52px;
            height: 52px;
            background: linear-gradient(135deg, #6c5ce7, #8b7cf0);
            color: #fff;
            border-radius: 14px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            box-shadow: 0 8px 20px -6px rgba(108, 92, 231, 0.55);
            margin-bottom: 12px;
        }

        .auth-title {
            font-size: 1.35rem;
            font-weight: 700;
            margin: 0;
            letter-spacing: -0.01em;
        }

        .auth-subtitle {
            color: var(--muted);
            font-size: 0.875rem;
            margin: 4px 0 0;
        }

        .auth-body {
            padding: 18px 28px 28px;
        }

        .info-banner {
            display: flex;
            gap: 10px;
            align-items: flex-start;
            background: var(--brand-soft);
            color: #4b3fb3;
            border-radius: 10px;
            padding: 10px 12px;
            font-size: 0.8rem;
            margin-bottom: 16px;
        }
        .info-banner i { font-size: 1rem; line-height: 1.2; }

        .form-label {
            font-size: 0.8rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 6px;
        }

        .form-control {
            height: 42px;
            border-radius: 10px;
            border: 1px solid var(--border);
            font-size: 0.9rem;
            transition: border-color .15s, box-shadow .15s;
        }
        .form-control:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 3px rgba(108, 92, 231, 0.18);
        }

        .input-group {
            flex-wrap: nowrap;
        }
        .input-group .form-control {
            min-width: 0;
            border-right: 0;
            border-top-right-radius: 0;
            border-bottom-right-radius: 0;
        }
        .input-group-text {
            background: #fff;
            border: 1px solid var(--border);
            border-left: 0;
            border-top-right-radius: 10px;
            border-bottom-right-radius: 10px;
            color: var(--muted);
            padding: 0 12px;
            cursor: pointer;
            transition: color .15s;
        }
        .input-group-text:hover { color: var(--brand); }
        .input-group:focus-within .form-control,
        .input-group:focus-within .input-group-text {
            border-color: var(--brand);
        }
        .input-group:focus-within .form-control {
            box-shadow: -3px 0 0 -1px rgba(108, 92, 231, 0.18);
        }

        /* validation states */
        .is-valid-input { border-color: var(--success) !important; }
        .is-invalid-input { border-color: var(--danger) !important; }
        .input-group:has(.is-valid-input) .input-group-text { border-color: var(--success); }
        .input-group:has(.is-invalid-input) .input-group-text { border-color: var(--danger); }

        .field-msg {
            font-size: 0.72rem;
            margin-top: 5px;
            min-height: 14px;
            color: var(--muted);
        }
        .field-msg.valid { color: var(--success); }
        .field-msg.invalid { color: var(--danger); }

        /* Password strength */
        .pwd-strength {
            display: flex;
            gap: 4px;
            margin-top: 6px;
        }
        .pwd-strength span {
            flex: 1;
            height: 4px;
            border-radius: 3px;
            background: #e5e7eb;
            transition: background .2s;
        }
        .pwd-strength.s1 span:nth-child(1) { background: #dc2626; }
        .pwd-strength.s2 span:nth-child(-n+2) { background: #f59e0b; }
        .pwd-strength.s3 span:nth-child(-n+3) { background: #eab308; }
        .pwd-strength.s4 span { background: #16a34a; }

        .btn-brand {
            width: 100%;
            height: 44px;
            background: linear-gradient(135deg, #6c5ce7, #8b7cf0);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.92rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: transform .15s, box-shadow .2s, opacity .2s;
            box-shadow: 0 8px 18px -8px rgba(108, 92, 231, 0.7);
        }
        /* 🔥 REDUCE FORM FIELD SPACING */
.auth-body {
    padding: 16px 24px 20px; /* tighter */
}

/* reduce bootstrap gap */
.row.g-3 {
    --bs-gutter-y: 10px; /* vertical gap reduced */
}

/* remove heavy margins */
.mt-3 {
    margin-top: 10px !important;
}

/* 🔥 REMOVE EMPTY MESSAGE SPACE */
.field-msg {
    font-size: 0.72rem;
    margin-top: 3px;
    min-height: 0; /* 🔥 IMPORTANT */
    display: none;
}

.field-msg.valid,
.field-msg.invalid {
    display: block;
}

/* 🔥 TIGHT INPUT GROUP SPACING */
.input-group {
    margin-bottom: 2px;
}

/* 🔥 COMPACT LABEL */
.form-label {
    margin-bottom: 4px;
}

/* 🔥 PASSWORD STRENGTH TIGHT */
.pwd-strength {
    margin-top: 4px;
}

/* 🔥 BUTTON SPACING */
.btn-brand.mt-4 {
    margin-top: 14px !important;
}

/* 🔥 FOOTER */
.auth-footer {
    margin-top: 12px;
}
        .btn-brand:hover { transform: translateY(-1px); box-shadow: 0 12px 22px -10px rgba(108, 92, 231, 0.8); color: #fff; }
        .btn-brand:active { transform: translateY(0); }
        .btn-brand:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }

        .btn-spinner {
            width: 16px;
            height: 16px;
            border: 2px solid rgba(255,255,255,0.4);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .7s linear infinite;
            display: none;
        }
        .btn-brand.loading .btn-spinner { display: inline-block; }
        .btn-brand.loading .btn-text { opacity: 0.85; }
        @@keyframes spin { to { transform: rotate(360deg); } }

        .auth-footer {
            text-align: center;
            font-size: 0.85rem;
            color: var(--muted);
            margin-top: 18px;
        }
        .auth-footer a {
            color: var(--brand);
            font-weight: 600;
            text-decoration: none;
        }
        .auth-footer a:hover { text-decoration: underline; }

        .alert {
            border-radius: 10px;
            font-size: 0.85rem;
            padding: 10px 12px;
            border: none;
        }
        .alert-danger { background: #fee2e2; color: #991b1b; }

        /* Mobile */
        @@media (max-width: 576px) {
            .auth-header { padding: 22px 20px 4px; }
            .auth-body { padding: 14px 20px 22px; }
            .auth-title { font-size: 1.2rem; }
        }
    </style>
</head>
<body>

<div class="auth-page">
    <div class="auth-card">

        <div class="auth-header">
            <div class="auth-logo"><i class="bi bi-person-plus-fill"></i></div>
            <h1 class="auth-title">Create Account</h1>
            <p class="auth-subtitle">Join the Lead Management System</p>
        </div>

        <div class="auth-body">

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <span>@Model.ErrorMessage</span>
                </div>
            }

            <div class="info-banner">
                <i class="bi bi-info-circle-fill"></i>
                <span>Self-registration is for <strong>Client / Hotel</strong> accounts only.</span>
            </div>

            <form asp-action="Register" method="post" id="registerForm" novalidate>
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label" for="companyName">Company Name *</label>
                        <input type="text" class="form-control" id="companyName"
                               name="CompanyName" placeholder="Acme Hotels"
                               value="@Model?.CompanyName" required />
                        <div class="field-msg" id="companyNameMsg"></div>
                    </div>

                    <div class="col-sm-6">
                        <label class="form-label" for="companyPhone">Company Phone *</label>
                        <input type="tel" class="form-control" id="companyPhone"
                               name="Phone" placeholder="+91 98765 43210"
                               value="@Model?.Phone" required />
                        <div class="field-msg" id="companyPhoneMsg"></div>
                    </div>
                </div>

                <div class="mt-3">
                    <label class="form-label" for="fullName">Full Name *</label>
                    <input type="text" class="form-control" id="fullName"
                           name="FullName" placeholder="John Smith"
                           value="@Model?.FullName" required />
                    <div class="field-msg" id="fullNameMsg"></div>
                </div>

                <div class="mt-3">
                    <label class="form-label" for="email">Email Address *</label>
                    <input type="email" class="form-control" id="email"
                           name="Email" placeholder="name@hotel.com"
                           value="@Model?.Email" required />
                    <div class="field-msg" id="emailMsg"></div>
                </div>

                <div class="mt-3">
                    <label class="form-label" for="pwd1">Password *</label>
                    <div class="input-group">
                        <input type="password" class="form-control" id="pwd1"
                               name="Password" placeholder="Create a strong password" required />
                        <span class="input-group-text" onclick="togglePassword('#pwd1', this)">
                            <i class="bi bi-eye"></i>
                        </span>
                    </div>
                    <div class="pwd-strength" id="pwdStrength"><span></span><span></span><span></span><span></span></div>
                    <div class="field-msg" id="pwdMsg">Min 8 chars with uppercase, lowercase, number &amp; symbol.</div>
                </div>

                <div class="mt-3">
                    <label class="form-label" for="pwd2">Confirm Password *</label>
                    <div class="input-group">
                        <input type="password" class="form-control" id="pwd2"
                               name="ConfirmPassword" placeholder="Re-enter password" required />
                        <span class="input-group-text" onclick="togglePassword('#pwd2', this)">
                            <i class="bi bi-eye"></i>
                        </span>
                    </div>
                    <div class="field-msg" id="pwd2Msg"></div>
                </div>

                <button type="submit" class="btn-brand mt-4" id="submitBtn">
                    <span class="btn-spinner"></span>
                    <span class="btn-text">Create Account</span>
                </button>
            </form>

            <div class="auth-footer">
                Already have an account?
                <a asp-action="Login">Sign in</a>
            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    function togglePassword(inputId, btn) {
        const input = document.querySelector(inputId);
        const icon = btn.querySelector('i');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('bi-eye', 'bi-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.replace('bi-eye-slash', 'bi-eye');
        }
    }

    // ---------- Validation helpers ----------
    function setState(input, msgEl, ok, message) {
        input.classList.remove('is-valid-input', 'is-invalid-input');
        msgEl.classList.remove('valid', 'invalid');
        if (input.value.length === 0) { msgEl.textContent = ''; return; }
        if (ok) {
            input.classList.add('is-valid-input');
            msgEl.classList.add('valid');
            msgEl.textContent = message;
        } else {
            input.classList.add('is-invalid-input');
            msgEl.classList.add('invalid');
            msgEl.textContent = message;
        }
    }

    const fields = {};

    // Company name
    fields.companyName = document.getElementById('companyName');
    fields.companyName.addEventListener('input', () => {
        const v = fields.companyName.value.trim();
        setState(fields.companyName, document.getElementById('companyNameMsg'),
            v.length >= 2, v.length >= 2 ? 'Looks good' : 'At least 2 characters required');
    });

    // Phone
    fields.companyPhone = document.getElementById('companyPhone');
    fields.companyPhone.addEventListener('input', () => {
        const v = fields.companyPhone.value.trim();
        const ok = /^[+]?\d{10,13}$/.test(v.replace(/\s/g, ''));
        setState(fields.companyPhone, document.getElementById('companyPhoneMsg'),
            ok, ok ? 'Valid phone number' : 'Enter valid phone (10–13 digits)');
    });

    // Full name
    fields.fullName = document.getElementById('fullName');
    fields.fullName.addEventListener('input', () => {
        const v = fields.fullName.value.trim();
        const ok = /^[A-Za-z][A-Za-z\s.'-]{1,}$/.test(v);
        setState(fields.fullName, document.getElementById('fullNameMsg'),
            ok, ok ? 'Looks good' : 'Enter your full name (letters only)');
    });

    // Email
    fields.email = document.getElementById('email');
    fields.email.addEventListener('input', () => {
        const v = fields.email.value.trim();
        const ok = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]{2,}$/.test(v);
        setState(fields.email, document.getElementById('emailMsg'),
            ok, ok ? 'Valid email address' : 'Enter a valid email address');
    });

    // Password + strength
    const pwd1 = document.getElementById('pwd1');
    const pwd2 = document.getElementById('pwd2');
    const pwdMsg = document.getElementById('pwdMsg');
    const pwd2Msg = document.getElementById('pwd2Msg');
    const strengthBar = document.getElementById('pwdStrength');

    function passwordScore(v) {
        let s = 0;
        if (v.length >= 8) s++;
        if (/[A-Z]/.test(v) && /[a-z]/.test(v)) s++;
        if (/\d/.test(v)) s++;
        if (/[@@$!%*?&#^_\-]/.test(v)) s++;
        return s;
    }

    pwd1.addEventListener('input', () => {
        const v = pwd1.value;
        const score = passwordScore(v);
        strengthBar.className = 'pwd-strength' + (v ? ' s' + score : '');

        if (!v) {
            pwd1.classList.remove('is-valid-input', 'is-invalid-input');
            pwdMsg.className = 'field-msg';
            pwdMsg.textContent = 'Min 8 chars with uppercase, lowercase, number & symbol.';
        } else if (score === 4) {
            setState(pwd1, pwdMsg, true, 'Strong password ✔');
        } else {
            setState(pwd1, pwdMsg, false, 'Add uppercase, lowercase, number & symbol (min 8)');
        }
        if (pwd2.value) pwd2.dispatchEvent(new Event('input'));
    });

    pwd2.addEventListener('input', () => {
        const ok = pwd2.value.length > 0 && pwd2.value === pwd1.value;
        setState(pwd2, pwd2Msg, ok, ok ? 'Passwords match' : 'Passwords do not match');
    });

    // Submit handling
    const form = document.getElementById('registerForm');
    const submitBtn = document.getElementById('submitBtn');

    form.addEventListener('submit', (e) => {
        // Trigger all validations
        ['companyName','companyPhone','fullName','email'].forEach(k => {
            fields[k].dispatchEvent(new Event('input'));
        });
        pwd1.dispatchEvent(new Event('input'));
        pwd2.dispatchEvent(new Event('input'));

        const invalid = form.querySelectorAll('.is-invalid-input').length > 0;
        const empty = [...form.querySelectorAll('input[required]')].some(i => !i.value.trim());

        if (invalid || empty) {
            e.preventDefault();
            const firstBad = form.querySelector('.is-invalid-input') ||
                             [...form.querySelectorAll('input[required]')].find(i => !i.value.trim());
            if (firstBad) firstBad.focus();
            return;
        }
        submitBtn.classList.add('loading');
        submitBtn.disabled = true;
    });
</script>

</body>
</html>
