            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 12px;
        }

        /* MOBILE */
        @@media (max-width: 576px) {
            .auth-card {
                max-width: 100%;
                border-radius: 10px;
            }

            .auth-card .card-body {
                padding: 16px !important;
            }

            .auth-card .p-4 {
                padding: 16px !important;
            }

            h5 {
                font-size: 1.1rem;
