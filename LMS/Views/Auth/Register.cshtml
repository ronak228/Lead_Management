@model RegisterViewModel
@{ Layout = null; ViewData["Title"] = "Register"; }
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Register – Lead Management</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
<link rel="stylesheet" href="~/css/site.css"/>
</head>
<body>
<div class="auth-page">
  <div class="auth-card card p-0 overflow-hidden">
    <div class="p-4 pb-0 text-center">
      <div class="auth-logo"><i class="bi bi-person-plus"></i></div>
      <h5 class="fw-700 mb-1" style="font-weight:700;">Create Account</h5>
      <p class="text-muted" style="font-size:.82rem;">Join the Lead Management System</p>
    </div>
    <div class="card-body p-4 pt-3">
      @if (!string.IsNullOrEmpty(Model.ErrorMessage))
      {<div class="alert alert-danger py-2 small mb-3"><i class="bi bi-exclamation-triangle me-1"></i>@Model.ErrorMessage</div>}
      <form asp-action="Register" method="post" id="regForm">
        <!-- Account Type -->
        <div class="mb-3">
          <label class="form-label">Account Type</label>
          <select asp-for="Role" class="form-select" id="roleSelect" onchange="toggleClientFields()">
            <option value="Employee">Employee / Staff</option>
            <option value="Client">Client</option>
          </select>
          <div class="form-text" style="font-size:.74rem;">Choose <strong>Client</strong> if you are a hotel registering to submit inquiries.</div>
        </div>

        <!-- Client-only fields -->
        <div id="clientFields" style="display:none;">
          <div class="mb-3">
            <label class="form-label">Company Name <span class="text-danger">*</span></label>
            <input asp-for="CompanyName" type="text" class="form-control" placeholder="e.g. Grand Hyatt Hotels"/>
          </div>
          <div class="mb-3">
            <label class="form-label">Company Phone <span class="text-danger">*</span></label>
            <input asp-for="Phone" type="text" class="form-control" placeholder="+91 98765 43210"/>
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label">Full Name</label>
          <input asp-for="FullName" type="text" class="form-control" placeholder="John Smith"/>
        </div>
        <div class="mb-3">
          <label class="form-label">Email Address</label>
          <input asp-for="Email" type="email" class="form-control" placeholder="john@hotel.com"/>
        </div>
        <div class="mb-3">
          <label class="form-label">Password</label>
          <input asp-for="Password" type="password" class="form-control" placeholder="Min. 6 characters"/>
        </div>
        <div class="mb-4">
          <label class="form-label">Confirm Password</label>
          <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Repeat password"/>
        </div>
        <button type="submit" class="btn btn-brand w-100 py-2" style="font-weight:600;font-size:.88rem;">
          <i class="bi bi-person-check me-2"></i>Create Account
        </button>
      </form>
      <p class="text-center small text-muted mt-3 mb-0">
        Already have an account? <a asp-action="Login" style="color:var(--brand);font-weight:600;text-decoration:none;">Sign in</a>
      </p>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function toggleClientFields() {
    var role = document.getElementById('roleSelect').value;
    document.getElementById('clientFields').style.display = role === 'Client' ? 'block' : 'none';
  }
  // Restore on validation error
  toggleClientFields();
</script>
</body></html>
