@model List<UserListItem>
@{
    ViewData["Title"] = "User Management";
    var search = ViewBag.Search as string ?? "";
    var filterRole = ViewBag.FilterRole as string ?? "";
    var sessionId = Context.Session.GetInt32("UserId");
}

<style>
    /* Clean professional styles matching other pages */
    
    /* Card enhancements */
    .card {
        border-radius: 16px;
        border: 1px solid rgba(0, 0, 0, 0.05);
        background: #ffffff;
    }
    
    /* Button refinements */
    .btn-brand {
        background-color: #0d6efd;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.2s ease;
    }
    
    .btn-brand:hover {
        background-color: #0b5ed7;
        transform: translateY(-1px);
    }
    
    .btn-outline-success {
        border-radius: 8px;
        font-weight: 500;
        transition: all 0.2s ease;
        border: 1.5px solid #198754;
        color: #198754;
    }
    
    .btn-outline-success:hover {
        background-color: #198754;
        color: white;
    }
    
    .btn-outline-secondary {
        border-radius: 8px;
        transition: all 0.2s ease;
    }
    
    .btn-outline-warning {
        border-radius: 8px;
        transition: all 0.2s ease;
        border: 1.5px solid #ffc107;
        color: #ffc107;
    }
    
    .btn-outline-warning:hover {
        background-color: #ffc107;
        color: white;
    }
    
    .btn-outline-danger {
        border-radius: 8px;
        transition: all 0.2s ease;
    }
    
    /* Card header */
    .card-header-clean {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        padding: 1rem 1.25rem;
        background: #ffffff;
        border-bottom: 1px solid #e9ecef;
    }
    
    .card-header-clean h6 {
        font-weight: 700;
        font-size: 0.9rem;
        margin-bottom: 0;
        color: #1a2c3e;
    }
    
    /* Filter form */
    .filter-form {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        align-items: flex-end;
    }
    
    .filter-form .input-group {
        min-width: 200px;
    }
    
    .filter-form .form-control,
    .filter-form .form-select,
    .filter-form .input-group-text {
        border-radius: 8px;
    }
    
    .filter-form .form-control:focus,
    .filter-form .form-select:focus {
        box-shadow: 0 0 0 2px rgba(13, 110, 253, 0.1);
        border-color: #0d6efd;
    }
    
    /* Clean table styling - Optimized for desktop */
    .table-clean {
        border-collapse: collapse;
        width: 100%;
        table-layout: fixed;
    }
    
    .table-clean thead th {
        background: #f8f9fa;
        font-weight: 700;
        font-size: 0.73rem;
        text-transform: uppercase;
        letter-spacing: 0.3px;
        color: #495057;
        border-bottom: 2px solid #dee2e6;
        padding: 0.875rem 0.75rem;
    }
    
    .table-clean tbody td {
        padding: 0.875rem 0.75rem;
        vertical-align: middle;
        border-bottom: 1px solid #e9ecef;
    }
    
    /* Optimized column widths */
    .table-clean th:first-child,
    .table-clean td:first-child {
        width: 45px;
        padding-left: 1rem;
    }
    
    .table-clean th:nth-child(2),
    .table-clean td:nth-child(2) {
        width: 22%;
    }
    
    .table-clean th:nth-child(3),
    .table-clean td:nth-child(3) {
        width: 25%;
    }
    
    .table-clean th:nth-child(4),
    .table-clean td:nth-child(4) {
        width: 95px;
    }
    
    .table-clean th:nth-child(5),
    .table-clean td:nth-child(5) {
        width: 90px;
    }
    
    .table-clean th:nth-child(6),
    .table-clean td:nth-child(6) {
        width: 85px;
    }
    
    .table-clean th:last-child,
    .table-clean td:last-child {
        width: auto;
        padding-right: 1rem;
    }
    
    /* User avatar */
    .user-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #f0f0ff;
        color: #0d6efd;
        font-weight: 700;
        font-size: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    
    .user-info {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: nowrap;
    }
    
    .user-name {
        font-weight: 600;
        color: #1f3a4e;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    
    /* Badge styles */
    .badge-admin,
    .badge-warning,
    .badge-user,
    .badge-active,
    .badge-inactive {
        font-size: 0.7rem;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        white-space: nowrap;
    }
    
    .badge-admin {
        background: #fef3f2;
        color: #dc2626;
    }
    
    .badge-warning {
        background: #fff8e7;
        color: #f59e0b;
    }
    
    .badge-user {
        background: #eaf9ef;
        color: #16a34a;
    }
    
    .badge-active {
        background: #eaf9ef;
        color: #16a34a;
    }
    
    .badge-inactive {
        background: #fef3f2;
        color: #dc2626;
    }
    
    /* Role select dropdown for desktop - Fixed width to show full text */
    .role-select {
        font-size: 0.73rem;
        border-radius: 6px;
        border: 1px solid #dee2e6;
        padding: 0.2rem 0.5rem;
        background: white;
        cursor: pointer;
        width: 100px;
        min-width: 100px;
    }
    
    .role-select option {
        padding: 4px 8px;
    }
    
    .role-select:focus {
        box-shadow: 0 0 0 2px rgba(13, 110, 253, 0.1);
        border-color: #0d6efd;
    }
    
    /* Simple action buttons - Compact and in one row */
    .table-actions {
        display: flex;
        gap: 5px;
        justify-content: flex-end;
        align-items: center;
        flex-wrap: nowrap;
    }
    
    .table-actions .btn-sm-icon {
        width: 28px;
        height: 28px;
        padding: 0;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #dee2e6;
        background: white;
        transition: none;
        flex-shrink: 0;
    }
    
    .table-actions .btn-sm-icon:hover {
        background-color: #f8f9fa;
    }
    
    .table-actions .btn-outline-secondary:hover {
        background-color: #0d6efd;
        border-color: #0d6efd;
        color: white;
    }
    
    .table-actions .btn-outline-warning:hover {
        background-color: #ffc107;
        border-color: #ffc107;
        color: white;
    }
    
    .table-actions .btn-outline-danger:hover {
        background-color: #dc2626;
        border-color: #dc2626;
        color: white;
    }
    
    .table-actions .btn-outline-success:hover {
        background-color: #16a34a;
        border-color: #16a34a;
        color: white;
    }
    
    /* Role change form group - Compact */
    .role-change-form {
        display: inline-flex;
        gap: 4px;
        align-items: center;
        flex-wrap: nowrap;
    }
    
    /* Input group */
    .input-group .input-group-text {
        background-color: white;
        border-radius: 8px 0 0 8px;
        border-right: none;
    }
    
    .input-group .form-control {
        border-radius: 0 8px 8px 0;
        border-left: none;
    }
    
    /* You badge */
    .you-badge {
        background: #eaf9ef;
        color: #16a34a;
        font-size: 0.6rem;
        padding: 2px 6px;
        border-radius: 10px;
        font-weight: 600;
        margin-left: 6px;
        display: inline-block;
        white-space: nowrap;
    }
    
    /* Email truncation */
    .user-email {
        font-size: 0.78rem;
        color: #6c757d;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    
    /* Date cell */
    .date-cell {
        font-size: 0.73rem;
        white-space: nowrap;
    }
    
    /* Mobile card view */
    .mobile-view {
        display: none;
    }
    
    .mobile-user-card {
        background: white;
        border-radius: 12px;
        margin-bottom: 12px;
        padding: 16px;
        border: 1px solid #e9ecef;
        transition: all 0.2s ease;
    }
    
    .mobile-user-card:hover {
        border-color: #dee2e6;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }
    
    .mobile-user-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
    }
    
    .mobile-user-info {
        flex: 1;
    }
    
    .mobile-user-name {
        font-weight: 700;
        color: #1f3a4e;
        font-size: 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }
    
    .mobile-user-email {
        font-size: 0.75rem;
        color: #6c757d;
        margin-top: 4px;
        word-break: break-all;
    }
    
    .mobile-user-details {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 12px;
        padding-top: 8px;
        border-top: 1px solid #f0f4fa;
    }
    
    .mobile-detail-item {
        flex: 1;
        min-width: 80px;
    }
    
    .mobile-detail-label {
        font-size: 0.65rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.3px;
        color: #6c757d;
        margin-bottom: 4px;
    }
    
    .mobile-detail-value {
        font-size: 0.85rem;
    }
    
    .mobile-actions {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid #f0f4fa;
        flex-wrap: wrap;
    }
    
    .mobile-role-btn {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 6px 12px;
        font-size: 0.75rem;
        font-weight: 600;
        color: #495057;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    
    .mobile-role-btn:hover {
        background: #e9ecef;
        border-color: #cbd5e0;
    }
    
    /* Modal styling */
    .role-modal .modal-content {
        border-radius: 20px;
        border: none;
    }
    
    .role-modal .modal-header {
        border-bottom: 1px solid #e9ecef;
        padding: 1rem 1.25rem;
        background: #f8f9fa;
        border-radius: 20px 20px 0 0;
    }
    
    .role-modal .modal-body {
        padding: 1.5rem;
    }
    
    .role-option {
        padding: 12px 16px;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s ease;
        border: 1px solid #e9ecef;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    
    .role-option:hover {
        background: #f8f9fa;
        border-color: #0d6efd;
        transform: translateX(4px);
    }
    
    .role-option.selected {
        background: #f0f0ff;
        border-color: #0d6efd;
        color: #0d6efd;
    }
    
    .role-option-icon {
        width: 40px;
        height: 40px;
        border-radius: 40px;
        background: #f0f0ff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }
    
    .role-option-info {
        flex: 1;
    }
    
    .role-option-title {
        font-weight: 700;
        font-size: 0.9rem;
        margin-bottom: 2px;
    }
    
    .role-option-desc {
        font-size: 0.7rem;
        color: #6c757d;
    }
    
    /* Desktop view */
    @@media (min-width: 1025px) {
        .desktop-table {
            display: block;
        }
        
        .mobile-view {
            display: none;
        }
    }
    
    /* Laptop view (769px - 1024px) */
    @@media (min-width: 769px) and (max-width: 1024px) {
        .desktop-table {
            display: block;
        }
        
        .mobile-view {
            display: none;
        }
        
        .table-clean thead th,
        .table-clean tbody td {
            padding: 0.7rem 0.5rem;
        }
        
        .badge-admin,
        .badge-warning,
        .badge-user,
        .badge-active,
        .badge-inactive {
            padding: 2px 8px;
            font-size: 0.65rem;
        }
        
        .table-actions .btn-sm-icon {
            width: 26px;
            height: 26px;
        }
        
        .role-select {
            font-size: 0.7rem;
            padding: 0.15rem 0.4rem;
            width: 95px;
            min-width: 95px;
        }
        
        .user-email {
            font-size: 0.72rem;
        }
        
        .user-name {
            font-size: 0.8rem;
        }
    }
    
    /* Mobile view */
    @@media (max-width: 768px) {
        body {
            padding: 12px;
        }
        
        .page-header h4 {
            font-size: 1.3rem;
        }
        
        .desktop-table {
            display: none;
        }
        
        .mobile-view {
            display: block;
        }
        
        .filter-form {
            flex-direction: column;
            align-items: stretch;
        }
        
        .filter-form .input-group {
            max-width: 100%;
        }
        
        .filter-form .form-select {
            width: 100% !important;
        }
        
        .filter-form .btn {
            width: 100%;
        }
        
        .card-header-clean {
            flex-direction: column;
            align-items: stretch;
        }
    }
    
    /* Simple scrollbar */
    .table-responsive::-webkit-scrollbar {
        height: 6px;
    }
    
    .table-responsive::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 3px;
    }
    
    .table-responsive::-webkit-scrollbar-thumb {
        background: #cbd5e0;
        border-radius: 3px;
    }
</style>

<div class="page-header d-flex align-items-start justify-content-between flex-wrap gap-2 mb-4">
    <div>
        <h4>User Management</h4>
        <p class="text-muted small mb-0">View and manage all registered users</p>
    </div>
    <div class="d-flex align-items-center gap-2">
        <span class="text-muted" style="font-size:.8rem; background: #f8f9fa; padding: 4px 12px; border-radius: 20px;">
            <i class="bi bi-people me-1"></i>@Model.Count user(s)
        </span>
    </div>
</div>

<!-- Search -->
<div class="card mb-4 shadow-sm">
    <div class="card-body py-3 px-4">
        <form method="get" class="filter-form">
            <!-- Search field: icon above input -->
            <div class="flex-grow-1" style="min-width:200px;">
                <label class="form-label mb-1" style="font-size:.75rem; font-weight:600; color:#6c757d;">
                    <i class="bi bi-search me-1"></i> Search
                </label>
                <input type="text" name="search" value="@search" class="form-control" 
                       placeholder="Search by name or email…" />
            </div>
            <select name="filterRole" class="form-select" style="width:auto; border-radius:8px;">
                <option value="">All Roles</option>
                @if (filterRole == "Admin")
                {
                    <option value="Admin" selected>Admin</option>
                }
                else
                {
                    <option value="Admin">Admin</option>
                }
                @if (filterRole == "Employee")
                {
                    <option value="Employee" selected>Employee</option>
                }
                else
                {
                    <option value="Employee">Employee</option>
                }
                @if (filterRole == "Client")
                {
                    <option value="Client" selected>Client</option>
                }
                else
                {
                    <option value="Client">Client</option>
                }
            </select>
            <button type="submit" class="btn btn-brand px-3" style="font-size:.83rem;">
                <i class="bi bi-search me-1"></i>Search
            </button>
            @if (!string.IsNullOrEmpty(search) || !string.IsNullOrEmpty(filterRole))
            {
                <a asp-action="Index" class="btn btn-outline-secondary px-3" style="font-size:.83rem;">
                    <i class="bi bi-arrow-repeat me-1"></i>Clear
                </a>
            }
        </form>
    </div>
</div>

<!-- Desktop Table View -->
<div class="card shadow-sm desktop-table">
    <div class="card-header-clean">
        <h6><i class="bi bi-people me-2" style="color:#0d6efd;"></i>All Users</h6>
    </div>
    <div class="card-body p-0">
        @if (Model.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-person-x d-block mb-2" style="font-size:2.2rem;opacity:.25;"></i>
                <span style="font-size:.84rem;">No users found.</span>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-clean mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Joined</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int sr = 1; }
                        @foreach (var u in Model)
                        {
                            var isSelf = u.Id == sessionId;
                            <tr>
                                <td class="text-muted fw-semibold">@sr</td>
                                <td>
                                    <div class="user-info">
                                        <div class="user-avatar">
                                            @(u.FullName.Length > 0 ? u.FullName[0].ToString().ToUpper() : "?")
                                        </div>
                                        <span class="user-name">
                                            @u.FullName
                                            @if (isSelf)
                                            {
                                                <span class="you-badge">
                                                    <i class="bi bi-person-check me-1" style="font-size:.55rem;"></i>You
                                                </span>
                                            }
                                        </span>
                                    </div>
                                </td>
                                <td class="user-email">
                                    <i class="bi bi-envelope me-1" style="font-size:.7rem;"></i>@u.Email
                                </td>
                                <td>
                                    <span class="@(u.Role == "Admin" ? "badge-admin" : u.Role == "Employee" ? "badge-warning" : "badge-user")">
                                        @if (u.Role == "Admin")
                                        {
                                            <i class="bi bi-shield me-1" style="font-size:.6rem;"></i>
                                        }
                                        else if (u.Role == "Employee")
                                        {
                                            <i class="bi bi-briefcase me-1" style="font-size:.6rem;"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-person me-1" style="font-size:.6rem;"></i>
                                        }
                                        @u.Role
                                    </span>
                                </td>
                                <td>
                                    <span class="@(u.IsActive ? "badge-active" : "badge-inactive")">
                                        @if (u.IsActive)
                                        {
                                            <i class="bi bi-check-circle me-1" style="font-size:.6rem;"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-x-circle me-1" style="font-size:.6rem;"></i>
                                        }
                                        @(u.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="date-cell">
                                    <i class="bi bi-calendar3 me-1" style="font-size:.65rem;"></i>
                                    @u.CreatedAt.ToString("dd MMM yyyy")
                                </td>
                                <td class="text-end">
                                    @if (!isSelf)
                                    {
                                        <div class="table-actions">
                                            <form asp-action="ChangeRole" method="post" class="role-change-form">
                                                <input type="hidden" name="id" value="@u.Id" />
                                                <select name="role" class="role-select">
                                                    <option value="Admin" selected="@(u.Role == "Admin")">👑 Admin</option>
                                                    <option value="Employee" selected="@(u.Role == "Employee")">💼 Employee</option>
                                                    <option value="Client" selected="@(u.Role == "Client")">👤 Client</option>
                                                </select>
                                                <button type="submit" class="btn btn-sm btn-sm-icon btn-outline-secondary" title="Update role">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                            </form>
                                            <form asp-action="Toggle" asp-route-id="@u.Id" method="post" class="d-inline">
                                                <button type="submit"
                                                        class="btn btn-sm btn-sm-icon @(u.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                        title="@(u.IsActive ? "Deactivate" : "Activate")">
                                                    <i class="bi @(u.IsActive ? "bi-person-dash" : "bi-person-check")"></i>
                                                </button>
                                            </form>
                                            <form asp-action="Delete" asp-route-id="@u.Id" method="post" class="d-inline"
                                                  onsubmit="return confirm('⚠️ Remove user @u.FullName? Their data will be preserved in audit logs.')">
                                                <button type="submit"
                                                        class="btn btn-sm btn-sm-icon btn-outline-danger"
                                                        title="Remove">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted" style="font-size:.7rem;">
                                            <i class="bi bi-lock me-1"></i>Current
                                        </span>
                                    }
                                </td>
                            </tr>
                            sr++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Mobile Card View -->
<div class="mobile-view">
    @if (Model.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-person-x d-block mb-2" style="font-size:2.2rem;opacity:.25;"></i>
            <span style="font-size:.84rem;">No users found.</span>
        </div>
    }
    else
    {
        @foreach (var u in Model)
        {
            var isSelf = u.Id == sessionId;
            <div class="mobile-user-card">
                <div class="mobile-user-header">
                    <div class="user-avatar" style="width: 44px; height: 44px; font-size: 1rem;">
                        @(u.FullName.Length > 0 ? u.FullName[0].ToString().ToUpper() : "?")
                    </div>
                    <div class="mobile-user-info">
                        <div class="mobile-user-name">
                            @u.FullName
                            @if (isSelf)
                            {
                                <span class="you-badge">
                                    <i class="bi bi-person-check me-1" style="font-size:.6rem;"></i>You
                                </span>
                            }
                        </div>
                        <div class="mobile-user-email">
                            <i class="bi bi-envelope me-1" style="font-size:.65rem;"></i>@u.Email
                        </div>
                    </div>
                </div>
                <div class="mobile-user-details">
                    <div class="mobile-detail-item">
                        <div class="mobile-detail-label">Role</div>
                        <div class="mobile-detail-value">
                            <span class="@(u.Role == "Admin" ? "badge-admin" : u.Role == "Employee" ? "badge-warning" : "badge-user")" style="display: inline-flex;">
                                @if (u.Role == "Admin")
                                {
                                    <i class="bi bi-shield me-1" style="font-size:.65rem;"></i>
                                }
                                else if (u.Role == "Employee")
                                {
                                    <i class="bi bi-briefcase me-1" style="font-size:.65rem;"></i>
                                }
                                else
                                {
                                    <i class="bi bi-person me-1" style="font-size:.65rem;"></i>
                                }
                                @u.Role
                            </span>
                        </div>
                    </div>
                    <div class="mobile-detail-item">
                        <div class="mobile-detail-label">Status</div>
                        <div class="mobile-detail-value">
                            <span class="@(u.IsActive ? "badge-active" : "badge-inactive")" style="display: inline-flex;">
                                @if (u.IsActive)
                                {
                                    <i class="bi bi-check-circle me-1" style="font-size:.65rem;"></i>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle me-1" style="font-size:.65rem;"></i>
                                }
                                @(u.IsActive ? "Active" : "Inactive")
                            </span>
                        </div>
                    </div>
                    <div class="mobile-detail-item">
                        <div class="mobile-detail-label">Joined</div>
                        <div class="mobile-detail-value" style="font-size: 0.75rem;">
                            <i class="bi bi-calendar3 me-1" style="font-size:.65rem;"></i>
                            @u.CreatedAt.ToString("dd MMM yyyy")
                        </div>
                    </div>
                </div>
                @if (!isSelf)
                {
                    <div class="mobile-actions">
                        <button type="button" class="mobile-role-btn" onclick="openRoleModal('@u.Id', '@u.FullName', '@u.Role')">
                            <i class="bi bi-arrow-repeat"></i>
                            Change Role
                        </button>
                        <form asp-action="Toggle" asp-route-id="@u.Id" method="post" class="d-inline">
                            <button type="submit"
                                    class="btn btn-sm btn-sm-icon @(u.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                    title="@(u.IsActive ? "Deactivate" : "Activate")">
                                <i class="bi @(u.IsActive ? "bi-person-dash" : "bi-person-check")"></i>
                            </button>
                        </form>
                        <form asp-action="Delete" asp-route-id="@u.Id" method="post" class="d-inline"
                              onsubmit="return confirm('⚠️ Remove user @u.FullName? Their data will be preserved in audit logs.')">
                            <button type="submit"
                                    class="btn btn-sm btn-sm-icon btn-outline-danger"
                                    title="Remove">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="mobile-actions">
                        <span class="text-muted" style="font-size:.74rem; width: 100%; text-align: center;">
                            <i class="bi bi-lock me-1"></i>Current user - cannot modify
                        </span>
                    </div>
                }
            </div>
        }
    }
</div>

<!-- Role Change Modal -->
<div class="modal fade role-modal" id="roleModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title fw-600">
                    <i class="bi bi-person-badge me-2" style="color:#0d6efd;"></i>Change Role
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-3" id="roleUserName">Loading...</p>
                <form id="roleChangeForm" asp-action="ChangeRole" method="post">
                    <input type="hidden" name="id" id="roleUserId" />
                    <input type="hidden" name="role" id="selectedRole" />
                    <div class="role-option" onclick="selectRole('Admin')">
                        <div class="role-option-icon">👑</div>
                        <div class="role-option-info">
                            <div class="role-option-title">Admin</div>
                            <div class="role-option-desc">Full system access</div>
                        </div>
                        <div class="role-check" id="checkAdmin"></div>
                    </div>
                    <div class="role-option" onclick="selectRole('Employee')">
                        <div class="role-option-icon">💼</div>
                        <div class="role-option-info">
                            <div class="role-option-title">Employee</div>
                            <div class="role-option-desc">Limited operational access</div>
                        </div>
                        <div class="role-check" id="checkEmployee"></div>
                    </div>
                    <div class="role-option" onclick="selectRole('Client')">
                        <div class="role-option-icon">👤</div>
                        <div class="role-option-info">
                            <div class="role-option-title">Client</div>
                            <div class="role-option-desc">View-only access</div>
                        </div>
                        <div class="role-check" id="checkClient"></div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-light" data-bs-dismiss="modal">
                    <i class="bi bi-x me-1"></i>Cancel
                </button>
                <button type="button" class="btn btn-brand btn-sm px-4" onclick="submitRoleChange()">
                    <i class="bi bi-check me-1"></i>Update Role
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let currentUserId = null;
    let currentUserRole = null;
    
    function openRoleModal(userId, userName, currentRole) {
        currentUserId = userId;
        currentUserRole = currentRole;
        document.getElementById('roleUserId').value = userId;
        document.getElementById('roleUserName').innerHTML = `<i class="bi bi-person me-1"></i>Select new role for <strong>${userName}</strong>`;
        
        document.querySelectorAll('.role-check').forEach(el => el.innerHTML = '');
        
        if (currentRole === 'Admin') {
            document.getElementById('checkAdmin').innerHTML = '<i class="bi bi-check-circle-fill" style="color:#0d6efd; font-size:1.2rem;"></i>';
        } else if (currentRole === 'Employee') {
            document.getElementById('checkEmployee').innerHTML = '<i class="bi bi-check-circle-fill" style="color:#0d6efd; font-size:1.2rem;"></i>';
        } else {
            document.getElementById('checkClient').innerHTML = '<i class="bi bi-check-circle-fill" style="color:#0d6efd; font-size:1.2rem;"></i>';
        }
        
        document.querySelectorAll('.role-option').forEach(opt => opt.classList.remove('selected'));
        if (currentRole === 'Admin') {
            document.querySelector('.role-option:first-child').classList.add('selected');
        } else if (currentRole === 'Employee') {
            document.querySelectorAll('.role-option')[1].classList.add('selected');
        } else {
            document.querySelectorAll('.role-option')[2].classList.add('selected');
        }
        
        new bootstrap.Modal(document.getElementById('roleModal')).show();
    }
    
    function selectRole(role) {
        document.getElementById('selectedRole').value = role;
        
        document.querySelectorAll('.role-check').forEach(el => el.innerHTML = '');
        if (role === 'Admin') {
            document.getElementById('checkAdmin').innerHTML = '<i class="bi bi-check-circle-fill" style="color:#0d6efd; font-size:1.2rem;"></i>';
        } else if (role === 'Employee') {
            document.getElementById('checkEmployee').innerHTML = '<i class="bi bi-check-circle-fill" style="color:#0d6efd; font-size:1.2rem;"></i>';
        } else {
            document.getElementById('checkClient').innerHTML = '<i class="bi bi-check-circle-fill" style="color:#0d6efd; font-size:1.2rem;"></i>';
        }
        
        document.querySelectorAll('.role-option').forEach(opt => opt.classList.remove('selected'));
        if (role === 'Admin') {
            document.querySelector('.role-option:first-child').classList.add('selected');
        } else if (role === 'Employee') {
            document.querySelectorAll('.role-option')[1].classList.add('selected');
        } else {
            document.querySelectorAll('.role-option')[2].classList.add('selected');
        }
    }
    
    function submitRoleChange() {
        const selectedRole = document.getElementById('selectedRole').value;
        if (!selectedRole) {
            alert('Please select a role');
            return;
        }
        if (selectedRole === currentUserRole) {
            alert('This is already the current role');
            return;
        }
        document.getElementById('roleChangeForm').submit();
    }
</script>
}

<!-- Ensure Bootstrap JS is loaded -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>